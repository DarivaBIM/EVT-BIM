<Window x:Class="FamiliesImporterHub.UI.ParameterEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editor de parâmetros"
        Width="380"
        SizeToContent="Height"
        ResizeMode="CanMinimize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Background="#F4F7FB"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Closed="OnWindowClosed">

    <Window.Resources>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SoftBorderBrush" Color="#D8E0EA" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F172A" />
        <SolidColorBrush x:Key="LabelBrush" Color="#64748B" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="ActiveBrush" Color="#16A34A" />
        <SolidColorBrush x:Key="ErrorBrush" Color="#DC2626" />

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource LabelBrush}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="28" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="28" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,4,0,8" />
        </Style>

        <Style x:Key="SelectButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelectionActive}" Value="True">
                    <Setter Property="Background" Value="{StaticResource ActiveBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HintTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="Foreground" Value="{StaticResource LabelBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="ValidationTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource LabelBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,8,0,0" />
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource CardBackgroundBrush}"
            BorderBrush="{StaticResource SoftBorderBrush}"
            BorderThickness="1"
            CornerRadius="14"
            Margin="12"
            Padding="16">
        <StackPanel>
            <TextBlock Text="Editor de parâmetros"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,4" />

            <TextBlock Text="Selecione elementos do projeto e atribua um valor a um parâmetro comum a todos eles."
                       Style="{StaticResource HintTextStyle}" />

            <Button x:Name="SelectButton"
                    Style="{StaticResource SelectButtonStyle}"
                    Content="Selecionar elementos"
                    Click="OnSelectClicked" />

            <TextBlock Text="{Binding SelectionSummary}"
                       Style="{StaticResource HintTextStyle}" />

            <TextBlock Text="Parâmetro" Style="{StaticResource FieldLabelStyle}" />
            <ComboBox x:Name="ParameterComboBox"
                      ItemsSource="{Binding Parameters}"
                      SelectedItem="{Binding SelectedParameter}"
                      DisplayMemberPath="DisplayName" />
            <TextBlock Text="{Binding ValueTypeHint}" Style="{StaticResource HintTextStyle}" />

            <TextBlock Text="Valor" Style="{StaticResource FieldLabelStyle}" />
            <TextBox x:Name="ValueTextBox"
                     Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding IsParameterSelected}" />
            <TextBlock Text="{Binding ValidationMessage}"
                       Style="{StaticResource ValidationTextStyle}" />

            <Button x:Name="ApplyButton"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="Aplicar nos elementos selecionados"
                    Click="OnApplyClicked" />

            <TextBlock x:Name="StatusTextBlock"
                       Style="{StaticResource StatusTextStyle}"
                       Text="{Binding StatusMessage}" />
        </StackPanel>
    </Border>
</Window>
