<Window x:Class="DarivaBIM.FamilyBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="DarivaBIM — Importar Famílias"
        Width="1100" Height="800"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <!--
        Window-shell minimo: o conteudo inteiro e um WebView2 que aponta pra
        URL passada no construtor. Nada de UI WPF tradicional (lista de
        familias, busca, etc.) — tudo isso vive no AcervoBIM Next.js.

        Status bar inferior mostra a URL atual, o estado de carregamento e
        o estado da conexao com o plugin Revit (pipe). O botao "Teste IPC"
        e debug-only: dispara um ImportFamily fake direto pelo bridge (sem
        precisar do AcervoBIM ter implementado a integracao ainda).
    -->
    <DockPanel>
        <Border DockPanel.Dock="Bottom"
                Background="#1E1E1E"
                Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusUrl"
                           Grid.Column="0"
                           Foreground="#A0A0A0"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="StatusState"
                           Grid.Column="1"
                           Foreground="#A0A0A0"
                           FontSize="11"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Text="Inicializando…" />
                <TextBlock x:Name="StatusPipe"
                           Grid.Column="2"
                           Foreground="#A0A0A0"
                           FontSize="11"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Text="Pipe: —" />
                <Button x:Name="DebugButton"
                        Grid.Column="3"
                        Content="Teste IPC"
                        Margin="12,0,0,0"
                        Padding="8,2"
                        FontSize="11"
                        Background="#333"
                        Foreground="#DDD"
                        BorderBrush="#555"
                        BorderThickness="1"
                        Cursor="Hand"
                        Click="OnDebugClick" />
            </Grid>
        </Border>
        <wv2:WebView2 x:Name="WebView" />
    </DockPanel>
</Window>
