<Project>

  <PropertyGroup>
    <Product>DarivaBIM</Product>
    <Company>DarivaBIM</Company>
    <Authors>DarivaBIM</Authors>
    <Copyright>Copyright (c) DarivaBIM</Copyright>
    <Version>0.1.0</Version>
    <AssemblyVersion>0.1.0.0</AssemblyVersion>
    <FileVersion>0.1.0.0</FileVersion>

    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>

    <!--
      Higiene de build:
      - TreatWarningsAsErrors em Release evita que avisos virem regressao
        silenciosa. Debug fica permissivo para nao quebrar fluxo iterativo.
      - AnalysisLevel=latest + EnforceCodeStyleInBuild aplicam analyzers
        oficiais e estilo definido pelo .editorconfig em todos os projetos.
      - Deterministic garante que dois builds da mesma revisao geram bytes
        identicos, simplificando cache de CI e diffs binarios.
    -->
    <TreatWarningsAsErrors Condition="'$(Configuration)' == 'Release'">true</TreatWarningsAsErrors>
    <AnalysisLevel>latest</AnalysisLevel>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <Deterministic>true</Deterministic>

    <PlatformTarget>x64</PlatformTarget>
    <Platforms>x64</Platforms>

    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <NeutralLanguage>pt-BR</NeutralLanguage>

    <!--
      Per-Revit-version target frameworks. Projects opt in by setting RevitVersion.
      Active scope per ADR-0015: Revit 2025 and 2026 only.
      Note: RevitVersion is set in each csproj's PropertyGroup, which is evaluated
      AFTER this file. Conditions referencing $(RevitVersion) here will see the
      empty value, so per-version properties (RevitInstallDir) are resolved in
      Directory.Build.targets instead. RevitTargetFramework is kept here only
      because no project currently uses it as its <TargetFramework> value.
    -->
    <RevitTargetFramework Condition="'$(RevitVersion)' == '2025'">net8.0-windows</RevitTargetFramework>
    <RevitTargetFramework Condition="'$(RevitVersion)' == '2026'">net8.0-windows</RevitTargetFramework>

    <!--
      The compile-fence symbol REVIT$(RevitVersion) is appended to
      DefineConstants in Directory.Build.targets, after each csproj has had a
      chance to set <RevitVersion>. Doing it here would expand to the empty
      value because the project's PropertyGroup hasn't run yet.
    -->
  </PropertyGroup>

  <PropertyGroup>
    <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
  </PropertyGroup>

</Project>
