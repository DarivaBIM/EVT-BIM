<Project>

  <PropertyGroup>
    <Product>DarivaBIM</Product>
    <Company>DarivaBIM</Company>
    <Authors>DarivaBIM</Authors>
    <Copyright>Copyright (c) DarivaBIM</Copyright>
    <Version>0.1.0</Version>
    <AssemblyVersion>0.1.0.0</AssemblyVersion>
    <FileVersion>0.1.0.0</FileVersion>

    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>

    <PlatformTarget>x64</PlatformTarget>
    <Platforms>x64</Platforms>

    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <NeutralLanguage>pt-BR</NeutralLanguage>

    <!--
      Per-Revit-version target frameworks. Projects opt in by setting RevitVersion.
      Note: RevitVersion is set in each csproj's PropertyGroup, which is evaluated
      AFTER this file. Conditions referencing $(RevitVersion) here will see the
      empty value, so per-version properties (RevitInstallDir) are resolved in
      Directory.Build.targets instead. RevitTargetFramework is kept here only
      because no project currently uses it as its <TargetFramework> value.
    -->
    <RevitTargetFramework Condition="'$(RevitVersion)' == '2023'">net48</RevitTargetFramework>
    <RevitTargetFramework Condition="'$(RevitVersion)' == '2024'">net48</RevitTargetFramework>
    <RevitTargetFramework Condition="'$(RevitVersion)' == '2025'">net8.0-windows</RevitTargetFramework>
    <RevitTargetFramework Condition="'$(RevitVersion)' == '2026'">net8.0-windows</RevitTargetFramework>
    <RevitTargetFramework Condition="'$(RevitVersion)' == '2027'">net10.0-windows</RevitTargetFramework>

    <!-- Symbol shared across the codebase to compile-fence per-version code. -->
    <DefineConstants Condition="'$(RevitVersion)' != ''">$(DefineConstants);REVIT$(RevitVersion)</DefineConstants>
  </PropertyGroup>

  <PropertyGroup>
    <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
  </PropertyGroup>

</Project>
