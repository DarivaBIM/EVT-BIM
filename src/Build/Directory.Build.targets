<Project>

  <!--
    Resolve RevitInstallDir here (instead of Directory.Build.props) so the
    project's <RevitVersion> PropertyGroup has already been evaluated. Without
    this, RevitInstallDir would be evaluated when RevitVersion is still empty
    and the Reference HintPaths below would resolve to "\RevitAPI.dll".
  -->
  <PropertyGroup Condition="'$(RevitVersion)' != ''">
    <RevitInstallDir Condition="'$(RevitVersion)' == '2023' AND '$(REVIT_2023_PATH)' != ''">$(REVIT_2023_PATH)</RevitInstallDir>
    <RevitInstallDir Condition="'$(RevitVersion)' == '2023' AND '$(RevitInstallDir)' == ''">C:\Program Files\Autodesk\Revit 2023</RevitInstallDir>
    <RevitInstallDir Condition="'$(RevitVersion)' == '2024' AND '$(REVIT_2024_PATH)' != ''">$(REVIT_2024_PATH)</RevitInstallDir>
    <RevitInstallDir Condition="'$(RevitVersion)' == '2024' AND '$(RevitInstallDir)' == ''">C:\Program Files\Autodesk\Revit 2024</RevitInstallDir>
    <RevitInstallDir Condition="'$(RevitVersion)' == '2025' AND '$(REVIT_2025_PATH)' != ''">$(REVIT_2025_PATH)</RevitInstallDir>
    <RevitInstallDir Condition="'$(RevitVersion)' == '2025' AND '$(RevitInstallDir)' == ''">C:\Program Files\Autodesk\Revit 2025</RevitInstallDir>
    <RevitInstallDir Condition="'$(RevitVersion)' == '2026' AND '$(REVIT_2026_PATH)' != ''">$(REVIT_2026_PATH)</RevitInstallDir>
    <RevitInstallDir Condition="'$(RevitVersion)' == '2026' AND '$(RevitInstallDir)' == ''">C:\Program Files\Autodesk\Revit 2026</RevitInstallDir>
    <RevitInstallDir Condition="'$(RevitVersion)' == '2027' AND '$(REVIT_2027_PATH)' != ''">$(REVIT_2027_PATH)</RevitInstallDir>
    <RevitInstallDir Condition="'$(RevitVersion)' == '2027' AND '$(RevitInstallDir)' == ''">C:\Program Files\Autodesk\Revit 2027</RevitInstallDir>
  </PropertyGroup>

  <!--
    Common Revit references for any project that opts in by setting
    RevitVersion. Provides RevitAPI.dll and RevitAPIUI.dll as Reference items.
    Uses HintPath into the per-version install directory and CopyLocal=false
    so the assemblies are not redistributed.
  -->
  <ItemGroup Condition="'$(RevitVersion)' != ''">
    <Reference Include="RevitAPI">
      <HintPath>$(RevitInstallDir)\RevitAPI.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="RevitAPIUI">
      <HintPath>$(RevitInstallDir)\RevitAPIUI.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

</Project>
