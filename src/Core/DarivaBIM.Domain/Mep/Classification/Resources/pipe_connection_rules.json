{
  "version": "2.0",
  "discipline": "Plumbing",
  "description": "Pipe connection rulebook MVP 1 (subtypes da secao 18; tokens normalizados sem acento); primaryAngleRule sempre em angulo RAW entre BasisZ dos conectores (0..180), deflexao de catalogo vive em nominalAngleDeg (decisao 2.B-2 Codex Opcao B)",

  "baseKindTokens": {
    "elbow": ["joelho", "curva"],
    "tee": ["te"],
    "wye": ["juncao", "wye"],
    "union": ["luva", "uniao"],
    "reducer": ["reducao", "bucha", "redutor", "adaptador"],
    "cap": ["cap", "tampao", "plug"],
    "valve": ["registro", "valvula", "esfera", "gaveta", "retencao"],
    "cross": ["cruzeta", "cross"],
    "multiport": ["manifold", "barrilete", "distribuidor", "coletor"]
  },

  "tokenAliases": {
    "te": ["tee"],
    "juncao": ["wye", "lateral"],
    "reducao": ["redutor"],
    "curva": ["bend", "curve"],
    "uniao": ["coupling"],
    "joelho": ["elbow", "cotovelo"]
  },

  "negativeTokens": {
    "te": ["terminal", "tempo", "teflon"],
    "sn": ["snake"],
    "sr": ["sra"]
  },

  "tolerances": {
    "angleDeg": 5,
    "diameterMm": 2
  },

  "rules": [
    {
      "id": "cap",
      "baseKind": "Cap",
      "geometryKind": "Unspecified",
      "topology": {
        "partTypeAccepts": ["Cap", "Other", "Undefined"],
        "connectorCount": 1
      },
      "lexicalHints": ["cap", "tampao", "plug"]
    },

    {
      "id": "union-simple",
      "baseKind": "Union",
      "geometryKind": "Straight",
      "nominalAngleDeg": 180,
      "topology": {
        "partTypeAccepts": ["Union", "PipeFlange", "Transition", "Other", "Undefined"],
        "connectorCount": 2,
        "diameterRule": { "mode": "roles", "constraints": [ { "ports": ["RunA", "RunB"], "relation": "equal" } ] },
        "primaryAngleRule": { "minDeg": 175, "maxDeg": 185 }
      },
      "lexicalDisambiguators": [
        { "trigger": "rosca", "promoteTo": "union-threaded", "mandatoryLexical": ["rosca"], "topologyMustMatch": true }
      ],
      "lexicalHints": ["luva", "uniao"]
    },
    {
      "id": "union-threaded",
      "baseKind": "Union",
      "geometryKind": "Straight",
      "nominalAngleDeg": 180,
      "topology": { "inherits": "union-simple" },
      "lexicalHints": ["rosca"],
      "requiresLexicalConfirmation": true
    },

    {
      "id": "reducer-concentric",
      "baseKind": "Reducer",
      "geometryKind": "Straight",
      "nominalAngleDeg": 180,
      "topology": {
        "partTypeAccepts": ["Transition", "Other", "Undefined"],
        "connectorCount": 2,
        "diameterRule": { "mode": "roles", "constraints": [ { "ports": ["RunLarge", "RunSmall"], "relation": "different" } ] },
        "primaryAngleRule": { "minDeg": 175, "maxDeg": 185 }
      },
      "lexicalDisambiguators": [
        { "trigger": "excentrica", "promoteTo": "reducer-eccentric", "mandatoryLexical": ["excentrica"], "topologyMustMatch": true },
        { "trigger": "bucha", "promoteTo": "bushing", "mandatoryLexical": ["bucha"], "topologyMustMatch": true },
        { "trigger": "adaptador", "promoteTo": "adapter", "mandatoryLexical": ["adaptador"], "topologyMustMatch": true },
        { "trigger": "nipel", "promoteTo": "male-female-connector", "mandatoryLexical": ["nipel"], "topologyMustMatch": true }
      ],
      "lexicalHints": ["reducao", "redutor"]
    },
    {
      "id": "reducer-eccentric",
      "baseKind": "Reducer",
      "geometryKind": "Straight",
      "nominalAngleDeg": 180,
      "topology": { "inherits": "reducer-concentric" },
      "lexicalHints": ["excentrica"],
      "requiresLexicalConfirmation": true
    },
    {
      "id": "bushing",
      "baseKind": "Reducer",
      "geometryKind": "Straight",
      "nominalAngleDeg": 180,
      "topology": { "inherits": "reducer-concentric" },
      "lexicalHints": ["bucha"],
      "requiresLexicalConfirmation": true
    },
    {
      "id": "adapter",
      "baseKind": "Reducer",
      "geometryKind": "Straight",
      "nominalAngleDeg": 180,
      "topology": { "inherits": "reducer-concentric" },
      "lexicalHints": ["adaptador"],
      "requiresLexicalConfirmation": true
    },
    {
      "id": "male-female-connector",
      "baseKind": "Reducer",
      "geometryKind": "Straight",
      "nominalAngleDeg": 180,
      "topology": { "inherits": "reducer-concentric" },
      "lexicalHints": ["nipel", "macho", "femea"],
      "requiresLexicalConfirmation": true
    },

    {
      "id": "elbow-45",
      "baseKind": "Elbow",
