      ],
      "lexicalHints": ["joelho"]
    },
    {
      "id": "elbow-90",
      "baseKind": "Elbow",
      "geometryKind": "ShortRadius",
      "nominalAngleDeg": 90,
      "topology": {
        "partTypeAccepts": ["Elbow", "Offset", "Other", "Undefined"],
        "connectorCount": 2,
        "diameterRule": { "mode": "roles", "constraints": [ { "ports": ["RunA", "RunB"], "relation": "equal" } ] },
        "primaryAngleRule": { "minDeg": 85, "maxDeg": 95 }
