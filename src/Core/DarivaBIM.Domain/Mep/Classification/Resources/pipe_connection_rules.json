      "id": "tee-misturador",
      "baseKind": "Tee",
      "geometryKind": "Branch",
      "nominalAngleDeg": 90,
      "topology": { "inherits": "tee" },
      "lexicalHints": ["misturador"],
      "requiresLexicalConfirmation": true
    },
    {
      "id": "tee-threaded",
      "baseKind": "Tee",
      "geometryKind": "Branch",
      "nominalAngleDeg": 90,
      "topology": { "inherits": "tee" },
      "lexicalHints": ["rosca"],
      "requiresLexicalConfirmation": true
