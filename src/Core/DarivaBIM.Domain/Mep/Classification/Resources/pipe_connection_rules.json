        { "trigger": "rosca", "promoteTo": "tee-threaded", "mandatoryLexical": ["rosca"], "topologyMustMatch": true }
      ],
      "lexicalHints": ["te"]
    },
    {
      "id": "tee-reducer",
      "baseKind": "Tee",
      "geometryKind": "Branch",
      "nominalAngleDeg": 90,
      "topology": {
        "inherits": "tee",
        "overrides": {
          "diameterRule": { "mode": "roles", "constraints": [ { "ports": ["RunA", "RunB"], "relation": "equal" }, { "ports": ["Branch"], "relation": "lessThan", "target": "RunA" } ] }
        }
      },
      "lexicalHints": ["reducao"]
    },
    {
      "id": "tee-inspection",
      "baseKind": "Tee",
      "geometryKind": "Branch",
      "nominalAngleDeg": 90,
      "topology": { "inherits": "tee" },
      "lexicalHints": ["inspecao"],
      "requiresLexicalConfirmation": true
    },
