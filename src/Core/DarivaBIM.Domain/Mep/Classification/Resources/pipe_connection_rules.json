        { "trigger": "bucha", "promoteTo": "elbow-brass-bushing", "mandatoryLexical": ["bucha", "latao"], "topologyMustMatch": true },
        { "trigger": "transposicao", "promoteTo": "transposition-curve", "mandatoryLexical": ["transposicao"], "topologyMustMatch": true },
        { "trigger": "visita", "promoteTo": "elbow-visit", "mandatoryLexical": ["visita"], "topologyMustMatch": true }
      ],
      "lexicalHints": ["joelho"]
    },
    {
      "id": "elbow-reducer",
      "baseKind": "Elbow",
      "geometryKind": "ShortRadius",
      "topology": {
        "inherits": "elbow-90",
        "overrides": {
          "diameterRule": { "mode": "roles", "constraints": [ { "ports": ["RunLarge", "RunSmall"], "relation": "different" } ] },
          "primaryAngleRule": { "minDeg": 85, "maxDeg": 140 }
        }
      },
      "lexicalHints": ["reducao"]
    },
    {
      "id": "elbow-threaded",
      "baseKind": "Elbow",
      "geometryKind": "ShortRadius",
      "nominalAngleDeg": 90,
      "topology": { "inherits": "elbow-90" },
      "lexicalHints": ["rosca"],
      "requiresLexicalConfirmation": true
    },
    {
      "id": "elbow-brass-bushing",
      "baseKind": "Elbow",
      "geometryKind": "ShortRadius",
      "nominalAngleDeg": 90,
      "topology": { "inherits": "elbow-90" },
      "lexicalHints": ["bucha", "latao"],
      "requiresLexicalConfirmation": true
    },
    {
      "id": "elbow-visit",
      "baseKind": "Elbow",
      "geometryKind": "ShortRadius",
      "nominalAngleDeg": 90,
      "topology": { "inherits": "elbow-90" },
      "lexicalHints": ["visita"],
      "requiresLexicalConfirmation": true
    },
    {
      "id": "long-radius-bend-45",
      "baseKind": "Elbow",
      "geometryKind": "LongRadius",
      "nominalAngleDeg": 45,
      "topology": { "inherits": "elbow-45" },
      "lexicalHints": ["curva"],
      "requiresLexicalConfirmation": true
    },
    {
      "id": "long-radius-bend-90",
      "baseKind": "Elbow",
      "geometryKind": "LongRadius",
      "nominalAngleDeg": 90,
      "topology": { "inherits": "elbow-90" },
      "lexicalHints": ["curva"],
