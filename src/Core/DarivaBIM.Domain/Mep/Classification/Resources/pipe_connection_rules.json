      "id": "tee",
      "baseKind": "Tee",
      "geometryKind": "Branch",
      "nominalAngleDeg": 90,
      "topology": {
        "partTypeAccepts": ["Tee", "LateralTee", "TapPerpendicular", "TapAdjustable", "SpudPerpendicular", "SpudAdjustable", "Other", "Undefined"],
        "connectorCount": 3,
        "diameterRule": { "mode": "roles", "constraints": [ { "ports": ["RunA", "RunB"], "relation": "equal" } ] },
        "primaryAngleRule": { "minDeg": 175, "maxDeg": 185 },
        "lateralAngleRule": { "minDeg": 85, "maxDeg": 95 }
