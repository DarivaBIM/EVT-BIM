<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--
        Design tokens do PipeCADMapper redesign — paleta clara, geometria
        consistente entre cards, inputs e botões.

        Os tokens são consumidos pelos Styles em Themes/Controls.xaml e pela
        janela em Ui/PipeConverterWindow.xaml. Estão isolados deste arquivo
        para permitir um eventual tema escuro futuro alterando apenas as
        cores aqui sem mexer em templates.
    -->

    <!-- ===== Cores base (paleta clara) ===== -->
    <Color x:Key="AppBgColor">#F3F4F6</Color>
    <Color x:Key="CardBgColor">#FFFFFF</Color>
    <Color x:Key="CardBgSubtleColor">#FAFAFB</Color>
    <Color x:Key="BorderColor">#E5E7EB</Color>
    <Color x:Key="BorderStrongColor">#D1D5DB</Color>
    <Color x:Key="DividerColor">#EEF0F3</Color>

    <Color x:Key="TextColor">#0F172A</Color>
    <Color x:Key="TextMutedColor">#475569</Color>
    <Color x:Key="TextSubtleColor">#94A3B8</Color>

    <Color x:Key="InputBgColor">#FFFFFF</Color>
    <Color x:Key="InputBorderColor">#D7DBE0</Color>
    <Color x:Key="InputBorderFocusColor">#1F6FEB</Color>

    <Color x:Key="AccentColor">#1F6FEB</Color>
    <Color x:Key="AccentHoverColor">#1A5FCC</Color>
    <Color x:Key="AccentSoftColor">#E8F0FE</Color>
    <Color x:Key="SuccessColor">#10894C</Color>

    <Color x:Key="ShadowColor">#0F172A</Color>

    <!-- ===== Brushes ===== -->
    <SolidColorBrush x:Key="AppBgBrush"           Color="{StaticResource AppBgColor}" />
    <SolidColorBrush x:Key="CardBgBrush"          Color="{StaticResource CardBgColor}" />
    <SolidColorBrush x:Key="CardBgSubtleBrush"    Color="{StaticResource CardBgSubtleColor}" />
    <SolidColorBrush x:Key="BorderBrush"          Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="BorderStrongBrush"    Color="{StaticResource BorderStrongColor}" />
    <SolidColorBrush x:Key="DividerBrush"         Color="{StaticResource DividerColor}" />

    <SolidColorBrush x:Key="TextBrush"            Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="TextMutedBrush"       Color="{StaticResource TextMutedColor}" />
    <SolidColorBrush x:Key="TextSubtleBrush"      Color="{StaticResource TextSubtleColor}" />

    <SolidColorBrush x:Key="InputBgBrush"         Color="{StaticResource InputBgColor}" />
    <SolidColorBrush x:Key="InputBorderBrush"     Color="{StaticResource InputBorderColor}" />
    <SolidColorBrush x:Key="InputBorderFocusBrush" Color="{StaticResource InputBorderFocusColor}" />

    <SolidColorBrush x:Key="AccentBrush"          Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush"     Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentSoftBrush"      Color="{StaticResource AccentSoftColor}" />
    <SolidColorBrush x:Key="SuccessBrush"         Color="{StaticResource SuccessColor}" />

    <!-- ===== Tipografia ===== -->
    <!--
        WPF não tem fallback CSS-style por família dentro de uma única
        FontFamily. "Segoe UI Variable" só existe a partir do Win11; em
        Win10/Revit antigos ele cai automaticamente para Segoe UI via WPF
        font fallback se a primeira não for encontrada. Caso contrário,
        "Segoe UI Variable, Segoe UI" funciona em algumas builds.
    -->
    <FontFamily x:Key="BodyFont">Segoe UI Variable Text, Segoe UI</FontFamily>
    <FontFamily x:Key="DisplayFont">Segoe UI Variable Display, Segoe UI</FontFamily>
    <FontFamily x:Key="MonoFont">Cascadia Mono, Consolas</FontFamily>

    <!-- ===== Raios ===== -->
    <sys:Double x:Key="Radius4">4</sys:Double>
    <sys:Double x:Key="Radius6">6</sys:Double>
    <sys:Double x:Key="Radius8">8</sys:Double>
    <sys:Double x:Key="Radius10">10</sys:Double>

    <CornerRadius x:Key="CornerRadius4">4</CornerRadius>
    <CornerRadius x:Key="CornerRadius6">6</CornerRadius>
    <CornerRadius x:Key="CornerRadius8">8</CornerRadius>
    <CornerRadius x:Key="CornerRadius10">10</CornerRadius>

    <!-- ===== Sombra padrão de card =====
         BlurRadius=4, ShadowDepth=1, Opacity=0.06, Color=Shadow. Usamos
         x:Shared="False" porque DropShadowEffect é alterado em runtime
         por alguns triggers (item ativo do segmented control) e queremos
         instâncias independentes por consumidor.
    -->
    <DropShadowEffect x:Key="CardShadow"
                      x:Shared="False"
                      BlurRadius="4"
                      ShadowDepth="1"
                      Direction="270"
                      Opacity="0.06"
                      Color="{StaticResource ShadowColor}" />

</ResourceDictionary>
