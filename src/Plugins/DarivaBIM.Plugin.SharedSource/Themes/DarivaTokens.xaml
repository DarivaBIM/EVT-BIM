<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--
        DarivaBIM design tokens — tema "Cream Paper" com acento coral.

        Esta dictionary é mergeada na Page.Resources de cada janela WPF do
        plugin. Mantenha tudo aqui (cores, tipografia, raios) para que o
        tema seja trocável em um único ponto.

        Convenções:
        - Brushes Frozen (a Avalonia/WPF freeza automaticamente quando o
          .Freeze() não é possível em XAML — mas no .NET 8 + WPF, brushes
          declarados em ResourceDictionary que não dependem de binding
          já são freezáveis pela engine).
        - Não use oklch direto — converta para hex; WPF não interpreta oklch.
    -->

    <!-- 2.1 Cores base do tema. Paper foi de #FBFAF7 (creme claro) para
         #EFEDE8 — mais para o cinza-quente; o creme excessivo deixava o
         painel parecer "amarelado" sobre o chrome cinza do Revit. As
         demais cores deslizaram um pouco para o cinza junto, preservando
         contraste relativo entre Paper/Surface/Rail. -->
    <Color x:Key="PaperColor">#FCFAF5</Color>     <!-- área de conteúdo -->
    <Color x:Key="SurfaceColor">#FFFFFF</Color>   <!-- card / search bg -->
    <Color x:Key="RailColor">#F4F0E9</Color>      <!-- sidebar / footer -->
    <Color x:Key="RailActiveColor">#FFFFFF</Color>
    <Color x:Key="ThumbBgColor">#F5F1EA</Color>   <!-- thumb area do card -->
    <Color x:Key="LineColor">#ECE6DA</Color>      <!-- bordas + divisores -->
    <Color x:Key="LineSoftColor">#EDE7DC</Color>  <!-- borda do search -->
    <Color x:Key="InkColor">#1A1815</Color>
    <Color x:Key="InkSoftColor">#6B6358</Color>
    <Color x:Key="InkFaintColor">#8B8275</Color>
    <Color x:Key="AccentColor">#D6633A</Color>
    <Color x:Key="AccentSoftColor">#FBEBE0</Color>

    <!-- Sinalizações -->
    <Color x:Key="SuccessColor">#16A34A</Color>   <!-- bullet "Sincronizado" -->
    <Color x:Key="HeartColor">#D94668</Color>
    <Color x:Key="WarnColor">#A87A3B</Color>

    <!-- Logo DarivaBIM -->
    <Color x:Key="LogoTileColor">#1D6FB8</Color>

    <SolidColorBrush x:Key="Paper" Color="{StaticResource PaperColor}" />
    <SolidColorBrush x:Key="Surface" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="Rail" Color="{StaticResource RailColor}" />
    <SolidColorBrush x:Key="RailActive" Color="{StaticResource RailActiveColor}" />
    <SolidColorBrush x:Key="ThumbBg" Color="{StaticResource ThumbBgColor}" />
    <SolidColorBrush x:Key="Line" Color="{StaticResource LineColor}" />
    <SolidColorBrush x:Key="LineSoft" Color="{StaticResource LineSoftColor}" />
    <SolidColorBrush x:Key="Ink" Color="{StaticResource InkColor}" />
    <SolidColorBrush x:Key="InkSoft" Color="{StaticResource InkSoftColor}" />
    <SolidColorBrush x:Key="InkFaint" Color="{StaticResource InkFaintColor}" />
    <SolidColorBrush x:Key="Accent" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentSoft" Color="{StaticResource AccentSoftColor}" />
    <SolidColorBrush x:Key="Success" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="Heart" Color="{StaticResource HeartColor}" />
    <SolidColorBrush x:Key="Warn" Color="{StaticResource WarnColor}" />
    <SolidColorBrush x:Key="LogoTile" Color="{StaticResource LogoTileColor}" />

    <!-- 2.2 Brushes translúcidos. Mantemos como tokens para que a janela
         consumidora não precise usar literais hex com canal alfa inline,
         que ficam invisíveis na revisão e fogem do tema. -->
    <Color x:Key="HeartChipBackgroundColor">#B3FFFFFF</Color>   <!-- chip do coração sobre o thumb -->
    <Color x:Key="OverlayBackgroundColor">#F2FBFAF7</Color>     <!-- overlay translúcido da galeria -->

    <SolidColorBrush x:Key="HeartChipBackground" Color="{StaticResource HeartChipBackgroundColor}" />
    <SolidColorBrush x:Key="OverlayBackground" Color="{StaticResource OverlayBackgroundColor}" />

    <!-- 2.3 Tipografia (Inter/Inter Tight não vieram no handoff; cai em
         Segoe UI que é o sans-serif moderno do Windows e tem proporções
         próximas o suficiente para preservar o feel da spec). WPF não faz
         fallback CSS-style: use uma única família por chave e module o peso
         pelo Setter de FontWeight. -->
    <FontFamily x:Key="DisplayFont">Segoe UI</FontFamily>
    <FontFamily x:Key="BodyFont">Segoe UI</FontFamily>
    <FontFamily x:Key="MonoFont">Consolas</FontFamily>

    <!-- 2.4 Raios de canto (CornerRadius é um struct; expomos como sys:Double
         e instanciamos onde for usado para evitar boxing). -->
    <sys:Double x:Key="RadiusCard">10</sys:Double>
    <sys:Double x:Key="RadiusInput">10</sys:Double>
    <sys:Double x:Key="RadiusButton">8</sys:Double>
    <sys:Double x:Key="RadiusPill">999</sys:Double>

    <!-- 8.3 Tooltip preto (Ink). Aplica-se a TODA Tooltip do escopo onde
         este dict for mergeado, por ser um Style sem x:Key. -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{StaticResource Ink}" />
        <Setter Property="Foreground" Value="{StaticResource Paper}" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="10.5" />
        <Setter Property="HasDropShadow" Value="False" />
        <Setter Property="Placement" Value="Top" />
        <Setter Property="VerticalOffset" Value="-4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Section card — borda hairline, raio 10. Usado para containers
         de busca/filtros. -->
    <Style x:Key="SectionCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Surface}" />
        <Setter Property="BorderBrush" Value="{StaticResource Line}" />
        <Setter Property="BorderThickness" Value="0.5" />
        <Setter Property="CornerRadius" Value="10" />
    </Style>

    <!-- 8.2 Family card — sombra hover + outline coral. -->
    <Style x:Key="FamilyCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Surface}" />
        <Setter Property="BorderBrush" Value="{StaticResource Line}" />
        <Setter Property="BorderThickness" Value="0.5" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="Cursor" Value="Hand" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect ShadowDepth="2"
                                          BlurRadius="16"
                                          Opacity="0.10"
                                          Color="{StaticResource InkColor}" />
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Texto base do corpo. -->
    <Style x:Key="BodyTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource Ink}" />
    </Style>

    <!-- Subtítulo CAPS (9px). WPF não tem letter-spacing nativo no
         TextBlock; emulamos passando o texto já em UPPERCASE pelo XAML
         e dependemos do peso 600 + tamanho pequeno para reforçar a
         hierarquia. Sem isso, simular tracking exigiria FormattedText
         + DrawingVisual, custo desproporcional ao ganho visual. -->
    <Style x:Key="EyebrowTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource InkFaint}" />
    </Style>

    <!-- Header H1 — 22px display, peso 600. -->
    <Style x:Key="HeaderTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DisplayFont}" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Ink}" />
    </Style>

</ResourceDictionary>
