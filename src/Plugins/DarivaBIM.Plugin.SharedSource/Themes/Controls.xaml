<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--
        Styles e ControlTemplates reutilizáveis para a janela do
        PipeCADMapper. Depende dos tokens definidos em Themes/Tokens.xaml
        — o ResourceDictionary consumidor precisa mergear Tokens.xaml
        antes deste arquivo.
    -->

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Themes/Tokens.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- =========================================================== -->
    <!-- Botões                                                       -->
    <!-- =========================================================== -->

    <!--
        Botão primário — usado para ações principais (selecionar CAD,
        criar marcadores, converter). Altura 34, raio 6, fundo Accent
        com hover AccentHover e estado disabled atenuado.
    -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="34" />
        <Setter Property="MinWidth" Value="120" />
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                          TextElement.FontWeight="SemiBold" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BorderStrongBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource TextSubtleBrush}" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        Botão secundário — outline Accent, fundo transparente. Usado
        para a ação "Selecionar outro vínculo CAD" e similares.
    -->
    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="34" />
        <Setter Property="MinWidth" Value="120" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                          TextElement.FontWeight="SemiBold" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource TextSubtleBrush}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        Botão fantasma — usado para "Marcar todas as linhas do layer"
        e similares, ações neutras paralelas a uma primária.
    -->
    <Style x:Key="GhostButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="34" />
        <Setter Property="MinWidth" Value="120" />
        <Setter Property="Background" Value="{StaticResource CardBgSubtleBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                          TextElement.FontWeight="SemiBold" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AppBgBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource CardBgSubtleBrush}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource TextSubtleBrush}" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================== -->
    <!-- TextBox + suporte a sufixo via Tag                           -->
    <!-- =========================================================== -->

    <!--
        TextBoxStyle — altura 34, raio 6. Se a propriedade Tag estiver
        setada com um texto, ele é renderizado à direita do conteúdo
        com cor TextSubtle (ex.: "mm"). Quando Tag é null, o slot do
        sufixo é colapsado.
    -->
    <Style x:Key="TextBoxStyle" TargetType="TextBox">
        <Setter Property="Height" Value="34" />
        <Setter Property="Background" Value="{StaticResource InputBgBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource TextBrush}" />
        <Setter Property="SelectionBrush" Value="{StaticResource AccentSoftBrush}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Grid.Column="0"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden" />
                            <TextBlock x:Name="Suffix"
                                       Grid.Column="1"
                                       Text="{TemplateBinding Tag}"
                                       Margin="0,0,12,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSubtleBrush}"
                                       FontSize="12" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Tag" Value="{x:Null}">
                            <Setter TargetName="Suffix" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource InputBorderFocusBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource TextSubtleBrush}" />
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource CardBgSubtleBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================== -->
    <!-- ComboBox: ToggleButton + Popup com chevron customizado       -->
    <!-- =========================================================== -->

    <!--
        ToggleButton interno que dispara o popup. Sem este estilo
        explícito, o tema padrão do Windows desenha o background azul
        de seleção que conflita com a paleta clara.
    -->
    <Style x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="ClickMode" Value="Press" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ComboBoxStyle — altura 34, raio 6. Suporta um ícone à esquerda
        via propriedade Tag (qualquer object — recomendado: Path). O
        chevron é desenhado como Path estático à direita.
    -->
    <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Height" Value="34" />
        <Setter Property="Background" Value="{StaticResource InputBgBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="28" />
                                </Grid.ColumnDefinitions>

                                <!--
                                    Slot opcional de ícone à esquerda. ContentControl
                                    com Content="{TemplateBinding Tag}" renderiza
                                    qualquer object setado em Tag (ex.: Path para um
                                    glifo). Quando Tag é null, o ContentControl fica
                                    sem dimensão.
                                -->
                                <ContentControl x:Name="IconSlot"
                                                Grid.Column="0"
                                                Content="{TemplateBinding Tag}"
                                                Margin="10,0,0,0"
                                                VerticalAlignment="Center"
                                                Focusable="False" />

                                <ContentPresenter x:Name="ContentSite"
                                                  Grid.Column="1"
                                                  Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  IsHitTestVisible="False"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" />

                                <!-- Chevron customizado -->
                                <Path Grid.Column="2"
                                      Data="M 0,0 L 8,0 L 4,5 Z"
                                      Fill="{StaticResource TextMutedBrush}"
                                      Stretch="None"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      IsHitTestVisible="False" />

                                <ToggleButton Grid.Column="0"
                                              Grid.ColumnSpan="3"
                                              Style="{StaticResource ComboBoxToggleButton}"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              Background="Transparent" />
                            </Grid>
                        </Border>

                        <Popup x:Name="PART_Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Border x:Name="PopupBorder"
                                    Background="{StaticResource CardBgBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Margin="0,2,0,0"
                                    SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8"
                                                      ShadowDepth="2"
                                                      Direction="270"
                                                      Opacity="0.10"
                                                      Color="{StaticResource ShadowColor}" />
                                </Border.Effect>
                                <ScrollViewer Margin="2"
                                              SnapsToDevicePixels="True">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Tag" Value="{x:Null}">
                            <Setter TargetName="IconSlot" Property="Margin" Value="0" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource InputBorderFocusBrush}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource CardBgSubtleBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource TextSubtleBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        Estilo do item dentro do popup do ComboBox. Hover muda o
        fundo para AccentSoft; item selecionado em destaque sutil.
    -->
    <Style x:Key="ComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="ItemBd"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="4"
                            Margin="2,1"
                            SnapsToDevicePixels="True">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBd" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBd" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        Garante que ComboBoxItem implícito dentro do ComboBox use o
        estilo customizado mesmo quando o usuário não setar
        ItemContainerStyle. Definir como Style sem x:Key faria override
        global; usamos x:Key e referenciamos no ComboBox via setter
        de ItemContainerStyle.
    -->

    <!-- =========================================================== -->
    <!-- CheckBox quadrado 16px raio 4 com ✓ branco                   -->
    <!-- =========================================================== -->

    <Style x:Key="CheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="Box"
                                Width="16"
                                Height="16"
                                Background="{StaticResource InputBgBrush}"
                                BorderBrush="{StaticResource BorderStrongBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                VerticalAlignment="Center"
                                SnapsToDevicePixels="True">
                            <Path x:Name="Check"
                                  Data="M 3,8 L 7,11 L 13,4"
                                  Stroke="White"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Stretch="None"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Visibility="Collapsed" />
                        </Border>
                        <ContentPresenter Margin="8,0,0,0"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource TextSubtleBrush}" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================== -->
    <!-- Segmented control (Unifilar | Bifilar)                       -->
    <!-- =========================================================== -->

    <!--
        Item do segmented control. Active: fundo branco + sombra
        sutil + texto SemiBold. Inactive: transparente, texto muted.
        Padding interno 10x6 ; raio 4. Hover do item inativo apenas
        muda a cor do texto para Text.
    -->
    <Style x:Key="SegmentedControlItemStyle" TargetType="ListBoxItem">
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Margin" Value="1,0" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="ItemBg"
                            Background="Transparent"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                          TextElement.FontWeight="{TemplateBinding FontWeight}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBg" Property="Background" Value="{StaticResource CardBgBrush}" />
                            <Setter TargetName="ItemBg" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="4"
                                                      ShadowDepth="1"
                                                      Direction="270"
                                                      Opacity="0.10"
                                                      Color="{StaticResource ShadowColor}" />
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="False" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        Segmented control = ListBox horizontal com fundo CardBgSubtle,
        borda Border, padding interno 3, raio externo 6. ItemsPanel
        UniformGrid garante itens com largura igual.
    -->
    <Style x:Key="SegmentedControlStyle" TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource CardBgSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="3" />
        <Setter Property="Height" Value="34" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource SegmentedControlItemStyle}" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
        <Setter Property="KeyboardNavigation.DirectionalNavigation" Value="Cycle" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <ItemsPresenter Margin="{TemplateBinding Padding}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================== -->
    <!-- Step badge (estados: pending / active / done)                -->
    <!-- =========================================================== -->

    <!--
        StepBadgeStyle — ContentControl com template fixo (Ellipse 22px
        + número como Content + Path do ✓). O estado é codificado em
        Tag para evitar criar um custom DependencyProperty/C#:
            Tag="pending" → contorno cinza, número TextMuted
            Tag="active"  → fundo Accent, número branco
            Tag="done"    → contorno Success forte, ✓ no lugar do número

        Consumidores definem Tag direto ou via DataTriggers em Style.
    -->
    <Style x:Key="StepBadgeStyle" TargetType="ContentControl">
        <Setter Property="Width" Value="22" />
        <Setter Property="Height" Value="22" />
        <Setter Property="Tag" Value="pending" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Grid Width="22" Height="22" SnapsToDevicePixels="True">
                        <Ellipse x:Name="Bg"
                                 Stroke="{StaticResource BorderStrongBrush}"
                                 StrokeThickness="1.5"
                                 Fill="{StaticResource CardBgBrush}" />
                        <TextBlock x:Name="Num"
                                   Text="{TemplateBinding Content}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   FontFamily="{StaticResource BodyFont}"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <!-- Coordenadas zeradas (0,0)-(10,8) e Stretch=Uniform
                             dentro de uma caixa 12×9 centralizada no badge.
                             A versão anterior (Stretch=None com coords 6..16)
                             usava o ponto (0,0) do Path como origem, então
                             HorizontalAlignment=Center centralizava o
                             bounding box visual ASSUMINDO que ele começasse
                             em (0,0) — mas começava em (6,7), o que jogava
                             o ✓ para fora do círculo no topo-direita. -->
                        <Path x:Name="Check"
                              Data="M 0,4 L 4,8 L 10,0"
                              Stroke="{StaticResource SuccessBrush}"
                              StrokeThickness="2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Stretch="Uniform"
                              Width="12"
                              Height="9"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Tag" Value="active">
                            <Setter TargetName="Bg" Property="Fill" Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="Bg" Property="Stroke" Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="Num" Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="Tag" Value="done">
                            <Setter TargetName="Bg" Property="Stroke" Value="{StaticResource SuccessBrush}" />
                            <Setter TargetName="Bg" Property="StrokeThickness" Value="2" />
                            <Setter TargetName="Num" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        Linha conectora vertical entre badges. Verde quando a etapa
        anterior está concluída (Tag="done"), cinza caso contrário.
        1.5px de espessura, comprimento via Height do consumidor.
    -->
    <Style x:Key="StepConnectorStyle" TargetType="Rectangle">
        <Setter Property="Width" Value="1.5" />
        <Setter Property="Fill" Value="{StaticResource BorderStrongBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Style.Triggers>
            <Trigger Property="Tag" Value="done">
                <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- =========================================================== -->
    <!-- Slider de tolerância — track Accent, thumb branco, ticks    -->
    <!-- =========================================================== -->

    <!--
        Thumb circular branco com borda Accent 2px, 18x18. Usado pelo
        ToleranceSliderStyle abaixo.
    -->
    <Style x:Key="ToleranceSliderThumbStyle" TargetType="Thumb">
        <Setter Property="Width" Value="18" />
        <Setter Property="Height" Value="18" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Grid>
                        <Ellipse Fill="{StaticResource CardBgBrush}"
                                 Stroke="{StaticResource AccentBrush}"
                                 StrokeThickness="2" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        RepeatButton invisível, usado para os lados Decrease/Increase
        do Track. Sem ele o tema padrão desenha um botão proeminente.
    -->
    <Style x:Key="ToleranceSliderRepeatButtonStyle" TargetType="RepeatButton">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ToleranceSliderStyle — Slider snap-to-tick com 5 valores.
        Track de 4px de altura, raio 2; lado esquerdo (Decrease) em
        Accent, lado direito (Increase) em Border. Ticks são
        desenhados pela camada externa do consumidor (Ellipses na
        Grid abaixo do slider) — incluir TickBar nativo aqui levaria
        a triângulos não-circulares.
    -->
    <Style x:Key="ToleranceSliderStyle" TargetType="Slider">
        <Setter Property="Minimum" Value="0" />
        <Setter Property="Maximum" Value="4" />
        <Setter Property="TickFrequency" Value="1" />
        <Setter Property="IsSnapToTickEnabled" Value="True" />
        <Setter Property="SmallChange" Value="1" />
        <Setter Property="LargeChange" Value="1" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        <Setter Property="Background" Value="{StaticResource BorderBrush}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid>
                        <!-- Track de fundo (1 linha cinza) -->
                        <Border Height="4"
                                CornerRadius="2"
                                Background="{TemplateBinding Background}"
                                VerticalAlignment="Center" />
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="Slider.DecreaseLarge"
                                              Style="{StaticResource ToleranceSliderRepeatButtonStyle}">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Height="4"
                                                    CornerRadius="2"
                                                    Background="{StaticResource AccentBrush}"
                                                    VerticalAlignment="Center" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="Slider.IncreaseLarge"
                                              Style="{StaticResource ToleranceSliderRepeatButtonStyle}" />
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ToleranceSliderThumbStyle}" />
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        Estilo de cada bolinha de tick (6x6) renderizada abaixo do
        slider. Consumidores podem trocar Fill via DataTrigger se
        quiserem destacar a posição atual. Default: Border (cinza).
    -->
    <Style x:Key="ToleranceTickDotStyle" TargetType="Ellipse">
        <Setter Property="Width" Value="6" />
        <Setter Property="Height" Value="6" />
        <Setter Property="Fill" Value="{StaticResource BorderStrongBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!--
        Label de tick (10.5pt). DataTriggers no consumidor trocam para
        Accent SemiBold quando ToleranceLevelIndex == índice do label.
    -->
    <Style x:Key="ToleranceTickLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10.5" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="Foreground" Value="{StaticResource TextSubtleBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <!-- =========================================================== -->
    <!-- Status bar — Border de rodapé com fonte monoespaçada         -->
    <!-- =========================================================== -->

    <Style x:Key="StatusBarStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBgSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="StatusTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <!-- =========================================================== -->
    <!-- Tipografia auxiliar (títulos/subtítulos das etapas)          -->
    <!-- =========================================================== -->

    <Style x:Key="StepTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DisplayFont}" />
        <Setter Property="FontSize" Value="13.5" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>

    <Style x:Key="StepSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Margin" Value="0,1,0,0" />
    </Style>

    <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <Style x:Key="HelperTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="Foreground" Value="{StaticResource TextSubtleBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBgBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="14" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Effect" Value="{StaticResource CardShadow}" />
    </Style>

    <Style x:Key="SubtleCardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBgSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

</ResourceDictionary>
