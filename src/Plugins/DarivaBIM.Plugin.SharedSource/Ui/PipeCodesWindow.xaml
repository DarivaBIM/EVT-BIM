<Window x:Class="DarivaBIM.Plugin.Ui.PipeCodesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:common="clr-namespace:DarivaBIM.Presentation.Wpf.Common;assembly=DarivaBIM.Presentation.Wpf"
        Title="Codificar Tigre — EVT-BIM"
        Width="1180"
        Height="720"
        MinWidth="980"
        MinHeight="560"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        Background="#F7F9FC"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        Closed="OnWindowClosed">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <common:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />

        <!-- ========================= Paleta base ========================= -->
        <SolidColorBrush x:Key="CardBackgroundBrush"  Color="#FFFFFF" />
        <SolidColorBrush x:Key="SoftBorderBrush"      Color="#DDE3EC" />
        <SolidColorBrush x:Key="StrongBorderBrush"    Color="#C8D0DC" />
        <SolidColorBrush x:Key="RowDividerBrush"      Color="#F1F3F7" />
        <SolidColorBrush x:Key="RowHeaderBgBrush"     Color="#FAFBFD" />
        <SolidColorBrush x:Key="TextPrimaryBrush"     Color="#1F2733" />
        <SolidColorBrush x:Key="TextMutedBrush"       Color="#5B6878" />
        <SolidColorBrush x:Key="TextSoftBrush"        Color="#8893A3" />
        <SolidColorBrush x:Key="AccentBrush"          Color="#2563EB" />
        <SolidColorBrush x:Key="AccentSoftBgBrush"    Color="#0F2563EB" />
        <SolidColorBrush x:Key="NeutralButtonBrush"   Color="#2C3744" />
        <SolidColorBrush x:Key="DisabledBgBrush"      Color="#EEF1F6" />
        <SolidColorBrush x:Key="DisabledBorderBrush"  Color="#DDE3EC" />
        <SolidColorBrush x:Key="DisabledForegroundBrush" Color="#8893A3" />

        <!-- Paletas das 4 caixinhas (do mockup) -->
        <SolidColorBrush x:Key="RedBgBrush"       Color="#FFF3F3" />
        <SolidColorBrush x:Key="RedBorderBrush"   Color="#F4C7C7" />
        <SolidColorBrush x:Key="RedAccentBrush"   Color="#B3261E" />

        <SolidColorBrush x:Key="OrangeBgBrush"    Color="#FFF6EC" />
        <SolidColorBrush x:Key="OrangeBorderBrush" Color="#F3D3A8" />
        <SolidColorBrush x:Key="OrangeAccentBrush" Color="#B45A08" />

        <SolidColorBrush x:Key="YellowBgBrush"    Color="#FFFAEB" />
        <SolidColorBrush x:Key="YellowBorderBrush" Color="#F4DFA1" />
        <SolidColorBrush x:Key="YellowAccentBrush" Color="#92660B" />

        <SolidColorBrush x:Key="GreenBgBrush"     Color="#F1FAF2" />
        <SolidColorBrush x:Key="GreenBorderBrush" Color="#B8DEC0" />
        <SolidColorBrush x:Key="GreenAccentBrush" Color="#1F7A39" />

        <!-- ========================= Tipografia ========================= -->
        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="PageHintStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="EyebrowLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSoftBrush}" />
        </Style>

        <Style x:Key="StatValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="StatSuffixStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
            <Setter Property="Margin" Value="4,0,0,2" />
        </Style>

        <!-- Verde quando todos os tubos têm parâmetro -->
        <Style x:Key="StatValueParamOkStyle" TargetType="TextBlock" BasedOn="{StaticResource StatValueStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding ParameterStatusOk}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource GreenAccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Amarelo quando ainda há tubos sem parâmetro -->
        <Style x:Key="StatValueParamWarningStyle" TargetType="TextBlock" BasedOn="{StaticResource StatValueStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding ParameterStatusWarning}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource YellowAccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EmptyStateStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontStyle" Value="Italic" />
            <Setter Property="Foreground" Value="{StaticResource TextSoftBrush}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,24" />
        </Style>

        <Style x:Key="ColumnHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSoftBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="TextAlignment" Value="Left" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="RowTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="TextAlignment" Value="Left" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="RowDiameterStyle" TargetType="TextBlock" BasedOn="{StaticResource RowTextStyle}">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
        </Style>

        <!-- Slice 4.1 — coluna COD. SUGERIDO. Tabular numbers + cinza um
             tom mais firme que o diametro pra dar peso ao codigo sugerido
             sem competir com o ELEMENTO. -->
        <Style x:Key="RowCodeStyle" TargetType="TextBlock" BasedOn="{StaticResource RowTextStyle}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="Consolas, Segoe UI" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="StatusPillTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="StatusPillSubtextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Opacity" Value="0.85" />
        </Style>

        <!-- ========================= Botões ========================= -->
        <ControlTemplate x:Key="RoundedButtonTemplate" TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}"
                    SnapsToDevicePixels="True">
                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  RecognizesAccessKey="True" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.92" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="FooterButtonBaseStyle" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template" Value="{StaticResource RoundedButtonTemplate}" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- "Atualizar lista" — neutro escuro -->
        <Style x:Key="NeutralButtonStyle" TargetType="Button" BasedOn="{StaticResource FooterButtonBaseStyle}">
            <Setter Property="Background" Value="{StaticResource NeutralButtonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource NeutralButtonBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <!-- "Deletar Códigos" — ghost cinza, fica disabled quando sem seleção -->
        <Style x:Key="GhostDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource FooterButtonBaseStyle}">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StrongBorderBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{StaticResource DisabledBgBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource DisabledBorderBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource DisabledForegroundBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- "Inserir/Atualizar Códigos" — primary azul, vira disabled cinza -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource FooterButtonBaseStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{StaticResource DisabledBgBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource DisabledBorderBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource DisabledForegroundBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- "Criar parâmetro nos tubos" — primary azul na barra superior -->
        <Style x:Key="CreateParamButtonStyle" TargetType="Button" BasedOn="{StaticResource FooterButtonBaseStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#F3F5F9" />
                    <Setter Property="BorderBrush" Value="{StaticResource SoftBorderBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource DisabledForegroundBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ========================= Linha (DataTemplate) =========================
             Slice 4.1 — coluna TIPO virou ELEMENTO (familia · tipo via ElementText)
             + nova coluna COD. SUGERIDO (MatchedCodeText). Layout balanceado pra
             caber 5 colunas mantendo o checkbox e o fluxo de leitura
             checkbox -> qtd -> elemento -> diametro -> codigo. -->
        <DataTemplate x:Key="GroupRowTemplate">
            <Border BorderBrush="{StaticResource RowDividerBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="10,8"
                    Background="Transparent">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="38" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="64" />
                        <ColumnDefinition Width="86" />
                    </Grid.ColumnDefinitions>

                    <CheckBox Grid.Column="0"
                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Left" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Count}"
                               Style="{StaticResource RowTextStyle}" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding ElementText}"
                               Style="{StaticResource RowTextStyle}"
                               Margin="0,0,8,0"
                               ToolTip="{Binding ElementText}" />
                    <TextBlock Grid.Column="3"
                               Text="{Binding DiameterText}"
                               Style="{StaticResource RowDiameterStyle}" />
                    <TextBlock Grid.Column="4"
                               Text="{Binding MatchedCodeText}"
                               Style="{StaticResource RowCodeStyle}"
                               ToolTip="{Binding MatchedCodeText}" />
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Slice 3.5 — header colapsável por categoria (Tubulações,
             Conexões de tubo, Acessórios, Aparelhos hidrossanitários) -->
        <Style x:Key="CategoryGroupHeaderStyle" TargetType="GroupItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupItem">
                        <Expander IsExpanded="True"
                                  Margin="0,4,0,2"
                                  Background="Transparent"
                                  BorderThickness="0">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding ItemCount, StringFormat=' ({0})'}"
                                               FontSize="11"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               VerticalAlignment="Center"
                                               Margin="4,0,0,0" />
                                </StackPanel>
                            </Expander.Header>
                            <ItemsPresenter Margin="14,0,0,4" />
                        </Expander>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ListBoxItemFlatStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentSoftBgBrush}" />
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#08000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========================= Toggle (recolher) ========================= -->
        <Style x:Key="CollapseToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextSoftBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ToolTip" Value="Recolher" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <Path x:Name="Glyph"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Stroke="{TemplateBinding Foreground}"
                                  StrokeThickness="1.4"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M 1,5 L 9,5" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Glyph" Property="Data" Value="M 1,5 L 9,5 M 5,1 L 5,9" />
                                <Setter Property="ToolTip" Value="Expandir" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#15000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20,16,20,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ========================= Cabeçalho da página ========================= -->
        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,12">
            <TextBlock DockPanel.Dock="Left"
                       Text="Codificar Tigre — EVT-BIM"
                       Style="{StaticResource PageTitleStyle}"
                       VerticalAlignment="Center"
                       Margin="0,0,14,0" />
            <TextBlock Style="{StaticResource PageHintStyle}"
                       VerticalAlignment="Center"
                       Text="Marque os Tipo + Diâmetro para inserir, regravar ou apagar o parâmetro Tigre: Código." />
        </DockPanel>

        <!-- ========================= Faixa de resumo ========================= -->
        <Border Grid.Row="1"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource SoftBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14,10"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Tile 1: Catálogo Tigre -->
                <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="CATÁLOGO TIGRE" Style="{StaticResource EyebrowLabelStyle}" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding CatalogCount}" Style="{StaticResource StatValueStyle}" />
                        <TextBlock Text="itens" Style="{StaticResource StatSuffixStyle}" />
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" Width="1" Height="32"
                        Background="{StaticResource SoftBorderBrush}"
                        Margin="14,0" />

                <!-- Tile 2: Tubos no projeto -->
                <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="TUBOS NO PROJETO" Style="{StaticResource EyebrowLabelStyle}" />
                    <TextBlock Text="{Binding PipesTotal}" Style="{StaticResource StatValueStyle}" />
                </StackPanel>

                <Border Grid.Column="3" Width="1" Height="32"
                        Background="{StaticResource SoftBorderBrush}"
                        Margin="14,0" />

                <!-- Tile 3: Tipos encontrados -->
                <StackPanel Grid.Column="4" Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="TIPOS ENCONTRADOS" Style="{StaticResource EyebrowLabelStyle}" />
                    <TextBlock Text="{Binding UniqueTypeCount}" Style="{StaticResource StatValueStyle}" />
                </StackPanel>

                <!-- Separador mais forte entre projeto vs parâmetro -->
                <Border Grid.Column="5" Width="1" Height="36"
                        Background="{StaticResource StrongBorderBrush}"
                        Margin="18,0" />

                <!-- Tile 4: Com parâmetro -->
                <StackPanel Grid.Column="6" Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="COM PARÂMETRO" Style="{StaticResource EyebrowLabelStyle}" />
                    <TextBlock Text="{Binding PipesWithParameter}" Style="{StaticResource StatValueParamOkStyle}" />
                </StackPanel>

                <Border Grid.Column="7" Width="1" Height="32"
                        Background="{StaticResource SoftBorderBrush}"
                        Margin="14,0" />

                <!-- Tile 5: Sem parâmetro -->
                <StackPanel Grid.Column="8" Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="SEM PARÂMETRO" Style="{StaticResource EyebrowLabelStyle}" />
                    <TextBlock Text="{Binding PipesWithoutParameter}" Style="{StaticResource StatValueParamWarningStyle}" />
                </StackPanel>

                <!-- Pill: Ação necessária / Tudo pronto -->
                <Grid Grid.Column="10" VerticalAlignment="Center" Margin="0,0,12,0">
                    <Border Background="{StaticResource YellowBgBrush}"
                            BorderBrush="{StaticResource YellowBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,6"
                            Visibility="{Binding ParameterStatusWarning, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="14" Height="14"
                                  Stretch="Uniform"
                                  Fill="{StaticResource YellowAccentBrush}"
                                  Data="M 11,2 L 20.5,19 L 1.5,19 Z"
                                  VerticalAlignment="Center" />
                            <TextBlock Text="Ação necessária"
                                       Style="{StaticResource StatusPillTextStyle}"
                                       Foreground="{StaticResource YellowAccentBrush}"
                                       Margin="6,0,0,0" />
                            <TextBlock Text=" · crie o parâmetro"
                                       Style="{StaticResource StatusPillSubtextStyle}"
                                       Foreground="{StaticResource YellowAccentBrush}"
                                       Margin="2,0,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource GreenBgBrush}"
                            BorderBrush="{StaticResource GreenBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,6"
                            Visibility="{Binding ParameterStatusOk, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{StaticResource GreenAccentBrush}"
                                    Width="16" Height="16"
                                    CornerRadius="999"
                                    VerticalAlignment="Center">
                                <Path Stretch="Uniform"
                                      Margin="3"
                                      Stroke="White"
                                      StrokeThickness="1.6"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Data="M 2.5,6.5 L 5,9 L 9.5,3.5" />
                            </Border>
                            <TextBlock Text="Tudo pronto"
                                       Style="{StaticResource StatusPillTextStyle}"
                                       Foreground="{StaticResource GreenAccentBrush}"
                                       Margin="6,0,0,0" />
                            <TextBlock Text=" · todos com parâmetro"
                                       Style="{StaticResource StatusPillSubtextStyle}"
                                       Foreground="{StaticResource GreenAccentBrush}"
                                       Margin="2,0,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Botão "Criar parâmetro nos tubos" -->
                <Button Grid.Column="11"
                        Style="{StaticResource CreateParamButtonStyle}"
                        Content="Criar parâmetro Tigre: Código"
                        IsEnabled="{Binding CanCreateParameter}"
                        VerticalAlignment="Center"
                        Click="OnEnsureParameterClicked" />
            </Grid>
        </Border>

        <!-- ========================= 4 cards lado a lado ========================= -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ===== Card 1: Sem correspondência (vermelho) ===== -->
            <Border Grid.Column="0"
                    Background="{StaticResource RedBgBrush}"
                    BorderBrush="{StaticResource RedBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Margin="0,0,6,0"
                    ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Cabeçalho do card -->
                    <StackPanel Grid.Row="0" Margin="14,12,14,0">
                        <DockPanel LastChildFill="True">
                            <Ellipse DockPanel.Dock="Left"
                                     Width="8" Height="8"
                                     Fill="{StaticResource RedAccentBrush}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,8,0" />
                            <Border DockPanel.Dock="Right"
                                    Background="#A6FFFFFF"
                                    BorderBrush="{StaticResource RedBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="999"
                                    Padding="8,1"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding NoMatchSection.Groups.Count}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource RedAccentBrush}" />
                            </Border>
                            <TextBlock Text="{Binding NoMatchSection.Title}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource RedAccentBrush}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,0,8,0" />
                        </DockPanel>
                        <TextBlock Text="{Binding NoMatchSection.Description}"
                                   FontSize="11.5"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"
                                   MinHeight="32" />
                    </StackPanel>

                    <!-- Toolbar: Selecionar todos · contador · recolher -->
                    <Grid Grid.Row="1" Margin="14,10,14,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0"
                                  Content="Selecionar todos"
