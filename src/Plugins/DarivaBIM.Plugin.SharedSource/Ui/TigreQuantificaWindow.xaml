<Window x:Class="DarivaBIM.Plugin.Ui.TigreQuantificaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tigre Quantifica — EVT-BIM"
        Width="1380"
        Height="780"
        MinWidth="1080"
        MinHeight="600"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        Background="#F7F9FC"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        Closed="OnWindowClosed">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <SolidColorBrush x:Key="CardBg"        Color="#FFFFFF" />
        <SolidColorBrush x:Key="SoftBorder"    Color="#DDE3EC" />
        <SolidColorBrush x:Key="TextPrimary"   Color="#1F2733" />
        <SolidColorBrush x:Key="TextMuted"     Color="#5B6878" />
        <SolidColorBrush x:Key="TextSoft"      Color="#8893A3" />
        <SolidColorBrush x:Key="Accent"        Color="#2563EB" />
        <SolidColorBrush x:Key="NeutralButton" Color="#2C3744" />

        <SolidColorBrush x:Key="RedAccent"     Color="#B3261E" />
        <SolidColorBrush x:Key="RedSoftBg"     Color="#FFF3F3" />
        <SolidColorBrush x:Key="YellowAccent"  Color="#92660B" />
        <SolidColorBrush x:Key="YellowSoftBg"  Color="#FFFAEB" />
        <SolidColorBrush x:Key="YellowBorder"  Color="#F4DFA1" />
        <SolidColorBrush x:Key="GreenAccent"   Color="#1F7A39" />

        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        </Style>

        <Style x:Key="PageHintStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="EyebrowLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSoft}" />
        </Style>

        <Style x:Key="KpiValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        </Style>

        <Style x:Key="KpiCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource SoftBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>

        <Style x:Key="HeaderCell" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSoft}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="BodyCell" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="NeutralButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource NeutralButton}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <!-- Pill de severidade dos findings (10x10 no slice 1; F3 #5 do
             1.6 muda para 14x14 + DropShadowEffect). -->
        <Style x:Key="SeverityPill" TargetType="Ellipse">
            <Setter Property="Width" Value="10" />
            <Setter Property="Height" Value="10" />
            <Setter Property="Fill" Value="{StaticResource YellowAccent}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SeverityKey}" Value="Red">
                    <Setter Property="Fill" Value="{StaticResource RedAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- DataTemplate da linha agregada (uma por QuantityGroupViewModel). -->
        <DataTemplate x:Key="GroupRowTemplate">
            <Border BorderBrush="{StaticResource SoftBorder}"
                    BorderThickness="0,0,0,1"
                    Padding="0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.6*" />
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="1.0*" />
                        <ColumnDefinition Width="0.7*" />
                        <ColumnDefinition Width="0.7*" />
                        <ColumnDefinition Width="1.5*" />
                        <ColumnDefinition Width="0.9*" />
                        <ColumnDefinition Width="0.9*" />
                        <ColumnDefinition Width="0.5*" />
                        <ColumnDefinition Width="0.7*" />
                        <ColumnDefinition Width="0.4*" />
                        <ColumnDefinition Width="1.0*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"  Style="{StaticResource BodyCell}" Text="{Binding Family}" />
                    <TextBlock Grid.Column="1"  Style="{StaticResource BodyCell}" Text="{Binding Type}" />
                    <TextBlock Grid.Column="2"  Style="{StaticResource BodyCell}" Text="{Binding Description}" />
                    <TextBlock Grid.Column="3"  Style="{StaticResource BodyCell}" Text="{Binding Diameter}" />
                    <TextBlock Grid.Column="4"  Style="{StaticResource BodyCell}" Text="{Binding TigreCode}" />
                    <TextBlock Grid.Column="5"  Style="{StaticResource BodyCell}" Text="{Binding Description}" />
                    <TextBlock Grid.Column="6"  Style="{StaticResource BodyCell}" Text="{Binding Manufacturer}" />
                    <TextBlock Grid.Column="7"  Style="{StaticResource BodyCell}" Text="{Binding System}" />
                    <TextBlock Grid.Column="8"  Style="{StaticResource BodyCell}" Text="{Binding ElementCountText}" />
                    <TextBlock Grid.Column="9"  Style="{StaticResource BodyCell}" Text="{Binding QuantityText}" />
                    <TextBlock Grid.Column="10" Style="{StaticResource BodyCell}" Text="{Binding Unit}" />
                    <TextBlock Grid.Column="11" Style="{StaticResource BodyCell}" Text="{Binding AuditNote}"
                               Foreground="{StaticResource RedAccent}" />
                </Grid>
            </Border>
        </DataTemplate>

        <!-- DataTemplate de um card de categoria. -->
        <DataTemplate x:Key="CategoryCardTemplate">
            <Border Background="{StaticResource CardBg}"
                    BorderBrush="{StaticResource SoftBorder}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16,12,14,12"
                    Margin="0,0,0,10">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Category}" Style="{StaticResource PageTitleStyle}" />
                            <TextBlock Text=" · " Style="{StaticResource PageHintStyle}" Margin="6,0" />
                            <TextBlock Style="{StaticResource PageHintStyle}">
                                <Run Text="{Binding GroupCount, Mode=OneWay}" />
                                <Run Text=" grupos" />
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Style="{StaticResource EyebrowLabel}"
                                   Text="{Binding Unit}"
                                   VerticalAlignment="Center" />
                    </Grid>
                    <!-- Cabeçalho da tabela. 12 colunas, ratios iguais ao GroupRowTemplate. -->
                    <Border BorderBrush="{StaticResource SoftBorder}"
                            BorderThickness="0,0,0,1"
                            Padding="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.6*" />
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="1.0*" />
                                <ColumnDefinition Width="0.7*" />
                                <ColumnDefinition Width="0.7*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="0.9*" />
                                <ColumnDefinition Width="0.9*" />
                                <ColumnDefinition Width="0.5*" />
                                <ColumnDefinition Width="0.7*" />
                                <ColumnDefinition Width="0.4*" />
                                <ColumnDefinition Width="1.0*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"  Style="{StaticResource HeaderCell}" Text="FAMÍLIA" />
                            <TextBlock Grid.Column="1"  Style="{StaticResource HeaderCell}" Text="TIPO" />
                            <TextBlock Grid.Column="2"  Style="{StaticResource HeaderCell}" Text="DESCRIÇÃO (tipo)" />
                            <TextBlock Grid.Column="3"  Style="{StaticResource HeaderCell}" Text="DIÂM." />
                            <TextBlock Grid.Column="4"  Style="{StaticResource HeaderCell}" Text="COD. TIGRE" />
                            <TextBlock Grid.Column="5"  Style="{StaticResource HeaderCell}" Text="DESCRIÇÃO" />
                            <TextBlock Grid.Column="6"  Style="{StaticResource HeaderCell}" Text="FABRICANTE" />
                            <TextBlock Grid.Column="7"  Style="{StaticResource HeaderCell}" Text="SISTEMA" />
                            <TextBlock Grid.Column="8"  Style="{StaticResource HeaderCell}" Text="QTD" />
                            <TextBlock Grid.Column="9"  Style="{StaticResource HeaderCell}" Text="QUANTIDADE" />
                            <TextBlock Grid.Column="10" Style="{StaticResource HeaderCell}" Text="UN" />
                            <TextBlock Grid.Column="11" Style="{StaticResource HeaderCell}" Text="AUDITORIA" />
                        </Grid>
                    </Border>
                    <ItemsControl ItemsSource="{Binding Groups}"
                                  ItemTemplate="{StaticResource GroupRowTemplate}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- DataTemplate de uma finding (lista lateral). -->
        <DataTemplate x:Key="FindingRowTemplate">
            <Border BorderBrush="{StaticResource SoftBorder}"
                    BorderThickness="0,0,0,1"
                    Padding="6,8">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Style="{StaticResource SeverityPill}" Margin="0,2,8,0" />
                    <StackPanel>
                        <TextBlock Text="{Binding FamilyType}" Style="{StaticResource BodyCell}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding MissingFieldsText}" Style="{StaticResource PageHintStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- header projeto -->
            <RowDefinition Height="Auto" />  <!-- KPIs           -->
            <RowDefinition Height="Auto" />  <!-- banner amarelo -->
            <RowDefinition Height="*"   />  <!-- conteúdo       -->
            <RowDefinition Height="Auto" />  <!-- erro           -->
            <RowDefinition Height="Auto" />  <!-- footer         -->
        </Grid.RowDefinitions>

        <!-- ============== Cabeçalho do projeto ============== -->
        <Border Grid.Row="0"
                Background="{StaticResource CardBg}"
                BorderBrush="{StaticResource SoftBorder}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="20,14"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Style="{StaticResource EyebrowLabel}" Text="EMPREENDIMENTO" />
                    <TextBlock Text="{Binding ProjectName}" Style="{StaticResource PageTitleStyle}" Margin="0,2,0,8" />
                    <WrapPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                            <TextBlock Text="Cliente: " Style="{StaticResource PageHintStyle}" />
                            <TextBlock Text="{Binding ProjectClient}" Style="{StaticResource PageHintStyle}" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                            <TextBlock Text="Autor: " Style="{StaticResource PageHintStyle}" />
                            <TextBlock Text="{Binding ProjectAuthor}" Style="{StaticResource PageHintStyle}" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                            <TextBlock Text="Data: " Style="{StaticResource PageHintStyle}" />
                            <TextBlock Text="{Binding ProjectIssueDate}" Style="{StaticResource PageHintStyle}" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Versão: " Style="{StaticResource PageHintStyle}" />
                            <TextBlock Text="{Binding ProjectVersion}" Style="{StaticResource PageHintStyle}" FontWeight="SemiBold" />
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Style="{StaticResource EyebrowLabel}"
                           Text="Tigre Quantifica" />
            </Grid>
        </Border>

        <!-- ============== KPIs ============== -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="4" Margin="0,0,0,12">
            <Border Style="{StaticResource KpiCard}">
                <StackPanel>
                    <TextBlock Style="{StaticResource EyebrowLabel}" Text="GRUPOS" />
                    <TextBlock Style="{StaticResource KpiValue}"     Text="{Binding TotalGroups}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}">
                <StackPanel>
                    <TextBlock Style="{StaticResource EyebrowLabel}" Text="ELEMENTOS" />
                    <TextBlock Style="{StaticResource KpiValue}"     Text="{Binding TotalElementCount}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}">
                <StackPanel>
                    <TextBlock Style="{StaticResource EyebrowLabel}" Text="CRÍTICOS" />
                    <TextBlock Style="{StaticResource KpiValue}"     Text="{Binding RedFindingsCount}"
                               Foreground="{StaticResource RedAccent}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}">
                <StackPanel>
                    <TextBlock Style="{StaticResource EyebrowLabel}" Text="ATENÇÃO" />
                    <TextBlock Style="{StaticResource KpiValue}"     Text="{Binding YellowFindingsCount}"
                               Foreground="{StaticResource YellowAccent}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- ============== Banner amarelo: PipesNeedCoding (slice 1.6 F1) ============== -->
        <Border Grid.Row="2"
                Background="{StaticResource YellowSoftBg}"
                BorderBrush="{StaticResource YellowBorder}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14,10"
                Margin="0,0,0,12"
                Visibility="{Binding PipesNeedCoding, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Foreground="{StaticResource YellowAccent}"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       Text="Nenhum tubo deste projeto tem código Tigre preenchido. Rode 'Codificar Tubos' antes de exportar o relatório de compras." />
        </Border>

        <!-- ============== Conteúdo: categorias + findings ============== -->
        <Grid Grid.Row="3" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,12,0">
                <ItemsControl ItemsSource="{Binding Categories}"
                              ItemTemplate="{StaticResource CategoryCardTemplate}" />
            </ScrollViewer>

            <Border Grid.Column="1"
                    Background="{StaticResource CardBg}"
                    BorderBrush="{StaticResource SoftBorder}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14,12">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Style="{StaticResource EyebrowLabel}" Text="AUDITORIA" />
                        <TextBlock Style="{StaticResource PageTitleStyle}"
                                   Text="{Binding TotalFindingsCount, StringFormat={}{0} achados}" />
                    </StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Findings}"
                                      ItemTemplate="{StaticResource FindingRowTemplate}" />
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ============== Erro fatal ============== -->
        <Border Grid.Row="4"
                Background="{StaticResource RedSoftBg}"
                BorderBrush="{StaticResource RedAccent}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14,10"
                Margin="0,0,0,12"
                Visibility="{Binding HasErrorMessage, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Foreground="{StaticResource RedAccent}"
                       TextWrapping="Wrap"
                       Text="{Binding ErrorMessage}" />
        </Border>

        <!-- ============== Footer ============== -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Style="{StaticResource PageHintStyle}"
                       Text="{Binding StatusMessage}" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="RescanButton"
                        Style="{StaticResource NeutralButtonStyle}"
                        Content="Re-escanear"
                        Click="OnRescanClicked" />
                <Button x:Name="ExportButton"
                        Style="{StaticResource PrimaryButton}"
                        Content="Exportar CSV"
                        Click="OnExportClicked" />
                <Button x:Name="CloseButton"
                        Style="{StaticResource NeutralButtonStyle}"
                        Content="Fechar"
                        Click="OnCloseClicked" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
