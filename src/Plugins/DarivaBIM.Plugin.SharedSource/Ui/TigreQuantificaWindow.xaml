<Window x:Class="DarivaBIM.Plugin.Ui.TigreQuantificaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tigre Quantifica — EVT-BIM"
        Width="1380"
        Height="780"
        MinWidth="1080"
        MinHeight="600"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        Background="#F7F9FC"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        Closed="OnWindowClosed">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <SolidColorBrush x:Key="CardBg"        Color="#FFFFFF" />
        <SolidColorBrush x:Key="SoftBorder"    Color="#DDE3EC" />
        <SolidColorBrush x:Key="TextPrimary"   Color="#1F2733" />
        <SolidColorBrush x:Key="TextMuted"     Color="#5B6878" />
        <SolidColorBrush x:Key="TextSoft"      Color="#8893A3" />
        <SolidColorBrush x:Key="Accent"        Color="#2563EB" />
        <SolidColorBrush x:Key="NeutralButton" Color="#2C3744" />

        <SolidColorBrush x:Key="RedAccent"     Color="#B3261E" />
        <SolidColorBrush x:Key="RedSoftBg"     Color="#FFF3F3" />
        <SolidColorBrush x:Key="YellowAccent"  Color="#92660B" />
        <SolidColorBrush x:Key="YellowSoftBg"  Color="#FFFAEB" />
        <SolidColorBrush x:Key="YellowBorder"  Color="#F4DFA1" />
        <SolidColorBrush x:Key="GreenAccent"   Color="#1F7A39" />

        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        </Style>

        <Style x:Key="PageHintStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="EyebrowLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSoft}" />
        </Style>

        <Style x:Key="KpiValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        </Style>

        <!-- Slice 4.2 F3 #3 — padding interno mais generoso (era 16,12)
             pra dar respiro entre eyebrow "GRUPOS/ELEMENTOS/..." e o
             numero grande do KpiValue. Mantem o card visualmente leve
             sem inflar a altura demais. -->
        <Style x:Key="KpiCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource SoftBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="18,14" />
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>

        <Style x:Key="HeaderCell" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSoft}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <!-- Slice 4.2 F3 #6 — TextTrimming default no BodyCell pra
             truncar com reticencias quando coluna estreita. Wrap antes
             quebrava linha em colunas curtas (DIAM., QTD, UN) e
             deformava a altura da row. ToolTip por celula (definido
             inline no GroupRowTemplate) mostra o texto completo no
             hover. ToolTipService.IsEnabled=False quando Text esta vazio
             pra nao mostrar balao de tooltip vazio em campos opcionais
             nao preenchidos (TigreCode/Manufacturer/etc retornam
             string.Empty no VM em vez de null). -->
        <Style x:Key="BodyCell" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="Text" Value="">
                    <Setter Property="ToolTipService.IsEnabled" Value="False" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="NeutralButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource NeutralButton}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <!-- Slice 4.2 F3 #5 — pill 10x10 -> 14x14 + DropShadowEffect
             sutil. Aumenta a presenca visual da severidade na lista de
             findings sem dominar o card, e da uma profundidade pequena
             que separa o pill do fundo branco. -->
        <Style x:Key="SeverityPill" TargetType="Ellipse">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Fill" Value="{StaticResource YellowAccent}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="4"
                                      ShadowDepth="1"
                                      Direction="270"
                                      Opacity="0.35"
                                      Color="#1F2733" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding SeverityKey}" Value="Red">
                    <Setter Property="Fill" Value="{StaticResource RedAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- DataTemplate da linha agregada (uma por QuantityGroupViewModel).
             Tabela: 11 colunas. CSV: 12 colunas (Família e Tipo separados
             no export, consolidados no slice 1.6 F3 #4 caso seja necessário).
             Coluna "DESCRIÇÃO (tipo)" REMOVIDA — bindava o mesmo Description
             que a coluna 5; era ruído visual sem informação distinta. -->
        <DataTemplate x:Key="GroupRowTemplate">
            <Border BorderBrush="{StaticResource SoftBorder}"
                    BorderThickness="0,0,0,1"
                    Padding="0,6">
                <!-- Slice 4.2 F3 #6 — MinWidth nas colunas mais criticas
                     pra evitar que truncamento agressivo apague campos
                     essenciais (FAMILIA / TIPO / COD. TIGRE / DESCRICAO).
                     ToolTip por celula via Setter no Style.Triggers nao
                     funciona em TextBlock (sem ContextMenu nem Tag), entao
                     ToolTip e setado inline. -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.6*" MinWidth="90" />
                        <ColumnDefinition Width="1.2*" MinWidth="70" />
                        <ColumnDefinition Width="0.7*" MinWidth="45" />
                        <ColumnDefinition Width="0.7*" MinWidth="60" />
                        <ColumnDefinition Width="1.5*" MinWidth="100" />
                        <ColumnDefinition Width="0.9*" MinWidth="60" />
                        <ColumnDefinition Width="0.9*" MinWidth="60" />
                        <ColumnDefinition Width="0.5*" MinWidth="34" />
                        <ColumnDefinition Width="0.7*" MinWidth="55" />
                        <ColumnDefinition Width="0.4*" MinWidth="28" />
                        <ColumnDefinition Width="1.0*" MinWidth="80" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"  Style="{StaticResource BodyCell}" Text="{Binding Family}"
                               ToolTip="{Binding Family}" />
                    <TextBlock Grid.Column="1"  Style="{StaticResource BodyCell}" Text="{Binding Type}"
                               ToolTip="{Binding Type}" />
                    <TextBlock Grid.Column="2"  Style="{StaticResource BodyCell}" Text="{Binding Diameter}"
                               ToolTip="{Binding Diameter}" />
                    <TextBlock Grid.Column="3"  Style="{StaticResource BodyCell}" Text="{Binding TigreCode}"
                               ToolTip="{Binding TigreCode}" />
                    <TextBlock Grid.Column="4"  Style="{StaticResource BodyCell}" Text="{Binding Description}"
                               ToolTip="{Binding Description}" />
                    <TextBlock Grid.Column="5"  Style="{StaticResource BodyCell}" Text="{Binding Manufacturer}"
                               ToolTip="{Binding Manufacturer}" />
                    <TextBlock Grid.Column="6"  Style="{StaticResource BodyCell}" Text="{Binding System}"
                               ToolTip="{Binding System}" />
                    <TextBlock Grid.Column="7"  Style="{StaticResource BodyCell}" Text="{Binding ElementCountText}"
                               ToolTip="{Binding ElementCountText}" />
                    <TextBlock Grid.Column="8"  Style="{StaticResource BodyCell}" Text="{Binding QuantityText}"
                               ToolTip="{Binding QuantityText}" />
                    <TextBlock Grid.Column="9"  Style="{StaticResource BodyCell}" Text="{Binding Unit}"
                               ToolTip="{Binding Unit}" />
                    <TextBlock Grid.Column="10" Style="{StaticResource BodyCell}" Text="{Binding AuditNote}"
                               Foreground="{StaticResource RedAccent}"
                               ToolTip="{Binding AuditNote}" />
                </Grid>
            </Border>
        </DataTemplate>

        <!-- DataTemplate de um card de categoria.
             Slice 4.2 F5 — Expander envolve a tabela, two-way binding em
             QuantityCategoryViewModel.IsExpanded (default true). Header
             vira ToggleButton custom: chevron rotaciona 0->90 conforme
             estado expandido, click no header inteiro toggleia. Template
             do Expander reescrito porque o chrome default (com box
             expander) conflita visualmente com o card. -->
        <DataTemplate x:Key="CategoryCardTemplate">
            <Border Background="{StaticResource CardBg}"
                    BorderBrush="{StaticResource SoftBorder}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16,12,14,12"
                    Margin="0,0,0,10">
                <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
                          Background="Transparent"
                          BorderThickness="0"
                          Padding="0">
                    <Expander.Style>
                        <Style TargetType="Expander">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Expander">
                                        <StackPanel>
                                            <ToggleButton x:Name="HeaderToggle"
                                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                          Cursor="Hand"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          HorizontalContentAlignment="Stretch"
                                                          Focusable="False">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="Transparent" Padding="0">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <!-- Chevron 10x10, rotaciona 0->90 quando expandido.
                                                                     Trigger seta RenderTransform inteira (TargetName
                                                                     precisa apontar pro elemento nomeado no namescope,
                                                                     não pro Transform interno). -->
                                                                <Path x:Name="Chevron"
                                                                      Grid.Column="0"
                                                                      Width="10" Height="10"
                                                                      Margin="0,0,8,0"
                                                                      VerticalAlignment="Center"
                                                                      Stretch="Uniform"
                                                                      Fill="{StaticResource TextMuted}"
                                                                      Data="M 0,0 L 8,4 L 0,8 Z"
                                                                      RenderTransformOrigin="0.5,0.5">
                                                                    <Path.RenderTransform>
                                                                        <RotateTransform Angle="0" />
                                                                    </Path.RenderTransform>
                                                                </Path>
                                                                <ContentPresenter Grid.Column="1" VerticalAlignment="Center" />
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="Chevron" Property="RenderTransform">
                                                                    <Setter.Value>
                                                                        <RotateTransform Angle="90" />
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                                <ContentPresenter ContentSource="Header" />
                                            </ToggleButton>
                                            <ContentPresenter x:Name="ExpandSite"
                                                              ContentSource="Content"
                                                              Visibility="Collapsed"
                                                              Margin="0,8,0,0" />
                                        </StackPanel>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsExpanded" Value="True">
                                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Expander.Style>
                    <Expander.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Category}" Style="{StaticResource PageTitleStyle}" />
                                <TextBlock Text=" · " Style="{StaticResource PageHintStyle}" Margin="6,0" />
                                <TextBlock Style="{StaticResource PageHintStyle}">
                                    <Run Text="{Binding GroupCount, Mode=OneWay}" />
                                    <Run Text=" grupos" />
                                </TextBlock>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Style="{StaticResource EyebrowLabel}"
                                       Text="{Binding Unit}"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Expander.Header>
                    <StackPanel>
                        <!-- Cabeçalho da tabela. 11 colunas, ratios + MinWidth
                             iguais ao GroupRowTemplate (Slice 4.2 F3 #6) pra
                             header e rows alinharem mesmo com truncamento.
                             CSV continua com 12 colunas (Família e Tipo
                             separados no export). -->
                        <Border BorderBrush="{StaticResource SoftBorder}"
                                BorderThickness="0,0,0,1"
                                Padding="0,0,0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.6*" MinWidth="90" />
                                    <ColumnDefinition Width="1.2*" MinWidth="70" />
                                    <ColumnDefinition Width="0.7*" MinWidth="45" />
                                    <ColumnDefinition Width="0.7*" MinWidth="60" />
                                    <ColumnDefinition Width="1.5*" MinWidth="100" />
                                    <ColumnDefinition Width="0.9*" MinWidth="60" />
                                    <ColumnDefinition Width="0.9*" MinWidth="60" />
                                    <ColumnDefinition Width="0.5*" MinWidth="34" />
                                    <ColumnDefinition Width="0.7*" MinWidth="55" />
                                    <ColumnDefinition Width="0.4*" MinWidth="28" />
                                    <ColumnDefinition Width="1.0*" MinWidth="80" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"  Style="{StaticResource HeaderCell}" Text="FAMÍLIA" />
                                <TextBlock Grid.Column="1"  Style="{StaticResource HeaderCell}" Text="TIPO" />
                                <TextBlock Grid.Column="2"  Style="{StaticResource HeaderCell}" Text="DIÂM." />
                                <TextBlock Grid.Column="3"  Style="{StaticResource HeaderCell}" Text="COD. TIGRE" />
                                <TextBlock Grid.Column="4"  Style="{StaticResource HeaderCell}" Text="DESCRIÇÃO" />
                                <TextBlock Grid.Column="5"  Style="{StaticResource HeaderCell}" Text="FABRICANTE" />
                                <TextBlock Grid.Column="6"  Style="{StaticResource HeaderCell}" Text="SISTEMA" />
                                <TextBlock Grid.Column="7"  Style="{StaticResource HeaderCell}" Text="QTD" />
                                <TextBlock Grid.Column="8"  Style="{StaticResource HeaderCell}" Text="QUANTIDADE" />
                                <TextBlock Grid.Column="9"  Style="{StaticResource HeaderCell}" Text="UN" />
                                <TextBlock Grid.Column="10" Style="{StaticResource HeaderCell}" Text="AUDITORIA" />
                            </Grid>
                        </Border>
                        <ItemsControl ItemsSource="{Binding Groups}"
                                      ItemTemplate="{StaticResource GroupRowTemplate}" />
                    </StackPanel>
                </Expander>
            </Border>
        </DataTemplate>

        <!-- Slice 4.3.A F2 / hotfix 4.3.A.1 — Style do Border que envolve o
             finding row. Antes era Button, mas Button-dentro-de-Button (o
             "Corrigir agora" interno) fazia o evento Click bubble para o
             ancestral, disparando os DOIS commands no mesmo click. Resultado:
             SelectElementsExternalEvent + 4 ExternalEvent.Create do
             PipeCodesWindow em paralelo = crash fatal do Revit.

             Solução: root vira Border + handler MouseLeftButtonUp no
             code-behind que checa CanSelectInRevit antes de disparar.
             O botão interno "Corrigir agora" continua Button normal e seu
             próprio handler seta e.Handled=true pra cortar o bubble. -->
        <Style x:Key="FindingRowBorder" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource SoftBorder}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="6,8" />
            <Setter Property="Cursor" Value="Arrow" />
            <Style.Triggers>
                <!-- Cursor=Hand só quando o finding tem elementos selecionáveis;
                     findings ProjectInfo (Cliente/Autor/etc) ficam com cursor
                     normal pra não prometer interação que não existe. -->
                <DataTrigger Binding="{Binding CanSelectInRevit}" Value="True">
                    <Setter Property="Cursor" Value="Hand" />
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F4FA" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Slice 4.3.A F1 ampliado — Style do mini-botao "Corrigir agora"
             inline no finding row. Cor accent pra destacar como CTA;
             so aparece quando CanCorrigirAgora=true (Visibility Collapsed
             default). -->
        <Style x:Key="CorrigirAgoraButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>

        <!-- DataTemplate de uma finding (lista lateral).
             Slice 4.2 F3 #6 — ToolTip no FamilyType e MissingFieldsText
             pra mostrar texto completo quando truncado pela sidebar
             estreita.
             Slice 4.3.A F2 / hotfix 4.3.A.1 — root vira Border (não Button)
             pra eliminar Button-dentro-de-Button. MouseLeftButtonUp
             dispara seleção via code-behind; bubble do botão filho é
             cortado por e.Handled=true no handler do "Corrigir agora".
             Slice 4.3.A F1 ampliado — mini-botao "Corrigir agora" inline
             no rodape do finding, visivel apenas quando CanCorrigirAgora. -->
        <DataTemplate x:Key="FindingRowTemplate">
            <Border Style="{StaticResource FindingRowBorder}"
                    MouseLeftButtonUp="OnFindingRowMouseUp">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Style="{StaticResource SeverityPill}" Margin="0,1,10,0" />
                    <StackPanel>
                        <TextBlock Text="{Binding FamilyType}"
                                   Style="{StaticResource BodyCell}"
                                   FontWeight="SemiBold"
                                   ToolTip="{Binding FamilyType}" />
                        <TextBlock Text="{Binding MissingFieldsText}"
                                   Style="{StaticResource PageHintStyle}"
                                   ToolTip="{Binding MissingFieldsText}" />
                        <Button Style="{StaticResource CorrigirAgoraButton}"
                                Content="Corrigir agora"
                                Click="OnCorrigirAgoraClick"
                                Visibility="{Binding CanCorrigirAgora, Converter={StaticResource BoolToVisibility}}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- header projeto -->
            <RowDefinition Height="Auto" />  <!-- KPIs           -->
            <RowDefinition Height="Auto" />  <!-- banner amarelo -->
            <RowDefinition Height="*"   />  <!-- conteúdo       -->
            <RowDefinition Height="Auto" />  <!-- erro           -->
            <RowDefinition Height="Auto" />  <!-- footer         -->
        </Grid.RowDefinitions>

        <!-- ============== Cabeçalho do projeto ==============
             Slice 4.2 F3+F4 — layout duas colunas com separador vertical
             entre IDENTIFICAÇÃO (nome do empreendimento multi-linha,
             coluna larga) e ESCOPO (Cliente/Autor/Data/Versão em grid
             2x2). Antes era WrapPanel 4 campos inline que comprimia o
             nome longo do projeto em uma linha so. -->
        <Border Grid.Row="0"
                Background="{StaticResource CardBg}"
                BorderBrush="{StaticResource SoftBorder}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="20,14"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.4*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Coluna 1: IDENTIFICAÇÃO (multi-linha) -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource EyebrowLabel}" Text="IDENTIFICAÇÃO" />
                    <TextBlock Text="{Binding ProjectName}"
                               Style="{StaticResource PageTitleStyle}"
                               TextWrapping="Wrap"
                               Margin="0,2,12,0" />
                </StackPanel>

                <!-- Separador vertical entre IDENTIFICAÇÃO e ESCOPO -->
                <Border Grid.Column="1"
                        Width="1"
                        Background="{StaticResource SoftBorder}"
                        VerticalAlignment="Stretch"
                        Margin="6,2,16,2" />

                <!-- Coluna 2: ESCOPO em grid 2x2 (4 pares label+valor distribuidos em
                     duas colunas e duas linhas) — aproveita melhor a largura disponivel. -->
                <Grid Grid.Column="2" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Cliente: " Style="{StaticResource PageHintStyle}" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ProjectClient}"
                               Style="{StaticResource PageHintStyle}" FontWeight="SemiBold" Margin="0,0,18,4" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Autor: " Style="{StaticResource PageHintStyle}" />
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding ProjectAuthor}"
                               Style="{StaticResource PageHintStyle}" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Data: " Style="{StaticResource PageHintStyle}" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ProjectIssueDate}"
                               Style="{StaticResource PageHintStyle}" FontWeight="SemiBold" Margin="0,0,18,0" />
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Versão: " Style="{StaticResource PageHintStyle}" />
                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding ProjectVersion}"
                               Style="{StaticResource PageHintStyle}" FontWeight="SemiBold" />
                </Grid>

                <!-- Coluna 4: badge "Tigre Quantifica" -->
                <TextBlock Grid.Column="3"
                           Style="{StaticResource EyebrowLabel}"
                           Text="Tigre Quantifica"
                           VerticalAlignment="Top"
                           Margin="16,0,0,0" />
            </Grid>
        </Border>

        <!-- ============== KPIs ==============
             Slice 4.2 F3 — legenda KPI logo abaixo dos 4 cards pra
             explicar o que cada indicador significa em uma linha. -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <UniformGrid Rows="1" Columns="4">
                <Border Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource EyebrowLabel}" Text="GRUPOS" />
                        <TextBlock Style="{StaticResource KpiValue}"     Text="{Binding TotalGroups}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource EyebrowLabel}" Text="ELEMENTOS" />
                        <TextBlock Style="{StaticResource KpiValue}"     Text="{Binding TotalElementCount}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource EyebrowLabel}" Text="CRÍTICOS" />
                        <TextBlock Style="{StaticResource KpiValue}"     Text="{Binding RedFindingsCount}"
                                   Foreground="{StaticResource RedAccent}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource EyebrowLabel}" Text="ATENÇÃO" />
                        <TextBlock Style="{StaticResource KpiValue}"     Text="{Binding YellowFindingsCount}"
                                   Foreground="{StaticResource YellowAccent}" />
                    </StackPanel>
                </Border>
            </UniformGrid>
            <TextBlock Style="{StaticResource PageHintStyle}"
                       Margin="4,6,0,0"
                       Foreground="{StaticResource TextSoft}"
                       FontSize="11"
                       Text="GRUPOS: linhas agregadas · ELEMENTOS: total no projeto · CRÍTICOS: códigos Tigre faltando · ATENÇÃO: campos secundários incompletos" />
        </StackPanel>

        <!-- ============== Banner amarelo: PipesNeedCoding (slice 1.6 F1) ============== -->
        <Border Grid.Row="2"
                Background="{StaticResource YellowSoftBg}"
                BorderBrush="{StaticResource YellowBorder}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14,10"
                Margin="0,0,0,12"
                Visibility="{Binding PipesNeedCoding, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Foreground="{StaticResource YellowAccent}"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       Text="Nenhum tubo deste projeto tem código Tigre preenchido. Rode 'Codificar Tigre' antes de exportar o relatório de compras." />
        </Border>

        <!-- ============== Conteúdo: categorias + findings ============== -->
        <Grid Grid.Row="3" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,12,0">
                <ItemsControl ItemsSource="{Binding Categories}"
                              ItemTemplate="{StaticResource CategoryCardTemplate}" />
            </ScrollViewer>

            <Border Grid.Column="1"
                    Background="{StaticResource CardBg}"
                    BorderBrush="{StaticResource SoftBorder}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14,12">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Style="{StaticResource EyebrowLabel}" Text="AUDITORIA" />
                        <TextBlock Style="{StaticResource PageTitleStyle}"
                                   Text="{Binding TotalFindingsCount, StringFormat={}{0} achados}" />
                    </StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Findings}"
                                      ItemTemplate="{StaticResource FindingRowTemplate}" />
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ============== Erro fatal ============== -->
        <Border Grid.Row="4"
                Background="{StaticResource RedSoftBg}"
                BorderBrush="{StaticResource RedAccent}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14,10"
                Margin="0,0,0,12"
                Visibility="{Binding HasErrorMessage, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Foreground="{StaticResource RedAccent}"
                       TextWrapping="Wrap"
                       Text="{Binding ErrorMessage}" />
        </Border>

        <!-- ============== Footer ============== -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Style="{StaticResource PageHintStyle}"
                       Text="{Binding StatusMessage}" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="RescanButton"
                        Style="{StaticResource NeutralButtonStyle}"
                        Content="Re-escanear"
                        Click="OnRescanClicked" />
                <Button x:Name="ExportButton"
                        Style="{StaticResource PrimaryButton}"
                        Content="Exportar CSV"
                        Click="OnExportClicked" />
                <Button x:Name="CloseButton"
                        Style="{StaticResource NeutralButtonStyle}"
                        Content="Fechar"
                        Click="OnCloseClicked" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
