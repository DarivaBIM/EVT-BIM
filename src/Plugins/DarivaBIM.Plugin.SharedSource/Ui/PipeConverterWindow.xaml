<Window x:Class="DarivaBIM.Plugin.Ui.PipeConverterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:common="clr-namespace:DarivaBIM.Presentation.Wpf.Common;assembly=DarivaBIM.Presentation.Wpf"
        Title="PipeCADMapper"
        Width="440"
        Height="720"
        MinWidth="440"
        MinHeight="720"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Background="{DynamicResource AppBgBrush}"
        FontFamily="{DynamicResource BodyFont}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        Loaded="OnWindowLoaded"
        Closing="OnWindowClosing">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/Tokens.xaml" />
                <ResourceDictionary Source="/Themes/Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis" />
            <common:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--
            Conteúdo principal: stepper vertical à esquerda + cards de
            cada etapa à direita. Roláveis quando a janela é redimensionada
            para uma altura menor que o conteúdo agregado.
        -->
        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0">
            <Grid Margin="22,20,22,20">
                <Grid.ColumnDefinitions>
                    <!-- Col 0: rail do stepper (badge centralizado, 22px). -->
                    <ColumnDefinition Width="22" />
                    <!-- Col 1: gap entre rail e conteúdo. -->
                    <ColumnDefinition Width="14" />
                    <!-- Col 2: conteúdo da etapa. -->
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ======================================================= -->
                <!-- Etapa 1 — Vínculo CAD                                  -->
                <!-- ======================================================= -->

                <!--
                    Badge da etapa 1. Tag controla o estado:
                      - active (default): fundo Accent, número branco
                      - done: contorno Success + ✓
                    DataTrigger transiciona para "done" assim que o usuário
                    tem um vínculo CAD selecionado (HasCadLink=true).
                -->
                <ContentControl Grid.Row="0" Grid.Column="0"
                                Content="1"
                                VerticalAlignment="Top">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl" BasedOn="{StaticResource StepBadgeStyle}">
                            <Setter Property="Tag" Value="active" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasCadLink}" Value="True">
                                    <Setter Property="Tag" Value="done" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>

                <!--
                    Conector vertical 1→2. Verde quando a etapa 1 está
                    concluída (HasCadLink=true), cinza caso contrário.
                    Margin top de 26px deixa um pequeno respiro abaixo do
                    badge antes de iniciar a linha.
                -->
                <Rectangle Grid.Row="0" Grid.Column="0"
                           Margin="0,26,0,0">
                    <Rectangle.Style>
                        <Style TargetType="Rectangle" BasedOn="{StaticResource StepConnectorStyle}">
                            <Setter Property="Tag" Value="pending" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasCadLink}" Value="True">
                                    <Setter Property="Tag" Value="done" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Rectangle.Style>
                </Rectangle>

                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,22">
                    <TextBlock Style="{StaticResource StepTitleStyle}"
                               Text="Vínculo CAD" />
                    <TextBlock Style="{StaticResource StepSubtitleStyle}"
                               Text="Selecione qual referência externa será mapeada" />

                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,10,0,0">
                        <StackPanel>
                            <!-- Estado vazio: sem CAD selecionado. -->
                            <StackPanel Visibility="{Binding HasCadLink, Converter={StaticResource InverseBoolToVis}}">
                                <TextBlock Style="{StaticResource HelperTextStyle}"
                                           Text="Nenhum vínculo CAD selecionado."
                                           Margin="0,0,0,12" />
                                <Button x:Name="PickCadButton"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Content="Selecionar vínculo CAD"
                                        HorizontalAlignment="Stretch"
                                        Click="OnPickCadClicked" />
                            </StackPanel>

                            <!-- Estado com CAD selecionado: nome + contagem + secundário. -->
                            <StackPanel Visibility="{Binding HasCadLink, Converter={StaticResource BoolToVis}}">
                                <TextBlock x:Name="CadLinkLabel"
                                           Text="{Binding SelectedCadLinkName, FallbackValue='(nenhum vínculo selecionado)', TargetNullValue='(nenhum vínculo selecionado)'}"
                                           FontFamily="{StaticResource DisplayFont}"
                                           FontSize="13.5"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,4" />

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Style="{StaticResource HelperTextStyle}"
                                               VerticalAlignment="Center"
                                               Text="{Binding ElementName=LayerComboBox, Path=Items.Count, Mode=OneWay, FallbackValue=0}" />
                                    <TextBlock Style="{StaticResource HelperTextStyle}"
                                               VerticalAlignment="Center"
                                               Text=" layer(s) detectada(s)" />
                                </StackPanel>

                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                        Content="Selecionar outro vínculo CAD"
                                        HorizontalAlignment="Left"
                                        Padding="14,0"
                                        Click="OnPickCadClicked" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ======================================================= -->
                <!-- Etapa 2 — Configuração                                 -->
                <!-- ======================================================= -->

                <ContentControl Grid.Row="1" Grid.Column="0"
                                Content="2"
                                VerticalAlignment="Top">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl" BasedOn="{StaticResource StepBadgeStyle}">
                            <Setter Property="Tag" Value="pending" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasCadLink}" Value="True">
                                    <Setter Property="Tag" Value="active" />
                                </DataTrigger>
                                <!--
                                    "Done" da etapa 2 é proxy: assim que existem
                                    marcadores na vista (CanConvertMarkers cobre
                                    Count>0 e !Busy) consideramos que a config
                                    foi finalizada o suficiente para a próxima.
                                -->
                                <DataTrigger Binding="{Binding CanConvertMarkers}" Value="True">
                                    <Setter Property="Tag" Value="done" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>

                <Rectangle Grid.Row="1" Grid.Column="0"
                           Margin="0,26,0,0">
                    <Rectangle.Style>
                        <Style TargetType="Rectangle" BasedOn="{StaticResource StepConnectorStyle}">
                            <Setter Property="Tag" Value="pending" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CanConvertMarkers}" Value="True">
                                    <Setter Property="Tag" Value="done" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Rectangle.Style>
                </Rectangle>

                <StackPanel Grid.Row="1" Grid.Column="2"
                            Margin="0,0,0,22"
                            IsEnabled="{Binding HasCadLink}">
                    <TextBlock Style="{StaticResource StepTitleStyle}"
                               Text="Configuração" />
                    <TextBlock Style="{StaticResource StepSubtitleStyle}"
                               Text="Defina layer, sistema, tipo e cota dos tubos" />

                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,10,0,0">
                        <StackPanel>
                            <!-- Layer de referência -->
                            <TextBlock Style="{StaticResource FieldLabelStyle}"
                                       Text="Layer de referência" />
                            <ComboBox x:Name="LayerComboBox"
                                      Style="{StaticResource ComboBoxStyle}"
                                      ItemContainerStyle="{StaticResource ComboBoxItemStyle}"
                                      ItemsSource="{Binding CadLayers}"
                                      SelectedItem="{Binding SelectedLayer}"
                                      Margin="0,0,0,14" />

                            <!-- Modo de representação (segmented control) -->
                            <TextBlock Style="{StaticResource FieldLabelStyle}"
                                       Text="Modo de representação" />
                            <ListBox Style="{StaticResource SegmentedControlStyle}"
                                     Margin="0,0,0,14">
                                <!--
                                    Cada item bind IsSelected nos bools do VM.
                                    Os setters de IsUnifilar/IsBifilar só
                                    reagem quando o valor vira true; o false
                                    do item recém-deselecionado é no-op. Isso
                                    funciona porque ListBox em modo single
                                    sempre garante exatamente uma seleção.
                                -->
                                <ListBoxItem Content="Unifilar"
                                             IsSelected="{Binding IsUnifilar, Mode=TwoWay}" />
                                <ListBoxItem Content="Bifilar"
                                             IsSelected="{Binding IsBifilar, Mode=TwoWay}" />
                            </ListBox>

                            <!-- Sistema -->
                            <TextBlock Style="{StaticResource FieldLabelStyle}"
                                       Text="Sistema" />
                            <ComboBox x:Name="SystemComboBox"
                                      Style="{StaticResource ComboBoxStyle}"
                                      ItemContainerStyle="{StaticResource ComboBoxItemStyle}"
                                      ItemsSource="{Binding Systems}"
                                      SelectedItem="{Binding SelectedSystem}"
                                      DisplayMemberPath="Name"
                                      Margin="0,0,0,14" />

                            <!-- Tipo de tubo -->
                            <TextBlock Style="{StaticResource FieldLabelStyle}"
                                       Text="Tipo de tubo" />
                            <ComboBox x:Name="PipeTypeComboBox"
                                      Style="{StaticResource ComboBoxStyle}"
                                      ItemContainerStyle="{StaticResource ComboBoxItemStyle}"
                                      ItemsSource="{Binding PipeTypes}"
                                      SelectedItem="{Binding SelectedPipeType}"
                                      DisplayMemberPath="Name"
                                      Margin="0,0,0,14" />

                            <!--
                                Diâmetro: visível apenas em Unifilar. Em Bifilar
                                a distância entre as paredes do CAD define o
                                diâmetro automaticamente (snappa para a lista
                                do tipo), então o input perde propósito.
                            -->
                            <StackPanel Visibility="{Binding IsUnifilar, Converter={StaticResource BoolToVis}}">
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Style="{StaticResource FieldLabelStyle}"
                                               Margin="0"
                                               Text="Diâmetro" />
                                    <TextBlock Grid.Column="1"
                                               Style="{StaticResource HelperTextStyle}"
                                               VerticalAlignment="Center"
                                               Text="mm" />
                                </Grid>
                                <ComboBox x:Name="DiameterComboBox"
                                          Style="{StaticResource ComboBoxStyle}"
                                          ItemContainerStyle="{StaticResource ComboBoxItemStyle}"
                                          ItemsSource="{Binding Diameters}"
                                          SelectedItem="{Binding SelectedDiameterMm}"
                                          Margin="0,0,0,14" />
                            </StackPanel>

                            <!-- Nível de referência -->
                            <TextBlock Style="{StaticResource FieldLabelStyle}"
                                       Text="Nível de referência" />
                            <ComboBox x:Name="LevelComboBox"
                                      Style="{StaticResource ComboBoxStyle}"
                                      ItemContainerStyle="{StaticResource ComboBoxItemStyle}"
                                      ItemsSource="{Binding Levels}"
                                      SelectedItem="{Binding SelectedLevel}"
                                      IsEnabled="{Binding IsLevelInputEnabled}"
                                      DisplayMemberPath="Name"
                                      Margin="0,0,0,10" />

                            <!-- Card cinza com checkbox de nível do CAD -->
                            <Border Style="{StaticResource SubtleCardBorderStyle}" Margin="0,0,0,14">
                                <CheckBox Style="{StaticResource CheckBoxStyle}"
                                          Content="Usar o nível de referência do CAD selecionado"
                                          IsChecked="{Binding UseCadElevation}"
                                          ToolTip="Quando marcado, o nível de referência é fixado no nível associado ao vínculo CAD selecionado." />
                            </Border>

                            <!--
                                Cota em relação ao nível — offset manual. NÃO
                                desabilita quando UseCadElevation está marcado:
                                o offset é somado sobre o nível derivado do CAD
                                e segue editável em ambos os modos.
                            -->
                            <TextBlock Style="{StaticResource FieldLabelStyle}"
                                       Text="Cota em relação ao nível" />
                            <TextBox x:Name="OffsetTextBox"
                                     Style="{StaticResource TextBoxStyle}"
                                     Tag="mm"
                                     Text="{Binding OffsetMm, StringFormat={}{0:0.##}}"
                                     Margin="0,0,0,14" />

                            <!--
                                Tolerância — slider visível APENAS no modo
                                Bifilar (no Unifilar é colapsado, o que mantém
                                o ToleranceLevelIndex bindado no background mas
                                fora da árvore visual renderizada).
                            -->
                            <StackPanel Visibility="{Binding IsBifilar, Converter={StaticResource BoolToVis}}">
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Style="{StaticResource FieldLabelStyle}"
                                               Margin="0"
                                               Text="Tolerância" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding SelectedToleranceLabel}"
                                               FontFamily="{StaticResource BodyFont}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBrush}"
                                               VerticalAlignment="Center" />
                                </Grid>

                                <Slider x:Name="ToleranceSlider"
                                        Style="{StaticResource ToleranceSliderStyle}"
                                        Value="{Binding ToleranceLevelIndex, Mode=TwoWay}"
                                        Margin="0,4,0,4" />

                                <!--
                                    5 dots circulares como ticks. UniformGrid
                                    distribui em 5 colunas iguais; o centro
                                    geométrico do dot fica no meio de cada
                                    coluna — alinha aproximadamente com as 5
                                    posições snap-to-tick do slider.
                                -->
                                <UniformGrid Rows="1" Columns="5" Margin="0,0,0,4">
                                    <Ellipse Style="{StaticResource ToleranceTickDotStyle}" />
                                    <Ellipse Style="{StaticResource ToleranceTickDotStyle}" />
                                    <Ellipse Style="{StaticResource ToleranceTickDotStyle}" />
                                    <Ellipse Style="{StaticResource ToleranceTickDotStyle}" />
                                    <Ellipse Style="{StaticResource ToleranceTickDotStyle}" />
                                </UniformGrid>

                                <!--
                                    Labels dos 5 níveis. DataTriggers em cada
                                    label comparam ToleranceLevelIndex (0..4)
                                    com o índice fixo da posição e destacam
                                    em Accent SemiBold quando coincide.
                                -->
                                <UniformGrid Rows="1" Columns="5">
                                    <TextBlock Text="Muito baixa">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource ToleranceTickLabelStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ToleranceLevelIndex}" Value="0">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="Baixa">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource ToleranceTickLabelStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ToleranceLevelIndex}" Value="1">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="Média">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource ToleranceTickLabelStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ToleranceLevelIndex}" Value="2">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="Alta">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource ToleranceTickLabelStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ToleranceLevelIndex}" Value="3">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="Muito alta">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource ToleranceTickLabelStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ToleranceLevelIndex}" Value="4">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </UniformGrid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ======================================================= -->
                <!-- Etapa 3 — Criar marcadores                             -->
                <!-- ======================================================= -->

                <ContentControl Grid.Row="2" Grid.Column="0"
                                Content="3"
                                VerticalAlignment="Top">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl" BasedOn="{StaticResource StepBadgeStyle}">
                            <Setter Property="Tag" Value="pending" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasCadLink}" Value="True">
                                    <Setter Property="Tag" Value="active" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CanConvertMarkers}" Value="True">
                                    <Setter Property="Tag" Value="done" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>

                <Rectangle Grid.Row="2" Grid.Column="0"
                           Margin="0,26,0,0">
                    <Rectangle.Style>
                        <Style TargetType="Rectangle" BasedOn="{StaticResource StepConnectorStyle}">
                            <Setter Property="Tag" Value="pending" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CanConvertMarkers}" Value="True">
                                    <Setter Property="Tag" Value="done" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Rectangle.Style>
                </Rectangle>

                <StackPanel Grid.Row="2" Grid.Column="2"
                            Margin="0,0,0,22"
                            IsEnabled="{Binding HasCadLink}">
                    <TextBlock Style="{StaticResource StepTitleStyle}"
                               Text="Criar marcadores" />
                    <TextBlock Style="{StaticResource StepSubtitleStyle}"
                               Text="Marque as linhas do layer para gerar tubos" />

                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,10,0,0">
                        <StackPanel>
                            <!-- Unifilar: pick linha-a-linha (primário) + batch (ghost). -->
                            <StackPanel Visibility="{Binding IsUnifilar, Converter={StaticResource BoolToVis}}">
                                <Button x:Name="ToggleLinePickButton"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Content="{Binding ToggleButtonText}"
                                        HorizontalAlignment="Stretch"
                                        Margin="0,0,0,8"
                                        Click="OnToggleLinePickClicked" />
                                <Button x:Name="UnifilarBatchButton"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Content="Marcar todas as linhas do layer"
                                        HorizontalAlignment="Stretch"
                                        Click="OnBatchClicked" />
                            </StackPanel>

                            <!-- Bifilar: apenas detecção automática (primário). -->
                            <StackPanel Visibility="{Binding IsBifilar, Converter={StaticResource BoolToVis}}">
                                <Button x:Name="BifilarBatchButton"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Content="Detectar tubos bifilar e marcar"
                                        HorizontalAlignment="Stretch"
                                        Click="OnBatchClicked" />
                            </StackPanel>

                            <!-- Contador de marcadores na vista. -->
                            <TextBlock Margin="0,12,0,0"
                                       Style="{StaticResource HelperTextStyle}">
                                <Run Text="Marcadores na vista: " />
                                <Run Text="{Binding ActiveViewMarkerCount, Mode=OneWay, FallbackValue=0}"
                                     FontWeight="SemiBold"
                                     Foreground="{StaticResource TextBrush}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ======================================================= -->
                <!-- Etapa 4 — Converter em tubos                            -->
                <!-- ======================================================= -->

                <ContentControl Grid.Row="3" Grid.Column="0"
                                Content="4"
                                VerticalAlignment="Top">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl" BasedOn="{StaticResource StepBadgeStyle}">
                            <Setter Property="Tag" Value="pending" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CanConvertMarkers}" Value="True">
                                    <Setter Property="Tag" Value="active" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>

                <!-- Última etapa não tem conector descendo. -->

                <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,0,0,0">
                    <TextBlock Style="{StaticResource StepTitleStyle}"
                               Text="Converter em tubos" />
                    <TextBlock Style="{StaticResource StepSubtitleStyle}"
                               Text="Transforme os marcadores criados em tubos reais" />

                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,10,0,0">
                        <StackPanel>
                            <Button x:Name="ConvertMarkersButton"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Content="Converter marcadores em tubos"
                                    HorizontalAlignment="Stretch"
                                    IsEnabled="{Binding CanConvertMarkers}"
                                    Click="OnConvertMarkersClicked" />

                            <!--
                                Helper exibido apenas quando o botão está
                                desabilitado (i.e., sem marcadores ainda).
                            -->
                            <TextBlock Style="{StaticResource HelperTextStyle}"
                                       Margin="0,8,0,0"
                                       Text="Crie marcadores primeiro para habilitar esta ação."
                                       Visibility="{Binding CanConvertMarkers, Converter={StaticResource InverseBoolToVis}}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!--
            Barra de status — fonte monoespaçada, bolinha verde indicando
            que a ferramenta está pronta. Bindado em StatusMessage para
            refletir o estado dinâmico (carregando, detectando, pronto).
        -->
        <Border Grid.Row="1" Style="{StaticResource StatusBarStyle}">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8"
                         Height="8"
                         Fill="{StaticResource SuccessBrush}"
                         Margin="0,0,8,0"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="StatusTextBlock"
                           Style="{StaticResource StatusTextStyle}"
                           Text="{Binding StatusMessage}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
