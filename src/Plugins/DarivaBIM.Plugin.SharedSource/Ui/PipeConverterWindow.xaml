<Window x:Class="DarivaBIM.Plugin.Ui.PipeConverterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PipeCADMapper"
        Width="360"
        SizeToContent="Height"
        ResizeMode="CanMinimize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Background="#F4F7FB"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="OnWindowLoaded"
        Closing="OnWindowClosing">

    <Window.Resources>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SoftBorderBrush" Color="#D8E0EA" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F172A" />
        <SolidColorBrush x:Key="LabelBrush" Color="#64748B" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="ActiveBrush" Color="#16A34A" />
        <SolidColorBrush x:Key="AccentBrush" Color="#D946EF" />
        <SolidColorBrush x:Key="SectionBrush" Color="#F8FAFC" />

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource LabelBrush}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,4,0,8" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="28" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="28" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,4,0,4" />
        </Style>

        <Style x:Key="ToggleButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Background" Value="{StaticResource ActiveBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource LabelBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,10,0,0" />
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Border Background="{StaticResource CardBackgroundBrush}"
            BorderBrush="{StaticResource SoftBorderBrush}"
            BorderThickness="1"
            CornerRadius="14"
            Margin="12"
            Padding="16">
        <StackPanel>
            <TextBlock Text="PipeCADMapper"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,12" />

            <!-- 1) Vínculo CAD -->
            <Border Background="{StaticResource SectionBrush}"
                    BorderBrush="{StaticResource SoftBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="1. Vínculo CAD" Style="{StaticResource SectionTitleStyle}" />

                    <Button x:Name="PickCadButton"
                            Content="Selecionar vínculo CAD"
                            Style="{StaticResource PrimaryButton}"
                            Click="OnPickCadClicked" />

                    <TextBlock x:Name="CadLinkLabel"
                               Margin="0,4,0,0"
                               FontSize="11"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding SelectedCadLinkName, FallbackValue='(nenhum vínculo selecionado)', TargetNullValue='(nenhum vínculo selecionado)'}" />
                </StackPanel>
            </Border>

            <!-- 2) Configuração (só habilitada após selecionar CAD) -->
            <Border Background="{StaticResource SectionBrush}"
                    BorderBrush="{StaticResource SoftBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,10"
                    IsEnabled="{Binding HasCadLink}">
                <StackPanel>
                    <TextBlock Text="2. Configuração" Style="{StaticResource SectionTitleStyle}" />

                    <TextBlock Text="Layer de referência" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox x:Name="LayerComboBox"
                              ItemsSource="{Binding CadLayers}"
                              SelectedItem="{Binding SelectedLayer}" />

                    <TextBlock Text="Modo de representação" Style="{StaticResource FieldLabelStyle}" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <RadioButton Content="Unifilar"
                                     GroupName="ModeGroup"
                                     IsChecked="{Binding IsUnifilar, Mode=TwoWay}"
                                     Margin="0,0,16,0"
                                     VerticalAlignment="Center" />
                        <RadioButton Content="Bifilar"
                                     GroupName="ModeGroup"
                                     IsChecked="{Binding IsBifilar, Mode=TwoWay}"
                                     VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Text="Sistema" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox x:Name="SystemComboBox"
                              ItemsSource="{Binding Systems}"
                              SelectedItem="{Binding SelectedSystem}"
                              DisplayMemberPath="Name" />

                    <TextBlock Text="Tipo de tubo" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox x:Name="PipeTypeComboBox"
                              ItemsSource="{Binding PipeTypes}"
                              SelectedItem="{Binding SelectedPipeType}"
                              DisplayMemberPath="Name" />

                    <!-- Diâmetro só faz sentido em unifilar; em bifilar a distância
                         entre as paredes do CAD define o diâmetro (snappado para a
                         lista do tipo) e o input ficaria sem propósito. -->
                    <StackPanel Visibility="{Binding IsUnifilar, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Diâmetro (mm)" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox x:Name="DiameterComboBox"
                                  ItemsSource="{Binding Diameters}"
                                  SelectedItem="{Binding SelectedDiameterMm}" />
                    </StackPanel>

                    <TextBlock Text="Nível de referência" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox x:Name="LevelComboBox"
                              ItemsSource="{Binding Levels}"
                              SelectedItem="{Binding SelectedLevel}"
                              IsEnabled="{Binding IsLevelInputEnabled}"
                              DisplayMemberPath="Name" />

                    <CheckBox Content="Usar cota Z do próprio CAD selecionado"
                              IsChecked="{Binding UseCadElevation}"
                              Margin="0,0,0,10"
                              VerticalAlignment="Center" />

                    <TextBlock Text="Cota em relação ao nível (mm)" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="OffsetTextBox"
                             IsEnabled="{Binding IsLevelInputEnabled}"
                             Text="{Binding OffsetMm, StringFormat={}{0:0.##}}" />

                    <TextBlock Style="{StaticResource FieldLabelStyle}">
                        <Run Text="Tolerância (modo bifilar) — " />
                        <Run Text="{Binding TolerancePercent, StringFormat={}{0:0}%, Mode=OneWay}"
                             FontWeight="Bold"
                             Foreground="{StaticResource TextPrimaryBrush}" />
                    </TextBlock>
                    <Slider x:Name="ToleranceSlider"
                            Minimum="0"
                            Maximum="100"
                            TickFrequency="10"
                            IsSnapToTickEnabled="False"
                            TickPlacement="BottomRight"
                            Value="{Binding TolerancePercent, Mode=TwoWay}"
                            Margin="0,0,0,10" />
                </StackPanel>
            </Border>

            <!-- 3) Marcadores (só habilitado após selecionar CAD + layer) -->
            <Border Background="{StaticResource SectionBrush}"
                    BorderBrush="{StaticResource SoftBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,10"
                    IsEnabled="{Binding HasCadLink}">
                <StackPanel>
                    <TextBlock Text="3. Criar marcadores" Style="{StaticResource SectionTitleStyle}" />

                    <!-- Unifilar: pick linha-a-linha e batch -->
                    <StackPanel Visibility="{Binding IsUnifilar, Converter={StaticResource BoolToVis}}">
                        <Button x:Name="ToggleLinePickButton"
                                Content="{Binding ToggleButtonText}"
                                Style="{StaticResource ToggleButton}"
                                Click="OnToggleLinePickClicked" />

                        <Button x:Name="UnifilarBatchButton"
                                Content="Marcar todas as linhas do layer"
                                Style="{StaticResource AccentButton}"
                                Click="OnBatchClicked" />
                    </StackPanel>

                    <!-- Bifilar: apenas batch (detecção automática) -->
                    <StackPanel Visibility="{Binding IsBifilar, Converter={StaticResource BoolToVis}}">
                        <Button x:Name="BifilarBatchButton"
                                Content="Detectar tubos bifilar e marcar"
                                Style="{StaticResource AccentButton}"
                                Click="OnBatchClicked" />
                    </StackPanel>

                    <TextBlock Margin="0,6,0,0"
                               FontSize="11"
                               Foreground="{StaticResource LabelBrush}"
                               TextWrapping="Wrap">
                        <Run Text="Marcadores na vista: " />
                        <Run Text="{Binding ActiveViewMarkerCount, Mode=OneWay}"
                             FontWeight="Bold" />
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- 4) Conversão -->
            <Border Background="{StaticResource SectionBrush}"
                    BorderBrush="{StaticResource SoftBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,0">
                <StackPanel>
                    <TextBlock Text="4. Converter em tubos" Style="{StaticResource SectionTitleStyle}" />

                    <Button x:Name="ConvertMarkersButton"
                            Content="Converter marcadores em tubos"
                            Style="{StaticResource PrimaryButton}"
                            IsEnabled="{Binding CanConvertMarkers}"
                            Click="OnConvertMarkersClicked" />
                </StackPanel>
            </Border>

            <TextBlock x:Name="StatusTextBlock"
                       Style="{StaticResource StatusTextStyle}"
                       Text="{Binding StatusMessage}" />
        </StackPanel>
    </Border>
</Window>
