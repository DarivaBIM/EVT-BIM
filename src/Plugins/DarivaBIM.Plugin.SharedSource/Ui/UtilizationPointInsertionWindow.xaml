<Window x:Class="DarivaBIM.Plugin.Ui.UtilizationPointInsertionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:common="clr-namespace:DarivaBIM.Presentation.Wpf.Common;assembly=DarivaBIM.Presentation.Wpf"
        xmlns:vmup="clr-namespace:DarivaBIM.Presentation.Wpf.UtilizationPoints;assembly=DarivaBIM.Presentation.Wpf"
        Title="Inserção de Pontos de Utilização"
        Width="820"
        Height="700"
        MinWidth="820"
        MinHeight="600"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7FB"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="OnWindowLoaded"
        Closing="OnWindowClosing"
        PreviewMouseMove="OnWindowPreviewMouseMove"
        PreviewMouseLeftButtonUp="OnWindowPreviewMouseLeftButtonUp">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <common:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <common:OneBasedIndexConverter x:Key="OneBasedIndex" />

        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SoftBorderBrush" Color="#D8E0EA" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F172A" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#475569" />
        <SolidColorBrush x:Key="LabelBrush" Color="#64748B" />
        <SolidColorBrush x:Key="MutedBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#0EA5E9" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#0284C7" />
        <SolidColorBrush x:Key="AccentBrush" Color="#06B6D4" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#10B981" />
        <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B" />
        <SolidColorBrush x:Key="DangerBrush" Color="#EF4444" />
        <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="SidebarItemBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="RuleCardBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="RuleCardBorderBrush" Color="#E2E8F0" />
        <SolidColorBrush x:Key="ChipOkBackgroundBrush" Color="#DCFCE7" />
        <SolidColorBrush x:Key="ChipOkForegroundBrush" Color="#15803D" />
        <SolidColorBrush x:Key="ChipWarningBackgroundBrush" Color="#FEF3C7" />
        <SolidColorBrush x:Key="ChipWarningForegroundBrush" Color="#B45309" />
        <SolidColorBrush x:Key="HintBannerBackgroundBrush" Color="#FFF3CD" />
        <SolidColorBrush x:Key="HintBannerBorderBrush" Color="#F0B429" />
        <SolidColorBrush x:Key="HintBannerForegroundBrush" Color="#8A4B00" />

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="SubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource LabelBrush}" />
        </Style>

        <Style x:Key="SidebarHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource LabelBrush}" />
        </Style>

        <Style x:Key="ChipTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="{StaticResource RuleCardBorderBrush}" />
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <!-- Combo da linha precisa caber thumbnail 24×24 + duas linhas de
             texto sem cortar a categoria. -->
        <Style x:Key="RuleTypeComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="6,4" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="110" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="12,0" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource RuleCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="IconActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <!-- Larguras das colunas: cabeçalho e linhas compartilham. Tipo é Star
             para flexar com o tamanho da janela; demais são fixas e enxutas.
             Min/Max ganharam 8 px a mais para acomodar o sufixo " m" depois
             do campo numérico. -->
        <GridLength x:Key="ColReorderWidth">28</GridLength>
        <GridLength x:Key="ColAltMinWidth">72</GridLength>
        <GridLength x:Key="ColAltMaxWidth">72</GridLength>
        <GridLength x:Key="ColStatusWidth">56</GridLength>
        <GridLength x:Key="ColActionsWidth">70</GridLength>

        <!-- ScrollBar slim: trilho transparente, polegar arredondado e
             discreto, com leve realce no hover. Auto-hide é mantido via
             VerticalScrollBarVisibility="Auto" no ScrollViewer; quando some,
             o gutter reservado no cabeçalho cobre a diferença de largura. -->
        <Style x:Key="SlimScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Background="#C8D2DE"
                                CornerRadius="4"
                                Margin="2,2,2,2" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#94A3B8" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#64748B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SlimScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="8" />
            <Setter Property="MinWidth" Value="8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent" SnapsToDevicePixels="True">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SlimScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <!-- Page-up/page-down botões invisíveis para
                                     manter o gesto de clicar no trilho. -->
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Opacity="0"
                                                  Focusable="False"
                                                  IsTabStop="False" />
                                </Track.IncreaseRepeatButton>
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Opacity="0"
                                                  Focusable="False"
                                                  IsTabStop="False" />
                                </Track.DecreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="8" />
                    <Setter Property="MinHeight" Value="8" />
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="MinWidth" Value="0" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ScrollViewer que aplica a SlimScrollBar como padrão. A coluna do
             scrollbar é fixa em 8 px sempre — isso reserva o "gutter"
             permanente para que o cabeçalho de colunas não desalinhe quando a
             barra entra/sai. Quando não há overflow, a coluna fica
             transparente. -->
        <Style x:Key="SlimScrollViewerStyle" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <ScrollContentPresenter Grid.Column="0" Grid.Row="0"
                                                    CanContentScroll="{TemplateBinding CanContentScroll}"
                                                    Margin="{TemplateBinding Padding}" />
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Grid.Column="1" Grid.Row="0"
                                       Style="{StaticResource SlimScrollBarStyle}"
                                       Orientation="Vertical"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Value="{Binding VerticalOffset, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" />
                            <ScrollBar x:Name="PART_HorizontalScrollBar"
                                       Grid.Column="0" Grid.Row="1"
                                       Style="{StaticResource SlimScrollBarStyle}"
                                       Orientation="Horizontal"
                                       Maximum="{TemplateBinding ScrollableWidth}"
                                       ViewportSize="{TemplateBinding ViewportWidth}"
                                       Value="{Binding HorizontalOffset, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}"
                                       Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Ícones vetoriais (Path) usados nos badges de status. Trocam os
             glifos Unicode ✓/⚠, que ficavam dependentes da fonte instalada e
             desalinhavam por causa do baseline. -->
        <Geometry x:Key="CheckIconGeometry">M2,6 L5,9 L10,2.5</Geometry>
        <Geometry x:Key="WarningIconGeometry">M6,1 L11,10 L1,10 Z M6,4.2 L6,7.2 M6,8.4 L6,9.0</Geometry>

        <Style x:Key="StatusBadgeStyle" TargetType="Border">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="CornerRadius" Value="11" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>

        <!-- TextBox dedicado às colunas Alt.Mín/Alt.Máx: alinhamento à
             direita (deixa o sufixo "m" colado no número) e borda vermelha
             quando a regra está com Max < Min. Reage a IsRangeInvalid do
             RuleViewModel via DataTrigger. -->
        <Style x:Key="HeightTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="Padding" Value="6,4,2,4" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRangeInvalid}" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                    <Setter Property="BorderThickness" Value="1.5" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" MinWidth="540" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="#FFFFFF"
                BorderBrush="{StaticResource SoftBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                               Text="Inserção de Pontos de Utilização" />
                    <TextBlock Style="{StaticResource SubtitleStyle}"
                               Margin="0,2,0,0"
                               Text="Configure grupos por ambiente e insira peças automaticamente em conectores hidráulicos livres." />
                </StackPanel>
                <Border Grid.Column="1"
                        Background="#F1F5F9"
                        CornerRadius="14"
                        Padding="10,6"
                        VerticalAlignment="Center"
                        MaxWidth="260">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                        <TextBlock Margin="8,0,0,0"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="{Binding StatusMessage}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Sidebar: groups + preset I/O + tip -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{StaticResource SidebarBackgroundBrush}"
                BorderBrush="{StaticResource SoftBorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="12,12,12,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Style="{StaticResource SidebarHeaderStyle}"
                               Text="GRUPOS"
                               TextTrimming="CharacterEllipsis" />
                    <Border Grid.Column="1"
                            Background="#E2E8F0"
                            CornerRadius="9"
                            Padding="6,1">
                        <TextBlock FontSize="10.5"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="{Binding GroupsCount}" />
                    </Border>
                </Grid>

                <Grid Grid.Row="1">
                    <!-- Empty state quando o usuário apagou todos os grupos.
                         O default-loader recria um Banheiro padrão na primeira
                         abertura, então isso só aparece após delete manual. -->
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="20,0,20,20"
                                Visibility="{Binding HasGroups, Converter={StaticResource InverseBoolToVisibility}}">
                        <TextBlock Text="📁"
                                   FontSize="22"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource MutedBrush}" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Text="Nenhum grupo ainda" />
                        <TextBlock Margin="0,2,0,0"
                                   FontSize="10.5"
                                   Foreground="{StaticResource MutedBrush}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Text="Crie um para começar a configurar as regras de inserção." />
                    </StackPanel>

                    <ScrollViewer Style="{StaticResource SlimScrollViewerStyle}"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="4,0,4,6"
                                  Visibility="{Binding HasGroups, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl ItemsSource="{Binding Groups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vmup:UtilizationPointGroupViewModel}">
                                <Border Margin="4,3,4,3"
                                        CornerRadius="8"
                                        Padding="8,6"
                                        BorderThickness="1"
                                        MouseLeftButtonUp="OnGroupItemClicked">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource SidebarItemBackgroundBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource RuleCardBorderBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Background" Value="#EFF6FF" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Width="26" Height="26"
                                                CornerRadius="8"
                                                Background="#E0F2FE"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding InitialLetter}"
                                                       FontWeight="Bold"
                                                       FontSize="12"
                                                       Foreground="{StaticResource PrimaryDarkBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1"
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="{Binding RulesCountLabel}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource MutedBrush}" />
                                                <TextBlock Text=" · "
                                                           FontSize="10"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           Visibility="{Binding HasMissingTypes, Converter={StaticResource BoolToVisibility}}" />
                                                <TextBlock Text="{Binding MissingTypesLabel}"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource WarningBrush}"
                                                           Visibility="{Binding HasMissingTypes, Converter={StaticResource BoolToVisibility}}" />
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Button Style="{StaticResource IconActionButtonStyle}"
                                                    Width="22" Height="22"
                                                    Click="OnRenameGroupClicked"
                                                    Tag="{Binding Id}"
                                                    ToolTip="Renomear"
                                                    Content="✎" />
                                            <Button Style="{StaticResource IconActionButtonStyle}"
                                                    Width="22" Height="22"
                                                    Click="OnDuplicateGroupClicked"
                                                    Tag="{Binding Id}"
                                                    ToolTip="Duplicar"
                                                    Content="❐" />
                                            <Button Style="{StaticResource IconActionButtonStyle}"
                                                    Width="22" Height="22"
                                                    Click="OnDeleteGroupClicked"
                                                    Tag="{Binding Id}"
                                                    ToolTip="Excluir"
                                                    Content="🗑" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <Button Grid.Row="2"
                        Style="{StaticResource GhostButtonStyle}"
                        Margin="12,6,12,8"
                        MinWidth="0"
                        Height="32"
                        Padding="6,0"
                        Click="OnNewGroupClicked"
                        Content="+ Novo grupo" />

                <Border Grid.Row="3"
                        Margin="12,0,12,8"
                        Padding="10"
                        CornerRadius="8"
                        Background="#FFFFFF"
                        BorderBrush="{StaticResource RuleCardBorderBrush}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="💡 Dica"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Margin="0,4,0,0"
                                   FontSize="10.5"
                                   Foreground="{StaticResource MutedBrush}"
                                   TextWrapping="Wrap"
                                   Text="Presets agrupam vários grupos e podem ser compartilhados com a equipe." />
                    </StackPanel>
                </Border>

                <Grid Grid.Row="4" Margin="12,0,12,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Style="{StaticResource GhostButtonStyle}"
                            MinWidth="0"
                            Height="30"
                            Padding="4,0"
                            FontSize="11"
                            Click="OnImportPresetClicked"
                            ToolTip="Importa todos os grupos de um arquivo JSON."
                            Content="📥 Importar"
                            Margin="0,0,3,0" />
                    <Button Grid.Column="1"
                            Style="{StaticResource GhostButtonStyle}"
                            MinWidth="0"
                            Height="30"
                            Padding="4,0"
                            FontSize="11"
                            Click="OnExportPresetClicked"
                            ToolTip="Exporta todos os grupos para um arquivo JSON."
                            Content="📤 Exportar"
                            Margin="3,0,0,0" />
                </Grid>
            </Grid>
        </Border>

        <!-- Main content: rules editor -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Active group header + add point -->
            <Grid Grid.Row="0" Margin="18,14,18,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                               Text="{Binding ActiveGroupName}"
                               TextTrimming="CharacterEllipsis" />
                    <Border Margin="10,0,0,0"
                            Background="{StaticResource ChipOkBackgroundBrush}"
                            CornerRadius="10"
                            Padding="9,3"
                            Visibility="{Binding HasActiveGroup, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="ATIVO"
                                   FontSize="10.5"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ChipOkForegroundBrush}" />
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource GhostButtonStyle}"
                            MinWidth="0"
                            Padding="10,0"
                            Click="OnRestoreDefaultsClicked"
                            ToolTip="Substitui as regras atuais pelo preset padrão de banheiro."
                            Visibility="{Binding HasActiveGroup, Converter={StaticResource BoolToVisibility}}"
                            Content="↻ Restaurar padrões" />
                    <Button Style="{StaticResource PrimaryButtonStyle}"
                            Margin="8,0,0,0"
                            MinWidth="0"
                            Padding="12,0"
                            Click="OnAddRuleClicked"
                            Content="+ Adicionar ponto" />
                </StackPanel>
            </Grid>

            <!-- Summary chips: agora ficam logo abaixo do nome do grupo, fora
                 do bloco de nível de referência (faz mais sentido como
                 cabeçalho do grupo do que como dependência do nível). -->
            <WrapPanel Grid.Row="1" Margin="18,0,18,8" Orientation="Horizontal">
                <Border Background="#FFFFFF"
                        CornerRadius="8"
                        Padding="8,4"
                        Margin="0,0,6,4"
                        BorderBrush="{StaticResource RuleCardBorderBrush}"
                        BorderThickness="1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource PrimaryBrush}" />
                        <TextBlock Margin="6,0,0,0"
                                   FontWeight="Bold"
                                   FontSize="11.5"
                                   Text="{Binding ActiveGroup.RulesCount, FallbackValue=0}" />
                        <TextBlock Margin="6,0,0,0"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="11"
                                   Text="pontos configurados" />
                    </StackPanel>
                </Border>
                <Border Background="#FFFFFF"
                        CornerRadius="8"
                        Padding="8,4"
                        Margin="0,0,6,4"
                        BorderBrush="{StaticResource RuleCardBorderBrush}"
                        BorderThickness="1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" />
                        <TextBlock Margin="6,0,0,0"
                                   FontWeight="Bold"
                                   FontSize="11.5"
                                   Text="{Binding ActiveGroupTypesFoundLabel}" />
                        <TextBlock Margin="6,0,0,0"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="11"
                                   Text="tipos encontrados" />
                    </StackPanel>
                </Border>
                <Border Background="#FFFFFF"
                        CornerRadius="8"
                        Padding="8,4"
                        Margin="0,0,0,4"
                        BorderBrush="{StaticResource RuleCardBorderBrush}"
                        BorderThickness="1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource WarningBrush}" />
                        <TextBlock Margin="6,0,0,0"
                                   FontWeight="Bold"
                                   FontSize="11.5"
                                   Text="{Binding ActiveGroupMissingTypesLabel}" />
                        <TextBlock Margin="6,0,0,0"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="11"
                                   Text="tipo não encontrado" />
                    </StackPanel>
                </Border>
            </WrapPanel>

            <TextBlock Grid.Row="2"
                       Margin="18,0,18,8"
                       Style="{StaticResource SubtitleStyle}"
                       Text="Regras de inserção por faixa de altura. A peça é escolhida pela cota do conector livre em relação ao nível. A ordem das regras define a preferência em caso de empate de faixa." />

            <!-- Awaiting selection hint (responsive: text wraps) -->
            <Border Grid.Row="3"
                    Margin="18,0,18,8"
                    Padding="12,8"
                    CornerRadius="8"
                    Background="{StaticResource HintBannerBackgroundBrush}"
                    BorderBrush="{StaticResource HintBannerBorderBrush}"
                    BorderThickness="1"
                    Visibility="{Binding IsAwaitingSelection, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="⚠"
                               FontSize="14"
                               FontWeight="Bold"
                               VerticalAlignment="Top"
                               Margin="0,1,8,0"
                               Foreground="{StaticResource HintBannerForegroundBrush}" />
                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               FontSize="11.5"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource HintBannerForegroundBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding AwaitingSelectionHint}" />
                </Grid>
            </Border>

            <!-- Level reference (slimmer now: só o dropdown + tolerância) -->
            <Border Grid.Row="4"
                    Margin="18,0,18,8"
                    Background="#F8FAFC"
                    CornerRadius="8"
                    BorderBrush="{StaticResource RuleCardBorderBrush}"
                    BorderThickness="1"
                    Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Style="{StaticResource LabelStyle}"
                               Text="NÍVEL DE REFERÊNCIA"
                               VerticalAlignment="Center" />
                    <ComboBox Grid.Column="1"
                              Margin="12,0,12,0"
                              MaxWidth="280"
                              HorizontalAlignment="Left"
                              ItemsSource="{Binding Levels}"
                              SelectedItem="{Binding SelectedLevel, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vmup:LevelOptionViewModel}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding DisplayName}" />
                                    <TextBlock Text="  "
                                               Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock Text="{Binding ElevationLabel}"
                                               Foreground="{StaticResource MutedBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Grid.Column="2"
                               FontSize="10.5"
                               Foreground="{StaticResource MutedBrush}"
                               VerticalAlignment="Center"
                               Text="Tolerância ±0.02 m" />
                </Grid>
            </Border>

            <!-- Rules list -->
            <Grid Grid.Row="5" Margin="18,0,18,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Column header. A última coluna de 8 px casa exatamente com
                     o gutter reservado pelo SlimScrollViewerStyle, de modo
                     que o cabeçalho permaneça alinhado às linhas haja ou não
                     scrollbar. -->
                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{StaticResource ColReorderWidth}" />
                        <ColumnDefinition Width="*" MinWidth="200" />
                        <ColumnDefinition Width="{StaticResource ColAltMinWidth}" />
                        <ColumnDefinition Width="{StaticResource ColAltMaxWidth}" />
                        <ColumnDefinition Width="{StaticResource ColStatusWidth}" />
                        <ColumnDefinition Width="{StaticResource ColActionsWidth}" />
                        <ColumnDefinition Width="8" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="1"
                               Style="{StaticResource LabelStyle}"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"
                               Text="TIPO DO PONTO DE UTILIZAÇÃO" />
                    <TextBlock Grid.Column="2"
                               Style="{StaticResource LabelStyle}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Text="ALT. MÍN." />
                    <TextBlock Grid.Column="3"
                               Style="{StaticResource LabelStyle}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Text="ALT. MÁX." />
                    <TextBlock Grid.Column="4"
                               Style="{StaticResource LabelStyle}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Text="STATUS" />
                    <TextBlock Grid.Column="5"
                               Style="{StaticResource LabelStyle}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Text="AÇÕES" />
                </Grid>

                <ScrollViewer Grid.Row="1"
                              Style="{StaticResource SlimScrollViewerStyle}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding HasActiveGroup, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl ItemsSource="{Binding ActiveRules}" AlternationCount="999">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vmup:UtilizationPointRuleViewModel}">
                                <!-- Borda vira amarela suave quando a regra
                                     compartilha faixa com outra do mesmo
                                     grupo — em caso de empate, a primeira
                                     na ordem ganha. -->
                                <Border Margin="0,0,0,6"
                                        CornerRadius="10"
                                        Padding="4,6"
                                        AllowDrop="True"
                                        DragOver="OnRuleRowDragOver"
                                        Drop="OnRuleRowDrop"
                                        Focusable="True"
                                        IsTabStop="False"
                                        FocusVisualStyle="{x:Null}"
                                        KeyDown="OnRuleRowKeyDown"
                                        Background="{StaticResource RuleCardBackgroundBrush}"
                                        BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="{StaticResource RuleCardBorderBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasOverlap}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource WarningBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="{StaticResource ColReorderWidth}" />
                                            <ColumnDefinition Width="*" MinWidth="200" />
                                            <ColumnDefinition Width="{StaticResource ColAltMinWidth}" />
                                            <ColumnDefinition Width="{StaticResource ColAltMaxWidth}" />
                                            <ColumnDefinition Width="{StaticResource ColStatusWidth}" />
                                            <ColumnDefinition Width="{StaticResource ColActionsWidth}" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Drag handle: número da linha em cima, 6 pontinhos
                                             embaixo. AlternationIndex vem do ContentPresenter
                                             gerado pelo ItemsControl com AlternationCount="999"
                                             — é 0-baseado, daí o OneBasedIndex. -->
                                        <Border Grid.Column="0"
                                                Width="26" Height="40"
                                                Background="Transparent"
                                                Cursor="SizeAll"
                                                PreviewMouseLeftButtonDown="OnRuleDragHandleMouseDown"
                                                ToolTip="Arraste para reordenar (a ordem define preferência em caso de empate de faixa).">
                                            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Path=(ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType={x:Type ContentPresenter}}, Converter={StaticResource OneBasedIndex}}"
                                                           FontSize="9"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock Text="⋮⋮"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           FontSize="13"
                                                           Margin="0,-1,0,0"
                                                           HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Border>

                                        <ComboBox Grid.Column="1"
                                                  Style="{StaticResource RuleTypeComboBoxStyle}"
                                                  Margin="4,0,8,0"
                                                  IsTextSearchEnabled="True"
                                                  TextSearch.TextPath="DisplayName"
                                                  ItemsSource="{Binding DataContext.FamilyTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding SelectedFamilyType, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vmup:FamilyTypeOptionViewModel}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Grid Width="26" Height="26" Margin="0,0,8,0" VerticalAlignment="Center">
                                                            <Border Background="#E0F2FE"
                                                                    CornerRadius="4"
                                                                    Visibility="{Binding HasNoThumbnail, Converter={StaticResource BoolToVisibility}}">
                                                                <TextBlock Text="F"
                                                                           FontWeight="Bold"
                                                                           Foreground="{StaticResource PrimaryDarkBrush}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="11" />
                                                            </Border>
                                                            <Image Source="{Binding Thumbnail}"
                                                                   Width="26" Height="26"
                                                                   Stretch="Uniform"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                                   Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVisibility}}" />
                                                        </Grid>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding FamilyName}"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding TypeName}"
                                                                           FontSize="11"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Text=" · "
                                                                           FontSize="11"
                                                                           Foreground="{StaticResource MutedBrush}" />
                                                                <TextBlock Text="{Binding CategoryName}"
                                                                           FontSize="11"
                                                                           Foreground="{StaticResource MutedBrush}"
                                                                           TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>

                                        <!-- Min/Max com sufixo "m" colado no número, deixando claro
                                             que o valor está em metros (unidade interna do tool).
                                             A unidade é fixa em metros independentemente da unidade
                                             do projeto Revit: a conversão acontece no insertion
                                             service via RevitUnitConverter.FeetToMeters. -->
                                        <Grid Grid.Column="2" Margin="2,0,2,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Style="{StaticResource HeightTextBoxStyle}"
                                                     Text="{Binding MinMetersText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" />
                                            <TextBlock Grid.Column="1"
                                                       Text="m"
                                                       FontSize="11"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="3,0,4,0" />
                                        </Grid>

                                        <Grid Grid.Column="3" Margin="2,0,2,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Style="{StaticResource HeightTextBoxStyle}"
                                                     Text="{Binding MaxMetersText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" />
                                            <TextBlock Grid.Column="1"
                                                       Text="m"
                                                       FontSize="11"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="3,0,4,0" />
                                        </Grid>

                                        <!-- Status: badge circular com ícone vetorial. Os Paths
                                             usam o eixo 12×12 do Geometry; StrokeThickness 1.8
                                             dá um traço crisp em DPI normal e Retina. -->
                                        <Border Grid.Column="4"
                                                Style="{StaticResource StatusBadgeStyle}"
                                                ToolTip="{Binding StatusLabel}">
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeStyle}">
                                                    <Setter Property="Background" Value="{StaticResource ChipOkBackgroundBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsOk}" Value="False">
                                                            <Setter Property="Background" Value="{StaticResource ChipWarningBackgroundBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Path Data="{StaticResource CheckIconGeometry}"
                                                      Stroke="{StaticResource ChipOkForegroundBrush}"
                                                      StrokeThickness="1.8"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"
                                                      Visibility="{Binding IsOk, Converter={StaticResource BoolToVisibility}}" />
                                                <Path Data="{StaticResource WarningIconGeometry}"
                                                      Stroke="{StaticResource ChipWarningForegroundBrush}"
                                                      StrokeThickness="1.6"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"
                                                      Visibility="{Binding IsWarning, Converter={StaticResource BoolToVisibility}}" />
                                            </Grid>
                                        </Border>

                                        <StackPanel Grid.Column="5"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <Button Style="{StaticResource IconActionButtonStyle}"
                                                    Click="OnDuplicateRuleClicked"
                                                    Tag="{Binding}"
                                                    ToolTip="Duplicar"
                                                    Content="❐" />
                                            <Button Style="{StaticResource IconActionButtonStyle}"
                                                    Click="OnDeleteRuleClicked"
                                                    Tag="{Binding}"
                                                    ToolTip="Excluir"
                                                    Content="🗑" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </ScrollViewer>

                <TextBlock Grid.Row="1"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="{StaticResource MutedBrush}"
                           Text="Crie um grupo no painel à esquerda para começar."
                           Visibility="{Binding HasActiveGroup, Converter={StaticResource InverseBoolToVisibility}}" />
            </Grid>
        </Grid>

        <!-- Footer: last execution + primary action -->
        <Border Grid.Row="2" Grid.ColumnSpan="2"
                Background="#FFFFFF"
                BorderBrush="{StaticResource SoftBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="16,8,16,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontWeight="SemiBold"
                                   Text="{Binding LastSummaryHeader}" />
                    </StackPanel>

                    <WrapPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                               Visibility="{Binding HasLastSummary, Converter={StaticResource BoolToVisibility}}">
                        <Border Background="#EFF6FF" CornerRadius="10" Padding="7,2" Margin="3,0,0,2">
                            <TextBlock Style="{StaticResource ChipTextStyle}"
                                       Foreground="{StaticResource PrimaryDarkBrush}"
                                       Text="{Binding LastSummaryAnalyzedLabel}" />
                        </Border>
                        <Border Background="#ECFEFF" CornerRadius="10" Padding="7,2" Margin="3,0,0,2">
                            <TextBlock Style="{StaticResource ChipTextStyle}"
                                       Foreground="#0E7490"
                                       Text="{Binding LastSummaryFreeLabel}" />
                        </Border>
                        <Border Background="{StaticResource ChipOkBackgroundBrush}" CornerRadius="10" Padding="7,2" Margin="3,0,0,2">
                            <TextBlock Style="{StaticResource ChipTextStyle}"
                                       Foreground="{StaticResource ChipOkForegroundBrush}"
                                       Text="{Binding LastSummaryInsertedLabel}" />
                        </Border>
                        <Border Background="{StaticResource ChipWarningBackgroundBrush}" CornerRadius="10" Padding="7,2" Margin="3,0,0,2">
                            <TextBlock Style="{StaticResource ChipTextStyle}"
                                       Foreground="{StaticResource ChipWarningForegroundBrush}"
                                       Text="{Binding LastSummaryWithoutRangeLabel}" />
                        </Border>
                        <Border Background="#FEE2E2" CornerRadius="10" Padding="7,2" Margin="3,0,0,2">
                            <TextBlock Style="{StaticResource ChipTextStyle}"
                                       Foreground="#B91C1C"
                                       Text="{Binding LastSummaryErrorsLabel}" />
                        </Border>
                    </WrapPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,14,0">
                            <TextBlock Style="{StaticResource LabelStyle}" Text="GRUPO ATIVO" />
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="{Binding ActiveGroupName}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="160" />
                        </StackPanel>
                        <StackPanel Margin="0,0,14,0">
                            <TextBlock Style="{StaticResource LabelStyle}" Text="REGRAS VÁLIDAS" />
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="✓"
                                           Foreground="{StaticResource SuccessBrush}"
                                           FontWeight="Bold"
                                           FontSize="12" />
                                <TextBlock Margin="6,0,0,0"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="{Binding ActiveGroupValidRulesLabel}" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Margin="0,0,14,0">
                            <TextBlock Style="{StaticResource LabelStyle}" Text="TIPOS AUSENTES" />
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="⚠"
                                           Foreground="{StaticResource WarningBrush}"
                                           FontWeight="Bold"
                                           FontSize="12" />
                                <TextBlock Margin="6,0,0,0"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="{Binding ActiveGroupMissingTypesLabel}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="14,0"
                            MinWidth="0"
                            IsEnabled="{Binding IsIdle}"
                            Click="OnPickAndInsertClicked"
                            Content="▶  Ativar inserção" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
