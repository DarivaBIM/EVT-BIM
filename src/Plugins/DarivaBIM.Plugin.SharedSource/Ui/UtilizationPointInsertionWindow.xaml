<Window x:Class="DarivaBIM.Plugin.Ui.UtilizationPointInsertionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:common="clr-namespace:DarivaBIM.Presentation.Wpf.Common;assembly=DarivaBIM.Presentation.Wpf"
        xmlns:vmup="clr-namespace:DarivaBIM.Presentation.Wpf.UtilizationPoints;assembly=DarivaBIM.Presentation.Wpf"
        Title="Inserção de Pontos de Utilização"
        Width="1280"
        Height="760"
        MinWidth="980"
        MinHeight="620"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7FB"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="OnWindowLoaded"
        Closing="OnWindowClosing">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <common:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />

        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SoftBorderBrush" Color="#D8E0EA" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F172A" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#475569" />
        <SolidColorBrush x:Key="LabelBrush" Color="#64748B" />
        <SolidColorBrush x:Key="MutedBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#0EA5E9" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#0284C7" />
        <SolidColorBrush x:Key="AccentBrush" Color="#06B6D4" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#10B981" />
        <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B" />
        <SolidColorBrush x:Key="DangerBrush" Color="#EF4444" />
        <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="SidebarItemBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SidebarItemSelectedBrush" Color="#E0F2FE" />
        <SolidColorBrush x:Key="SidebarItemSelectedBorderBrush" Color="#0EA5E9" />
        <SolidColorBrush x:Key="RuleCardBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="RuleCardBorderBrush" Color="#E2E8F0" />
        <SolidColorBrush x:Key="RuleCardWarningBorderBrush" Color="#FBBF24" />
        <SolidColorBrush x:Key="ChipNeutralBackgroundBrush" Color="#F1F5F9" />
        <SolidColorBrush x:Key="ChipOkBackgroundBrush" Color="#DCFCE7" />
        <SolidColorBrush x:Key="ChipOkForegroundBrush" Color="#15803D" />
        <SolidColorBrush x:Key="ChipWarningBackgroundBrush" Color="#FEF3C7" />
        <SolidColorBrush x:Key="ChipWarningForegroundBrush" Color="#B45309" />

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="SubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource LabelBrush}" />
        </Style>

        <Style x:Key="SidebarHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource LabelBrush}" />
        </Style>

        <Style x:Key="ChipTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="{StaticResource RuleCardBorderBrush}" />
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="140" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="12,0" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#1E293B" />
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource RuleCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="IconActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="#FFFFFF"
                BorderBrush="{StaticResource SoftBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                               Text="Inserção de Pontos de Utilização" />
                    <TextBlock Style="{StaticResource SubtitleStyle}"
                               Margin="0,2,0,0"
                               Text="Configure grupos por ambiente e insira peças automaticamente em conectores hidráulicos livres." />
                </StackPanel>
                <Border Grid.Column="1"
                        Background="#F1F5F9"
                        CornerRadius="14"
                        Padding="12,6"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                        <TextBlock Margin="8,0,0,0"
                                   FontSize="11.5"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="{Binding StatusMessage}"
                                   MaxWidth="520"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Sidebar: groups -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{StaticResource SidebarBackgroundBrush}"
                BorderBrush="{StaticResource SoftBorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="16,16,16,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Style="{StaticResource SidebarHeaderStyle}"
                               Text="GRUPOS DE CONFIGURAÇÃO" />
                    <Border Grid.Column="1"
                            Background="#E2E8F0"
                            CornerRadius="9"
                            Padding="6,1">
                        <TextBlock FontSize="10.5"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="{Binding GroupsCount}" />
                    </Border>
                </Grid>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="8,0,8,8">
                    <ItemsControl ItemsSource="{Binding Groups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vmup:UtilizationPointGroupViewModel}">
                                <Border Margin="4,4,4,4"
                                        CornerRadius="10"
                                        Padding="10,8"
                                        BorderThickness="1"
                                        x:Name="GroupItemBorder"
                                        Background="{StaticResource SidebarItemBackgroundBrush}"
                                        BorderBrush="{StaticResource RuleCardBorderBrush}"
                                        MouseLeftButtonUp="OnGroupItemClicked">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Width="30" Height="30"
                                                CornerRadius="8"
                                                Background="#E0F2FE"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding InitialLetter}"
                                                       FontWeight="Bold"
                                                       FontSize="12"
                                                       Foreground="{StaticResource PrimaryDarkBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1"
                                                    Margin="10,0,0,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12.5"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="{Binding RulesCountLabel}"
                                                           FontSize="10.5"
                                                           Foreground="{StaticResource MutedBrush}" />
                                                <TextBlock Text=" · "
                                                           FontSize="10.5"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           Visibility="{Binding HasMissingTypes, Converter={StaticResource BoolToVisibility}}" />
                                                <TextBlock Text="{Binding MissingTypesLabel}"
                                                           FontSize="10.5"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource WarningBrush}"
                                                           Visibility="{Binding HasMissingTypes, Converter={StaticResource BoolToVisibility}}" />
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Button Style="{StaticResource IconActionButtonStyle}"
                                                    Click="OnRenameGroupClicked"
                                                    Tag="{Binding Id}"
                                                    ToolTip="Renomear"
                                                    Content="✎" />
                                            <Button Style="{StaticResource IconActionButtonStyle}"
                                                    Click="OnDuplicateGroupClicked"
                                                    Tag="{Binding Id}"
                                                    ToolTip="Duplicar"
                                                    Content="❐" />
                                            <Button Style="{StaticResource IconActionButtonStyle}"
                                                    Click="OnDeleteGroupClicked"
                                                    Tag="{Binding Id}"
                                                    ToolTip="Excluir"
                                                    Content="🗑" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Button Grid.Row="2"
                        Style="{StaticResource GhostButtonStyle}"
                        Margin="16,8,16,12"
                        Click="OnNewGroupClicked"
                        Content="+ Novo grupo" />

                <Border Grid.Row="3"
                        Margin="16,0,16,16"
                        Padding="12"
                        CornerRadius="10"
                        Background="#FFFFFF"
                        BorderBrush="{StaticResource RuleCardBorderBrush}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="💡 Dica"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Margin="0,4,0,0"
                                   FontSize="11"
                                   Foreground="{StaticResource MutedBrush}"
                                   TextWrapping="Wrap"
                                   Text="Grupos são presets reutilizáveis. Exporte para compartilhar com a equipe." />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main content: rules editor -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Active group header + presets buttons -->
            <Grid Grid.Row="0" Margin="24,20,24,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                               Text="{Binding ActiveGroupName}" />
                    <Border Margin="10,0,0,0"
                            Background="{StaticResource ChipOkBackgroundBrush}"
                            CornerRadius="10"
                            Padding="9,3"
                            Visibility="{Binding HasActiveGroup, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="ATIVO"
                                   FontSize="10.5"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ChipOkForegroundBrush}" />
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource GhostButtonStyle}"
                            MinWidth="0"
                            Padding="14,0"
                            Click="OnImportPresetClicked"
                            Content="📥  Importar preset"
                            Margin="0,0,8,0" />
                    <Button Style="{StaticResource GhostButtonStyle}"
                            MinWidth="0"
                            Padding="14,0"
                            Click="OnExportPresetClicked"
                            Content="📤  Exportar preset"
                            Margin="0,0,8,0" />
                    <Button Style="{StaticResource PrimaryButtonStyle}"
                            MinWidth="0"
                            Padding="14,0"
                            Click="OnAddRuleClicked"
                            Content="+ Adicionar ponto" />
                </StackPanel>
            </Grid>

            <TextBlock Grid.Row="1"
                       Margin="24,0,24,12"
                       Style="{StaticResource SubtitleStyle}"
                       Text="Regras de inserção por faixa de altura. A peça é escolhida pela cota do conector livre em relação ao nível." />

            <!-- Level dropdown + summary chips -->
            <Border Grid.Row="2"
                    Margin="24,0,24,12"
                    Background="#F8FAFC"
                    CornerRadius="10"
                    BorderBrush="{StaticResource RuleCardBorderBrush}"
                    BorderThickness="1"
                    Padding="14,10">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Style="{StaticResource LabelStyle}"
                                   Text="NÍVEL DE REFERÊNCIA"
                                   VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1"
                                  Margin="14,0,14,0"
                                  Width="280"
                                  HorizontalAlignment="Left"
                                  ItemsSource="{Binding Levels}"
                                  SelectedItem="{Binding SelectedLevel, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type vmup:LevelOptionViewModel}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding DisplayName}" />
                                        <TextBlock Text="  "
                                                   Foreground="{StaticResource MutedBrush}" />
                                        <TextBlock Text="{Binding ElevationLabel}"
                                                   Foreground="{StaticResource MutedBrush}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Grid.Column="2"
                                   FontSize="11.5"
                                   Foreground="{StaticResource MutedBrush}"
                                   VerticalAlignment="Center"
                                   Text="Tolerância vertical: ±0.02 m" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Border Background="#FFFFFF"
                                CornerRadius="8"
                                Padding="12,6"
                                Margin="0,0,8,0"
                                BorderBrush="{StaticResource RuleCardBorderBrush}"
                                BorderThickness="1">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource PrimaryBrush}" />
                                <TextBlock Margin="8,0,0,0"
                                           FontWeight="Bold"
                                           FontSize="13"
                                           Text="{Binding ActiveGroup.RulesCount, FallbackValue=0}" />
                                <TextBlock Margin="6,0,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="11"
                                           Text="pontos configurados" />
                            </StackPanel>
                        </Border>
                        <Border Background="#FFFFFF"
                                CornerRadius="8"
                                Padding="12,6"
                                Margin="0,0,8,0"
                                BorderBrush="{StaticResource RuleCardBorderBrush}"
                                BorderThickness="1">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" />
                                <TextBlock Margin="8,0,0,0"
                                           FontWeight="Bold"
                                           FontSize="13"
                                           Text="{Binding ActiveGroupTypesFoundLabel}" />
                                <TextBlock Margin="6,0,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="11"
                                           Text="tipos encontrados" />
                            </StackPanel>
                        </Border>
                        <Border Background="#FFFFFF"
                                CornerRadius="8"
                                Padding="12,6"
                                BorderBrush="{StaticResource RuleCardBorderBrush}"
                                BorderThickness="1">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource WarningBrush}" />
                                <TextBlock Margin="8,0,0,0"
                                           FontWeight="Bold"
                                           FontSize="13"
                                           Text="{Binding ActiveGroupMissingTypesLabel}" />
                                <TextBlock Margin="6,0,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="11"
                                           Text="tipo não encontrado" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Rules list -->
            <Border Grid.Row="3"
                    Margin="24,0,24,12"
                    Background="Transparent">
                <Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Visibility="{Binding HasActiveGroup, Converter={StaticResource BoolToVisibility}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Column header -->
                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="2" Style="{StaticResource LabelStyle}" Text="NOME DO PONTO" />
                                <TextBlock Grid.Column="3" Style="{StaticResource LabelStyle}" Text="TIPO DE FAMÍLIA" />
                                <TextBlock Grid.Column="4" Style="{StaticResource LabelStyle}" Text="ALTURA MÍN." />
                                <TextBlock Grid.Column="5" Style="{StaticResource LabelStyle}" Text="ALTURA MÁX." />
                                <TextBlock Grid.Column="6" Style="{StaticResource LabelStyle}" Text="STATUS" />
                                <TextBlock Grid.Column="7" Style="{StaticResource LabelStyle}" Text="AÇÕES" />
                            </Grid>

                            <ItemsControl Grid.Row="1" ItemsSource="{Binding ActiveRules}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vmup:UtilizationPointRuleViewModel}">
                                        <Border Margin="0,0,0,8"
                                                CornerRadius="10"
                                                Padding="10,10"
                                                Background="{StaticResource RuleCardBackgroundBrush}"
                                                BorderThickness="1"
                                                BorderBrush="{StaticResource RuleCardBorderBrush}">
                                            <Grid VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40" />
                                                    <ColumnDefinition Width="40" />
                                                    <ColumnDefinition Width="220" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="140" />
                                                    <ColumnDefinition Width="80" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="⋮⋮"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           FontSize="14"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center" />

                                                <Border Grid.Column="1"
                                                        Width="22" Height="22"
                                                        Background="#F1F5F9"
                                                        CornerRadius="11"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center">
                                                    <TextBlock Text="•"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               FontWeight="Bold"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </Border>

                                                <TextBox Grid.Column="2"
                                                         Margin="0,0,12,0"
                                                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />

                                                <ComboBox Grid.Column="3"
                                                          Margin="0,0,12,0"
                                                          IsTextSearchEnabled="True"
                                                          TextSearch.TextPath="DisplayName"
                                                          ItemsSource="{Binding DataContext.FamilyTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          SelectedItem="{Binding SelectedFamilyType, Mode=TwoWay}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vmup:FamilyTypeOptionViewModel}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Border Width="22" Height="22"
                                                                        CornerRadius="6"
                                                                        Background="#E0F2FE"
                                                                        Margin="0,0,8,0">
                                                                    <TextBlock Text="F"
                                                                               FontWeight="Bold"
                                                                               Foreground="{StaticResource PrimaryDarkBrush}"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"
                                                                               FontSize="10" />
                                                                </Border>
                                                                <StackPanel VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding FamilyName}"
                                                                               FontSize="12"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding TypeName}"
                                                                                   FontSize="11"
                                                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                                                        <TextBlock Text=" · "
                                                                                   FontSize="11"
                                                                                   Foreground="{StaticResource MutedBrush}" />
                                                                        <TextBlock Text="{Binding CategoryName}"
                                                                                   FontSize="11"
                                                                                   Foreground="{StaticResource MutedBrush}" />
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>

                                                <TextBox Grid.Column="4"
                                                         Margin="0,0,6,0"
                                                         HorizontalContentAlignment="Center"
                                                         Text="{Binding MinMetersText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" />

                                                <TextBox Grid.Column="5"
                                                         Margin="0,0,6,0"
                                                         HorizontalContentAlignment="Center"
                                                         Text="{Binding MaxMetersText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" />

                                                <Border Grid.Column="6"
                                                        Margin="0,0,8,0"
                                                        CornerRadius="10"
                                                        Padding="10,4"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{StaticResource ChipOkBackgroundBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsOk}" Value="False">
                                                                    <Setter Property="Background" Value="{StaticResource ChipWarningBackgroundBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock VerticalAlignment="Center" FontSize="11">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="✓" />
                                                                    <Setter Property="Foreground" Value="{StaticResource ChipOkForegroundBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsOk}" Value="False">
                                                                            <Setter Property="Text" Value="⚠" />
                                                                            <Setter Property="Foreground" Value="{StaticResource ChipWarningForegroundBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Margin="6,0,0,0"
                                                                   Text="{Binding StatusLabel}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource ChipTextStyle}">
                                                                    <Setter Property="Foreground" Value="{StaticResource ChipOkForegroundBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsOk}" Value="False">
                                                                            <Setter Property="Foreground" Value="{StaticResource ChipWarningForegroundBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>

                                                <StackPanel Grid.Column="7" Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Button Style="{StaticResource IconActionButtonStyle}"
                                                            Click="OnDuplicateRuleClicked"
                                                            Tag="{Binding}"
                                                            ToolTip="Duplicar"
                                                            Content="❐" />
                                                    <Button Style="{StaticResource IconActionButtonStyle}"
                                                            Click="OnDeleteRuleClicked"
                                                            Tag="{Binding}"
                                                            ToolTip="Excluir"
                                                            Content="🗑" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </Grid>
                    </ScrollViewer>

                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Foreground="{StaticResource MutedBrush}"
                               Text="Crie um grupo no painel à esquerda para começar."
                               Visibility="{Binding HasActiveGroup, Converter={StaticResource InverseBoolToVisibility}}" />
                </Grid>
            </Border>
        </Grid>

        <!-- Footer: last execution + action buttons -->
        <Border Grid.Row="2" Grid.ColumnSpan="2"
                Background="#FFFFFF"
                BorderBrush="{StaticResource SoftBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="20,12,20,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontSize="11.5"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontWeight="SemiBold"
                                   Text="{Binding LastSummaryHeader}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                                Visibility="{Binding HasLastSummary, Converter={StaticResource BoolToVisibility}}">
                        <Border Background="#EFF6FF" CornerRadius="10" Padding="8,3" Margin="4,0,0,0">
                            <TextBlock Style="{StaticResource ChipTextStyle}"
                                       Foreground="{StaticResource PrimaryDarkBrush}"
                                       Text="{Binding LastSummaryAnalyzedLabel}" />
                        </Border>
                        <Border Background="#ECFEFF" CornerRadius="10" Padding="8,3" Margin="4,0,0,0">
                            <TextBlock Style="{StaticResource ChipTextStyle}"
                                       Foreground="#0E7490"
                                       Text="{Binding LastSummaryFreeLabel}" />
                        </Border>
                        <Border Background="{StaticResource ChipOkBackgroundBrush}" CornerRadius="10" Padding="8,3" Margin="4,0,0,0">
                            <TextBlock Style="{StaticResource ChipTextStyle}"
                                       Foreground="{StaticResource ChipOkForegroundBrush}"
                                       Text="{Binding LastSummaryInsertedLabel}" />
                        </Border>
                        <Border Background="{StaticResource ChipWarningBackgroundBrush}" CornerRadius="10" Padding="8,3" Margin="4,0,0,0">
                            <TextBlock Style="{StaticResource ChipTextStyle}"
                                       Foreground="{StaticResource ChipWarningForegroundBrush}"
                                       Text="{Binding LastSummaryWithoutRangeLabel}" />
                        </Border>
                        <Border Background="#FEE2E2" CornerRadius="10" Padding="8,3" Margin="4,0,0,0">
                            <TextBlock Style="{StaticResource ChipTextStyle}"
                                       Foreground="#B91C1C"
                                       Text="{Binding LastSummaryErrorsLabel}" />
                        </Border>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,18,0">
                            <TextBlock Style="{StaticResource LabelStyle}" Text="GRUPO ATIVO" />
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="12.5"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="{Binding ActiveGroupName}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,18,0">
                            <TextBlock Style="{StaticResource LabelStyle}" Text="REGRAS VÁLIDAS" />
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="✓"
                                           Foreground="{StaticResource SuccessBrush}"
                                           FontWeight="Bold"
                                           FontSize="12" />
                                <TextBlock Margin="6,0,0,0"
                                           FontSize="12.5"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="{Binding ActiveGroupValidRulesLabel}" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Margin="0,0,18,0">
                            <TextBlock Style="{StaticResource LabelStyle}" Text="TIPOS AUSENTES" />
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="⚠"
                                           Foreground="{StaticResource WarningBrush}"
                                           FontWeight="Bold"
                                           FontSize="12" />
                                <TextBlock Margin="6,0,0,0"
                                           FontSize="12.5"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="{Binding ActiveGroupMissingTypesLabel}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="ContinuousModeButton"
                                Style="{StaticResource GhostButtonStyle}"
                                MinWidth="0"
                                Padding="14,0"
                                Margin="0,0,8,0"
                                Click="OnToggleContinuousModeClicked"
                                Content="{Binding ContinuousModeLabel}" />
                        <Button Style="{StaticResource GhostButtonStyle}"
                                MinWidth="0"
                                Padding="14,0"
                                Margin="0,0,8,0"
                                IsEnabled="{Binding IsIdle}"
                                Click="OnUseSelectionClicked"
                                Content="▷  Usar seleção atual" />
                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                Padding="14,0"
                                IsEnabled="{Binding IsIdle}"
                                Click="OnPickAndInsertClicked"
                                Content="▶  Selecionar elementos e inserir" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
