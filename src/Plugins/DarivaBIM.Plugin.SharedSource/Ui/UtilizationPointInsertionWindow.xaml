<Window x:Class="DarivaBIM.Plugin.Ui.UtilizationPointInsertionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:common="clr-namespace:DarivaBIM.Presentation.Wpf.Common;assembly=DarivaBIM.Presentation.Wpf"
        xmlns:vmup="clr-namespace:DarivaBIM.Presentation.Wpf.UtilizationPoints;assembly=DarivaBIM.Presentation.Wpf"
        Title="Inserção de Pontos de Utilização"
        Width="1100"
        Height="640"
        MinWidth="900"
        MinHeight="560"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7FB"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="OnWindowLoaded"
        Closing="OnWindowClosing"
        PreviewMouseMove="OnWindowPreviewMouseMove"
        PreviewMouseLeftButtonUp="OnWindowPreviewMouseLeftButtonUp">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <common:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <common:DoubleToGridLengthConverter x:Key="DoubleToGridLength" />

        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SoftBorderBrush" Color="#D8E0EA" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F172A" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#475569" />
        <SolidColorBrush x:Key="LabelBrush" Color="#64748B" />
        <SolidColorBrush x:Key="MutedBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#0EA5E9" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#0284C7" />
        <SolidColorBrush x:Key="AccentBrush" Color="#06B6D4" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#10B981" />
        <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B" />
        <SolidColorBrush x:Key="DangerBrush" Color="#EF4444" />
        <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="SidebarItemBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SidebarItemSelectedBrush" Color="#E0F2FE" />
        <SolidColorBrush x:Key="SidebarItemSelectedBorderBrush" Color="#0EA5E9" />
        <SolidColorBrush x:Key="RuleCardBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="RuleCardBorderBrush" Color="#E2E8F0" />
        <SolidColorBrush x:Key="RuleCardWarningBorderBrush" Color="#FBBF24" />
        <SolidColorBrush x:Key="ChipNeutralBackgroundBrush" Color="#F1F5F9" />
        <SolidColorBrush x:Key="ChipOkBackgroundBrush" Color="#DCFCE7" />
        <SolidColorBrush x:Key="ChipOkForegroundBrush" Color="#15803D" />
        <SolidColorBrush x:Key="ChipWarningBackgroundBrush" Color="#FEF3C7" />
        <SolidColorBrush x:Key="ChipWarningForegroundBrush" Color="#B45309" />
        <SolidColorBrush x:Key="HintBannerBackgroundBrush" Color="#FFF3CD" />
        <SolidColorBrush x:Key="HintBannerBorderBrush" Color="#F0B429" />
        <SolidColorBrush x:Key="HintBannerForegroundBrush" Color="#8A4B00" />

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="SubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource LabelBrush}" />
        </Style>

        <Style x:Key="SidebarHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource LabelBrush}" />
        </Style>

        <Style x:Key="ChipTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="{StaticResource RuleCardBorderBrush}" />
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="12,0" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#1E293B" />
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource RuleCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="IconActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <!-- Thumb fininho para arrastar e redimensionar colunas. -->
        <Style x:Key="ColumnResizerThumbStyle" TargetType="Thumb">
            <Setter Property="Width" Value="6" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="SizeWE" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="Transparent">
                            <Rectangle Width="1"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Stretch"
                                       Fill="{StaticResource RuleCardBorderBrush}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="#FFFFFF"
                BorderBrush="{StaticResource SoftBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                               Text="Inserção de Pontos de Utilização" />
                    <TextBlock Style="{StaticResource SubtitleStyle}"
                               Margin="0,2,0,0"
                               Text="Configure grupos por ambiente e insira peças automaticamente em conectores hidráulicos livres." />
                </StackPanel>
                <Border Grid.Column="1"
                        Background="#F1F5F9"
                        CornerRadius="14"
                        Padding="12,6"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                        <TextBlock Margin="8,0,0,0"
                                   FontSize="11.5"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="{Binding StatusMessage}"
                                   MaxWidth="460"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Sidebar: groups + preset I/O + tip -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{StaticResource SidebarBackgroundBrush}"
                BorderBrush="{StaticResource SoftBorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="14,14,14,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Style="{StaticResource SidebarHeaderStyle}"
                               Text="GRUPOS DE CONFIGURAÇÃO" />
                    <Border Grid.Column="1"
                            Background="#E2E8F0"
                            CornerRadius="9"
                            Padding="6,1">
                        <TextBlock FontSize="10.5"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="{Binding GroupsCount}" />
                    </Border>
                </Grid>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="6,0,6,6">
                    <ItemsControl ItemsSource="{Binding Groups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vmup:UtilizationPointGroupViewModel}">
                                <Border Margin="4,4,4,4"
                                        CornerRadius="10"
                                        Padding="10,8"
                                        BorderThickness="1"
                                        x:Name="GroupItemBorder"
                                        Background="{StaticResource SidebarItemBackgroundBrush}"
                                        BorderBrush="{StaticResource RuleCardBorderBrush}"
                                        MouseLeftButtonUp="OnGroupItemClicked">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Width="28" Height="28"
                                                CornerRadius="8"
                                                Background="#E0F2FE"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding InitialLetter}"
                                                       FontWeight="Bold"
                                                       FontSize="12"
                                                       Foreground="{StaticResource PrimaryDarkBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1"
                                                    Margin="10,0,0,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12.5"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="{Binding RulesCountLabel}"
                                                           FontSize="10.5"
                                                           Foreground="{StaticResource MutedBrush}" />
                                                <TextBlock Text=" · "
                                                           FontSize="10.5"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           Visibility="{Binding HasMissingTypes, Converter={StaticResource BoolToVisibility}}" />
                                                <TextBlock Text="{Binding MissingTypesLabel}"
                                                           FontSize="10.5"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource WarningBrush}"
                                                           Visibility="{Binding HasMissingTypes, Converter={StaticResource BoolToVisibility}}" />
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Button Style="{StaticResource IconActionButtonStyle}"
                                                    Click="OnRenameGroupClicked"
                                                    Tag="{Binding Id}"
                                                    ToolTip="Renomear"
                                                    Content="✎" />
                                            <Button Style="{StaticResource IconActionButtonStyle}"
                                                    Click="OnDuplicateGroupClicked"
                                                    Tag="{Binding Id}"
                                                    ToolTip="Duplicar"
                                                    Content="❐" />
                                            <Button Style="{StaticResource IconActionButtonStyle}"
                                                    Click="OnDeleteGroupClicked"
                                                    Tag="{Binding Id}"
                                                    ToolTip="Excluir"
                                                    Content="🗑" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Button Grid.Row="2"
                        Style="{StaticResource GhostButtonStyle}"
                        Margin="14,6,14,8"
                        Click="OnNewGroupClicked"
                        Content="+ Novo grupo" />

                <Border Grid.Row="3"
                        Margin="14,0,14,8"
                        Padding="12"
                        CornerRadius="10"
                        Background="#FFFFFF"
                        BorderBrush="{StaticResource RuleCardBorderBrush}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="💡 Dica"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Margin="0,4,0,0"
                                   FontSize="11"
                                   Foreground="{StaticResource MutedBrush}"
                                   TextWrapping="Wrap"
                                   Text="Presets agrupam vários grupos e podem ser compartilhados com a equipe." />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Stretch"
                            Margin="14,0,14,14">
                    <Button Style="{StaticResource GhostButtonStyle}"
                            MinWidth="0"
                            Height="30"
                            Padding="10,0"
                            HorizontalAlignment="Stretch"
                            Width="111"
                            Click="OnImportPresetClicked"
                            ToolTip="Importa todos os grupos de um arquivo JSON."
                            Content="📥 Importar"
                            Margin="0,0,4,0" />
                    <Button Style="{StaticResource GhostButtonStyle}"
                            MinWidth="0"
                            Height="30"
                            Padding="10,0"
                            HorizontalAlignment="Stretch"
                            Width="111"
                            Click="OnExportPresetClicked"
                            ToolTip="Exporta todos os grupos para um arquivo JSON."
                            Content="📤 Exportar"
                            Margin="0,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content: rules editor -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Active group header + add point -->
            <Grid Grid.Row="0" Margin="20,16,20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                               Text="{Binding ActiveGroupName}" />
                    <Border Margin="10,0,0,0"
                            Background="{StaticResource ChipOkBackgroundBrush}"
                            CornerRadius="10"
                            Padding="9,3"
                            Visibility="{Binding HasActiveGroup, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="ATIVO"
                                   FontSize="10.5"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ChipOkForegroundBrush}" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1"
                        Style="{StaticResource PrimaryButtonStyle}"
                        MinWidth="0"
                        Padding="14,0"
                        Click="OnAddRuleClicked"
                        Content="+ Adicionar ponto" />
            </Grid>

            <TextBlock Grid.Row="1"
                       Margin="20,0,20,10"
                       Style="{StaticResource SubtitleStyle}"
                       Text="Regras de inserção por faixa de altura. A peça é escolhida pela cota do conector livre em relação ao nível. A ordem das regras define a preferência em caso de empate de faixa." />

            <!-- Awaiting selection hint -->
            <Border Grid.Row="2"
                    Margin="20,0,20,10"
                    Padding="14,10"
                    CornerRadius="8"
                    Background="{StaticResource HintBannerBackgroundBrush}"
                    BorderBrush="{StaticResource HintBannerBorderBrush}"
                    BorderThickness="1"
                    Visibility="{Binding IsAwaitingSelection, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚠"
                               FontSize="14"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource HintBannerForegroundBrush}" />
                    <TextBlock Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="11.5"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource HintBannerForegroundBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding AwaitingSelectionHint}" />
                </StackPanel>
            </Border>

            <!-- Level dropdown + summary chips -->
            <Border Grid.Row="3"
                    Margin="20,0,20,10"
                    Background="#F8FAFC"
                    CornerRadius="10"
                    BorderBrush="{StaticResource RuleCardBorderBrush}"
                    BorderThickness="1"
                    Padding="12,8">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Style="{StaticResource LabelStyle}"
                                   Text="NÍVEL DE REFERÊNCIA"
                                   VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1"
                                  Margin="12,0,12,0"
                                  Width="260"
                                  HorizontalAlignment="Left"
                                  ItemsSource="{Binding Levels}"
                                  SelectedItem="{Binding SelectedLevel, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type vmup:LevelOptionViewModel}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding DisplayName}" />
                                        <TextBlock Text="  "
                                                   Foreground="{StaticResource MutedBrush}" />
                                        <TextBlock Text="{Binding ElevationLabel}"
                                                   Foreground="{StaticResource MutedBrush}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Grid.Column="2"
                                   FontSize="11"
                                   Foreground="{StaticResource MutedBrush}"
                                   VerticalAlignment="Center"
                                   Text="Tolerância vertical: ±0.02 m" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Border Background="#FFFFFF"
                                CornerRadius="8"
                                Padding="10,5"
                                Margin="0,0,6,0"
                                BorderBrush="{StaticResource RuleCardBorderBrush}"
                                BorderThickness="1">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource PrimaryBrush}" />
                                <TextBlock Margin="6,0,0,0"
                                           FontWeight="Bold"
                                           FontSize="12"
                                           Text="{Binding ActiveGroup.RulesCount, FallbackValue=0}" />
                                <TextBlock Margin="6,0,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="11"
                                           Text="pontos configurados" />
                            </StackPanel>
                        </Border>
                        <Border Background="#FFFFFF"
                                CornerRadius="8"
                                Padding="10,5"
                                Margin="0,0,6,0"
                                BorderBrush="{StaticResource RuleCardBorderBrush}"
                                BorderThickness="1">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" />
                                <TextBlock Margin="6,0,0,0"
                                           FontWeight="Bold"
                                           FontSize="12"
                                           Text="{Binding ActiveGroupTypesFoundLabel}" />
                                <TextBlock Margin="6,0,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="11"
                                           Text="tipos encontrados" />
                            </StackPanel>
                        </Border>
                        <Border Background="#FFFFFF"
                                CornerRadius="8"
                                Padding="10,5"
                                BorderBrush="{StaticResource RuleCardBorderBrush}"
                                BorderThickness="1">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource WarningBrush}" />
                                <TextBlock Margin="6,0,0,0"
                                           FontWeight="Bold"
                                           FontSize="12"
                                           Text="{Binding ActiveGroupMissingTypesLabel}" />
                                <TextBlock Margin="6,0,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="11"
                                           Text="tipo não encontrado" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Rules list -->
            <Border Grid.Row="4"
                    Margin="20,0,20,10"
                    Background="Transparent">
                <Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  Visibility="{Binding HasActiveGroup, Converter={StaticResource BoolToVisibility}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Column header (resizable via thumbs) -->
                            <Grid Grid.Row="0" Margin="0,0,0,6" Height="22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="{Binding ColumnsLayout.NameWidth, Converter={StaticResource DoubleToGridLength}}" />
                                    <ColumnDefinition Width="{Binding ColumnsLayout.TypeWidth, Converter={StaticResource DoubleToGridLength}}" />
                                    <ColumnDefinition Width="{Binding ColumnsLayout.MinHeightWidth, Converter={StaticResource DoubleToGridLength}}" />
                                    <ColumnDefinition Width="{Binding ColumnsLayout.MaxHeightWidth, Converter={StaticResource DoubleToGridLength}}" />
                                    <ColumnDefinition Width="{Binding ColumnsLayout.StatusWidth, Converter={StaticResource DoubleToGridLength}}" />
                                    <ColumnDefinition Width="64" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1"
                                           Style="{StaticResource LabelStyle}"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           Margin="2,0,0,0"
                                           Text="NOME DO PONTO" />
                                <TextBlock Grid.Column="2"
                                           Style="{StaticResource LabelStyle}"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           Margin="2,0,0,0"
                                           Text="TIPO DE FAMÍLIA" />
                                <TextBlock Grid.Column="3"
                                           Style="{StaticResource LabelStyle}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="ALT. MÍN." />
                                <TextBlock Grid.Column="4"
                                           Style="{StaticResource LabelStyle}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="ALT. MÁX." />
                                <TextBlock Grid.Column="5"
                                           Style="{StaticResource LabelStyle}"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           Margin="4,0,0,0"
                                           Text="STATUS" />
                                <TextBlock Grid.Column="6"
                                           Style="{StaticResource LabelStyle}"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Margin="0,0,2,0"
                                           Text="AÇÕES" />

                                <!-- Resizer thumbs sit at the right edge of each data column. -->
                                <Thumb Grid.Column="1"
                                       Style="{StaticResource ColumnResizerThumbStyle}"
                                       Tag="Name"
                                       HorizontalAlignment="Right"
                                       Margin="0,-4,-3,-4"
                                       DragDelta="OnColumnResizerDragDelta" />
                                <Thumb Grid.Column="2"
                                       Style="{StaticResource ColumnResizerThumbStyle}"
                                       Tag="Type"
                                       HorizontalAlignment="Right"
                                       Margin="0,-4,-3,-4"
                                       DragDelta="OnColumnResizerDragDelta" />
                                <Thumb Grid.Column="3"
                                       Style="{StaticResource ColumnResizerThumbStyle}"
                                       Tag="MinHeight"
                                       HorizontalAlignment="Right"
                                       Margin="0,-4,-3,-4"
                                       DragDelta="OnColumnResizerDragDelta" />
                                <Thumb Grid.Column="4"
                                       Style="{StaticResource ColumnResizerThumbStyle}"
                                       Tag="MaxHeight"
                                       HorizontalAlignment="Right"
                                       Margin="0,-4,-3,-4"
                                       DragDelta="OnColumnResizerDragDelta" />
                                <Thumb Grid.Column="5"
                                       Style="{StaticResource ColumnResizerThumbStyle}"
                                       Tag="Status"
                                       HorizontalAlignment="Right"
                                       Margin="0,-4,-3,-4"
                                       DragDelta="OnColumnResizerDragDelta" />
                            </Grid>

                            <ItemsControl Grid.Row="1" ItemsSource="{Binding ActiveRules}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vmup:UtilizationPointRuleViewModel}">
                                        <Border Margin="0,0,0,6"
                                                CornerRadius="10"
                                                Padding="6,8"
                                                AllowDrop="True"
                                                DragOver="OnRuleRowDragOver"
                                                Drop="OnRuleRowDrop"
                                                Background="{StaticResource RuleCardBackgroundBrush}"
                                                BorderThickness="1"
                                                BorderBrush="{StaticResource RuleCardBorderBrush}">
                                            <Grid VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="28" />
                                                    <ColumnDefinition Width="{Binding DataContext.ColumnsLayout.NameWidth, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource DoubleToGridLength}}" />
                                                    <ColumnDefinition Width="{Binding DataContext.ColumnsLayout.TypeWidth, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource DoubleToGridLength}}" />
                                                    <ColumnDefinition Width="{Binding DataContext.ColumnsLayout.MinHeightWidth, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource DoubleToGridLength}}" />
                                                    <ColumnDefinition Width="{Binding DataContext.ColumnsLayout.MaxHeightWidth, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource DoubleToGridLength}}" />
                                                    <ColumnDefinition Width="{Binding DataContext.ColumnsLayout.StatusWidth, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource DoubleToGridLength}}" />
                                                    <ColumnDefinition Width="64" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Drag handle: 6 dots, used to reorder rules -->
                                                <Border Grid.Column="0"
                                                        Width="24" Height="28"
                                                        Background="Transparent"
                                                        Cursor="SizeAll"
                                                        PreviewMouseLeftButtonDown="OnRuleDragHandleMouseDown"
                                                        ToolTip="Arraste para reordenar (a ordem define preferência em caso de empate de faixa).">
                                                    <TextBlock Text="⋮⋮"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               FontSize="14"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </Border>

                                                <TextBox Grid.Column="1"
                                                         Margin="2,0,8,0"
                                                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />

                                                <ComboBox Grid.Column="2"
                                                          Margin="0,0,8,0"
                                                          IsTextSearchEnabled="True"
                                                          TextSearch.TextPath="DisplayName"
                                                          ItemsSource="{Binding DataContext.FamilyTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          SelectedItem="{Binding SelectedFamilyType, Mode=TwoWay}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vmup:FamilyTypeOptionViewModel}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Grid Width="24" Height="24" Margin="0,0,8,0">
                                                                    <Border Background="#E0F2FE"
                                                                            CornerRadius="4"
                                                                            Visibility="{Binding HasNoThumbnail, Converter={StaticResource BoolToVisibility}}">
                                                                        <TextBlock Text="F"
                                                                                   FontWeight="Bold"
                                                                                   Foreground="{StaticResource PrimaryDarkBrush}"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"
                                                                                   FontSize="10" />
                                                                    </Border>
                                                                    <Image Source="{Binding Thumbnail}"
                                                                           Width="24" Height="24"
                                                                           Stretch="Uniform"
                                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                                           Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVisibility}}" />
                                                                </Grid>
                                                                <StackPanel VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding FamilyName}"
                                                                               FontSize="12"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding TypeName}"
                                                                                   FontSize="11"
                                                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                                                        <TextBlock Text=" · "
                                                                                   FontSize="11"
                                                                                   Foreground="{StaticResource MutedBrush}" />
                                                                        <TextBlock Text="{Binding CategoryName}"
                                                                                   FontSize="11"
                                                                                   Foreground="{StaticResource MutedBrush}" />
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>

                                                <TextBox Grid.Column="3"
                                                         Margin="0,0,4,0"
                                                         HorizontalContentAlignment="Center"
                                                         Text="{Binding MinMetersText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" />

                                                <TextBox Grid.Column="4"
                                                         Margin="0,0,4,0"
                                                         HorizontalContentAlignment="Center"
                                                         Text="{Binding MaxMetersText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" />

                                                <Border Grid.Column="5"
                                                        Margin="4,0,4,0"
                                                        CornerRadius="10"
                                                        Padding="8,4"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{StaticResource ChipOkBackgroundBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsOk}" Value="False">
                                                                    <Setter Property="Background" Value="{StaticResource ChipWarningBackgroundBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock VerticalAlignment="Center" FontSize="11">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="✓" />
                                                                    <Setter Property="Foreground" Value="{StaticResource ChipOkForegroundBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsOk}" Value="False">
                                                                            <Setter Property="Text" Value="⚠" />
                                                                            <Setter Property="Foreground" Value="{StaticResource ChipWarningForegroundBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Margin="6,0,0,0"
                                                                   Text="{Binding StatusLabel}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource ChipTextStyle}">
                                                                    <Setter Property="Foreground" Value="{StaticResource ChipOkForegroundBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsOk}" Value="False">
                                                                            <Setter Property="Foreground" Value="{StaticResource ChipWarningForegroundBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>

                                                <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Button Style="{StaticResource IconActionButtonStyle}"
                                                            Click="OnDuplicateRuleClicked"
                                                            Tag="{Binding}"
                                                            ToolTip="Duplicar"
                                                            Content="❐" />
                                                    <Button Style="{StaticResource IconActionButtonStyle}"
                                                            Click="OnDeleteRuleClicked"
                                                            Tag="{Binding}"
                                                            ToolTip="Excluir"
                                                            Content="🗑" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </Grid>
                    </ScrollViewer>

                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Foreground="{StaticResource MutedBrush}"
                               Text="Crie um grupo no painel à esquerda para começar."
                               Visibility="{Binding HasActiveGroup, Converter={StaticResource InverseBoolToVisibility}}" />
                </Grid>
            </Border>
        </Grid>

        <!-- Footer: last execution + primary action -->
        <Border Grid.Row="2" Grid.ColumnSpan="2"
                Background="#FFFFFF"
                BorderBrush="{StaticResource SoftBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="18,10,18,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontWeight="SemiBold"
                                   Text="{Binding LastSummaryHeader}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                                Visibility="{Binding HasLastSummary, Converter={StaticResource BoolToVisibility}}">
                        <Border Background="#EFF6FF" CornerRadius="10" Padding="8,3" Margin="4,0,0,0">
                            <TextBlock Style="{StaticResource ChipTextStyle}"
                                       Foreground="{StaticResource PrimaryDarkBrush}"
                                       Text="{Binding LastSummaryAnalyzedLabel}" />
                        </Border>
                        <Border Background="#ECFEFF" CornerRadius="10" Padding="8,3" Margin="4,0,0,0">
                            <TextBlock Style="{StaticResource ChipTextStyle}"
                                       Foreground="#0E7490"
                                       Text="{Binding LastSummaryFreeLabel}" />
                        </Border>
                        <Border Background="{StaticResource ChipOkBackgroundBrush}" CornerRadius="10" Padding="8,3" Margin="4,0,0,0">
                            <TextBlock Style="{StaticResource ChipTextStyle}"
                                       Foreground="{StaticResource ChipOkForegroundBrush}"
                                       Text="{Binding LastSummaryInsertedLabel}" />
                        </Border>
                        <Border Background="{StaticResource ChipWarningBackgroundBrush}" CornerRadius="10" Padding="8,3" Margin="4,0,0,0">
                            <TextBlock Style="{StaticResource ChipTextStyle}"
                                       Foreground="{StaticResource ChipWarningForegroundBrush}"
                                       Text="{Binding LastSummaryWithoutRangeLabel}" />
                        </Border>
                        <Border Background="#FEE2E2" CornerRadius="10" Padding="8,3" Margin="4,0,0,0">
                            <TextBlock Style="{StaticResource ChipTextStyle}"
                                       Foreground="#B91C1C"
                                       Text="{Binding LastSummaryErrorsLabel}" />
                        </Border>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,18,0">
                            <TextBlock Style="{StaticResource LabelStyle}" Text="GRUPO ATIVO" />
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="{Binding ActiveGroupName}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,18,0">
                            <TextBlock Style="{StaticResource LabelStyle}" Text="REGRAS VÁLIDAS" />
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="✓"
                                           Foreground="{StaticResource SuccessBrush}"
                                           FontWeight="Bold"
                                           FontSize="12" />
                                <TextBlock Margin="6,0,0,0"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="{Binding ActiveGroupValidRulesLabel}" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Margin="0,0,18,0">
                            <TextBlock Style="{StaticResource LabelStyle}" Text="TIPOS AUSENTES" />
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="⚠"
                                           Foreground="{StaticResource WarningBrush}"
                                           FontWeight="Bold"
                                           FontSize="12" />
                                <TextBlock Margin="6,0,0,0"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="{Binding ActiveGroupMissingTypesLabel}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="18,0"
                            MinWidth="0"
                            IsEnabled="{Binding IsIdle}"
                            Click="OnPickAndInsertClicked"
                            Content="▶  Ativar inserção de pontos" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
