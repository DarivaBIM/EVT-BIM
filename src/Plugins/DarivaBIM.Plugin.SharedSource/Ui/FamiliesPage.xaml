<Page x:Class="DarivaBIM.Plugin.Ui.FamiliesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="clr-namespace:DarivaBIM.Plugin.Ui"
      Title="FamiliesPage"
      Loaded="OnPageLoaded"
      Background="{DynamicResource Paper}"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DarivaTokens.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <!--
            Skeleton/shimmer resources. x:Shared="False" forces WPF to mint a
            fresh brush instance for every consumer, so each placeholder owns
            its own (unfrozen) RelativeTransform that the storyboard can drive
            independently — without this, the brush ends up frozen and the
            animation silently no-ops.
        -->
        <LinearGradientBrush x:Key="ShimmerBrush"
                             x:Shared="False"
                             StartPoint="0,0.5"
                             EndPoint="1,0.5">
            <GradientStop Color="#E5EBF1" Offset="0.0" />
            <GradientStop Color="#F1F5F9" Offset="0.5" />
            <GradientStop Color="#E5EBF1" Offset="1.0" />
            <LinearGradientBrush.RelativeTransform>
                <TranslateTransform X="-1" />
            </LinearGradientBrush.RelativeTransform>
        </LinearGradientBrush>

        <Style x:Key="SkeletonShape" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ShimmerBrush}" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.RelativeTransform).(TranslateTransform.X)"
                                From="-1"
                                To="2"
                                Duration="0:0:1.4"
                                RepeatBehavior="Forever" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <!--
            Tag dot: a 28px circular ToggleButton that visually represents
            one system (água fria, esgoto, pluvial, ...). The chip ALWAYS
            shows the category pastel (BackgroundBrush) so each system reads
            at a glance whether it's selected or not. Selection is signaled
            by a 2px colored ring around the chip (ForegroundBrush — the
            category accent), which is unambiguous without competing with
            the fill.

            Visual states:
              · Default — pastel fill, no ring.
              · Hover (unchecked) — pastel fill, hairline gray ring +
                tiny scale-up so the dot feels interactive.
              · Checked — pastel fill, 2px ring in the category accent
                color (e.g., #1565C0 around an Água Fria chip).

            Accessibility: the system name is exposed both as ToolTip and
            AutomationProperties.Name so screen readers can announce the
            filter; the glyph is decorative.
        -->
        <Style x:Key="TagDotStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,4,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid SnapsToDevicePixels="True">
                            <!--
                                Estados:
                                  · Inativo: bolinha Surface (branca) + borda
                                    hairline. Ícone do sistema sempre visível.
                                  · Hover (inativo): borda escurece para InkFaint.
                                  · Ativo: bolinha colorida no pastel do sistema,
                                    borda 2px na cor de marca, e um anel externo
                                    (DotGlow) translúcido na cor de marca que
                                    estende o feedback além da borda — emulando
                                    o "halo" da spec, sem usar DropShadow (que
                                    seria mais caro de animar).

                                A geometria: a bolinha principal mede 40 e o
                                glow externo 48 (= Width do ToggleButton),
                                então a margem entre eles é 4px de cada lado.
                                Ícone 26px dá respiro generoso pra acomodar
                                os PNGs sem espremer.
                            -->
                            <Ellipse x:Name="DotGlow"
                                     Width="48"
                                     Height="48"
                                     Fill="Transparent" />

                            <Ellipse x:Name="DotFill"
                                     Width="40"
                                     Height="40"
                                     Fill="{DynamicResource Surface}"
                                     Stroke="{DynamicResource Line}"
                                     StrokeThickness="1" />

                            <!-- 24×24 dentro do DotFill 40×40 dá 8px de margem
                                 cada lado. Como agora o ícone é vetor (DrawingImage)
                                 não há perda de nitidez. -->
                            <Image x:Name="DotIcon"
                                   Source="{Binding Icon}"
                                   Width="24"
                                   Height="24"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   SnapsToDevicePixels="True"
                                   Visibility="Collapsed" />

                            <TextBlock x:Name="DotGlyph"
                                       Text="{Binding Glyph}"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding ForegroundBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsChecked" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="DotFill" Property="Stroke" Value="{DynamicResource InkFaint}" />
                            </MultiTrigger>

                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="DotGlow" Property="Fill" Value="{Binding BackgroundBrush}" />
                                <Setter TargetName="DotGlow" Property="Opacity" Value="0.55" />
                                <Setter TargetName="DotFill" Property="Fill" Value="{Binding BackgroundBrush}" />
                                <Setter TargetName="DotFill" Property="Stroke" Value="{Binding ForegroundBrush}" />
                                <Setter TargetName="DotFill" Property="StrokeThickness" Value="2" />
                            </Trigger>

                            <DataTrigger Binding="{Binding HasIcon}" Value="True">
                                <Setter TargetName="DotIcon" Property="Visibility" Value="Visible" />
                                <Setter TargetName="DotGlyph" Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.04" ScaleY="1.04" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--
            Section header toggle for the entire filter panel. Clicking the
            chevron + "Filtrar por sistema" label expands/collapses the dots
            area below. Default = collapsed so the gallery reclaims vertical
            space until the user actively wants to filter.
        -->
        <Style x:Key="FilterSectionToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0,3" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource InkSoft}" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="8">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              RecognizesAccessKey="False" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Ink}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ClearTagsButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource InkSoft}" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--
            Skeleton card. Espelha as proporções do FamilyCardStyle para que
            o load não dê "salto" visual quando o ListBox real toma o lugar
            do skeleton: largura 168, thumb 150, body com 2 linhas de texto
            e bolinhas de sistema.
        -->
        <DataTemplate x:Key="SkeletonCardTemplate">
            <Border Width="168"
                    Background="{DynamicResource Surface}"
                    BorderBrush="{DynamicResource Line}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Margin="5"
                    ClipToBounds="True">
                <StackPanel>
                    <!-- Thumb -->
                    <Border Style="{StaticResource SkeletonShape}"
                            Height="150"
                            CornerRadius="10,10,0,0" />

                    <!-- Body -->
                    <StackPanel Margin="10,8,10,10">
                        <Border Style="{StaticResource SkeletonShape}"
                                Height="11"
                                Width="120"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,5" />

                        <Border Style="{StaticResource SkeletonShape}"
                                Height="9"
                                Width="80"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,10" />

                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource SkeletonShape}"
                                    Height="20"
                                    Width="20"
                                    CornerRadius="10"
                                    Margin="0,0,4,0" />
                            <Border Style="{StaticResource SkeletonShape}"
                                    Height="20"
                                    Width="20"
                                    CornerRadius="10"
                                    Margin="0,0,4,0" />
                            <Border Style="{StaticResource SkeletonShape}"
                                    Height="20"
                                    Width="20"
                                    CornerRadius="10" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!--
            ===== Modo lista =====
            Template alternativo para a galeria. Cada "linha" é um card único
            full-width com layout horizontal (thumb 64×64 à esquerda, texto
            no meio, coração à direita). Usado quando o usuário troca o
            toggle do toolbar para o ícone de lista; em código a página
            faz GalleryList.ItemTemplate = FindResource("GalleryRowListTemplate")
            e força _itemsPerRow=1 para que cada FamilyRow tenha exatamente
            um card.
        -->
        <DataTemplate x:Key="GalleryRowListTemplate">
            <ItemsControl ItemsSource="{Binding Cards}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,8"
                                Style="{StaticResource FamilyCardStyle}"
                                Tag="{Binding}"
                                MouseLeftButtonUp="OnFamilyCardClicked">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="76" />
                                    <ColumnDefinition Width="*" />
                                    <!-- Heart com largura fixa pra que o body
                                         (col 1) tenha espaço determinístico
                                         para os badges de sistema; com Auto
                                         a col 2 podia disputar pixel com o
                                         body em painéis estreitos. -->
                                    <ColumnDefinition Width="34" />
                                </Grid.ColumnDefinitions>

                                <!-- Thumb: 76×76, raio só nos cantos esquerdos.
                                     Fundo branco (Surface) para camuflar imagens
                                     de família que vêm com fundo branco. -->
                                <Border Grid.Column="0"
                                        Background="{DynamicResource Surface}"
                                        CornerRadius="10,0,0,10">
                                    <Image ui:CachedImage.SourceUrl="{Binding UrlImg}"
                                           Width="64"
                                           Height="64"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           SnapsToDevicePixels="True"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                </Border>

                                <!-- Body: nome (top), data, sistemas (bottom).
                                     Margin direito de 8px protege o último badge
                                     do WrapPanel de encostar no card edge — sem
                                     ele, o BorderThickness do badge ficava
                                     visualmente cortado pelo ClipToBounds do
                                     FamilyCardStyle. -->
                                <StackPanel Grid.Column="1"
                                            Margin="12,8,8,8"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               FontFamily="{DynamicResource BodyFont}"
                                               FontSize="12.5"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Ink}"
                                               LineHeight="15"
                                               LineStackingStrategy="BlockLineHeight"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis" />

                                    <TextBlock Text="{Binding UpdatedAtLabel, StringFormat='Atualizado em {0}'}"
                                               FontFamily="{DynamicResource BodyFont}"
                                               FontSize="10.5"
                                               Foreground="{DynamicResource InkSoft}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,3,0,6" />

                                    <!-- WrapPanel para os badges quebrarem para
                                         a próxima linha se a col 1 ficar
                                         estreita demais (em vez de extrapolar
                                         a coluna e ser cortado pelo ClipToBounds
                                         do FamilyCardStyle). -->
                                    <ItemsControl ItemsSource="{Binding SistemaBadges}"
                                                  HorizontalAlignment="Left">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="18"
                                                        Height="18"
                                                        Background="{Binding BackgroundBrush}"
                                                        BorderBrush="{Binding BorderBrush}"
                                                        BorderThickness="0.5"
                                                        CornerRadius="9"
                                                        Margin="0,0,3,0"
                                                        ToolTip="{Binding Label}"
                                                        ToolTipService.InitialShowDelay="200"
                                                        AutomationProperties.Name="{Binding Label}">
                                                    <Image Source="{Binding Icon}"
                                                           Width="11"
                                                           Height="11"
                                                           Stretch="Uniform"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           SnapsToDevicePixels="True"
                                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- Heart: top-right. Mesma lógica do grid card. -->
                                <ToggleButton Grid.Column="2"
                                              VerticalAlignment="Top"
                                              Margin="0,8,8,0"
                                              Width="26"
                                              Height="26"
                                              Cursor="Hand"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              IsChecked="{Binding IsFavorita, Mode=OneWay}"
                                              Click="OnFavoriteHeartClick"
                                              ToolTip="Favoritar"
                                              AutomationProperties.Name="Favoritar">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border CornerRadius="13"
                                                    Background="{TemplateBinding Background}">
                                                <TextBlock x:Name="HeartIcon"
                                                           Text="♡"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource InkSoft}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="HeartIcon" Property="Text" Value="♥" />
                                                    <Setter TargetName="HeartIcon" Property="Foreground" Value="{DynamicResource Heart}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </DataTemplate>

        <!--
            ===== Rail =====
            Aba do rail à esquerda. Selecionada: fundo `RailActive`, ícone Ink.
            Inativa: transparente, ícone InkSoft. Hover (inativa): LineSoft.
            36×36 com raio 9 — tamanho-alvo confortável para click sem
            ocupar muito espaço vertical num painel estreito.
        -->
        <Style x:Key="RailTabStyle" TargetType="RadioButton">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource InkSoft}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd"
                                CornerRadius="9"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource LineSoft}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource RailActive}" />
                                <Setter Property="Foreground" Value="{DynamicResource Ink}" />
                                <Setter TargetName="bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="6" Opacity="0.06" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--
            Botão só-ícone do rail (engrenagem). Mesmo template do
            RailTabStyle sem o trigger de IsChecked, para que o hover
            funcione mas o estado "ativo" só pertença às abas.
        -->
        <Style x:Key="RailIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource InkSoft}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="9"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource LineSoft}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--
            ===== Toolbar =====
            Botão de sort do toolbar. Pill arredondado: borda hairline +
            fundo Surface, hover puxa LineSoft. O Border do template lê
            BorderBrush/BorderThickness do estilo pelo TemplateBinding,
            então o SortMenuItemStyle (popup) consegue zerar a borda
            sem precisar redefinir o template inteiro.
        -->
        <Style x:Key="ToolbarSortButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource InkSoft}" />
            <Setter Property="FontFamily" Value="{DynamicResource BodyFont}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource LineSoft}" />
                                <Setter Property="Foreground" Value="{DynamicResource Ink}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Item do popup de sort. Estende o ToolbarSortButtonStyle e
             desfaz o pill (borda + fundo) para que cada item se comporte
             como linha plana de menu, mantendo só o hover de fundo do
             pai para feedback. -->
        <Style x:Key="SortMenuItemStyle"
               TargetType="Button"
               BasedOn="{StaticResource ToolbarSortButtonStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="MinWidth" Value="140" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <!--
            Toggle de modo de exibição (grade/lista). RadioButton agrupado
            em "ViewMode". Quando checked, ganha fundo Paper + sombra leve
            para destacar do trilho cinza atrás.
        -->
        <Style x:Key="ViewToggleButtonStyle" TargetType="RadioButton">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource InkSoft}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd"
                                CornerRadius="5"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource Paper}" />
                                <Setter Property="Foreground" Value="{DynamicResource Ink}" />
                                <Setter TargetName="bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="2" Opacity="0.10" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Texto do footer (status + versão). -->
        <Style x:Key="FooterTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{DynamicResource BodyFont}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource InkSoft}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Estilo do "v X.Y.Z" — usa InkFaint pra dar hierarquia em
             relação ao "Sincronizado" (que é InkSoft). -->
        <Style x:Key="FooterVersionStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource FooterTextStyle}">
            <Setter Property="Foreground" Value="{DynamicResource InkFaint}" />
        </Style>

        <!--
            ScrollBar fina (8px) e discreta para a galeria. Sem botões de
            seta nas pontas, sem borda no track, thumb arredondado em
            InkFaint com opacidade que cresce em hover/drag para feedback.

            Style sem x:Key — afeta toda ScrollBar dentro desta Page. Hoje
            o único consumidor é o ScrollViewer interno do GalleryList; o
            popup do sort é pequeno demais pra precisar scroll. RepeatButtons
            sobrevivem (transparentes) para que o paging por click no track
            continue funcionando.

            Performance: nenhum DropShadowEffect, nenhuma animação contínua;
            só dois triggers de Opacity. Render-thread.
        -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="8" />
                    <Setter Property="MinWidth" Value="8" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="{TemplateBinding Background}">
                                    <Track x:Name="PART_Track" IsDirectionReversed="True">
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border x:Name="thumbBorder"
                                                                Background="{DynamicResource InkFaint}"
                                                                CornerRadius="4"
                                                                Margin="2"
                                                                Opacity="0.35"
                                                                SnapsToDevicePixels="True" />
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="thumbBorder" Property="Opacity" Value="0.65" />
                                                            </Trigger>
                                                            <Trigger Property="IsDragging" Value="True">
                                                                <Setter TargetName="thumbBorder" Property="Opacity" Value="0.85" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageDownCommand">
                                                <RepeatButton.Template>
                                                    <ControlTemplate TargetType="RepeatButton">
                                                        <Border Background="Transparent" />
                                                    </ControlTemplate>
                                                </RepeatButton.Template>
                                            </RepeatButton>
                                        </Track.IncreaseRepeatButton>
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageUpCommand">
                                                <RepeatButton.Template>
                                                    <ControlTemplate TargetType="RepeatButton">
                                                        <Border Background="Transparent" />
                                                    </ControlTemplate>
                                                </RepeatButton.Template>
                                            </RepeatButton>
                                        </Track.DecreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="56" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--
            ===== RAIL =====
            Coluna fixa de 56px à esquerda. Logo DarivaBIM no topo, abas de
            navegação no meio, settings + avatar embaixo. Borda hairline
            direita para separar visualmente do painel principal.
        -->
        <Border Grid.Column="0"
                Background="{DynamicResource Rail}"
                BorderBrush="{DynamicResource Line}"
                BorderThickness="0,0,0.5,0">
            <DockPanel LastChildFill="False">

                <!--
                    Logo DarivaBIM (rail superior). Path SVG da marca
                    convertido para XAML — viewBox 256×256 com 6 subpaths
                    que formam o cubo logotipo. Renderiza nítido em qualquer
                    DPI porque é vetor; Viewbox cuida do downscale para
                    o tile 36×36 sem perda.
                -->
                <Border DockPanel.Dock="Top"
                        Width="36"
                        Height="36"
                        CornerRadius="9"
                        Background="{DynamicResource LogoTile}"
                        Margin="10,12,10,14">
                    <Viewbox Margin="5"
                             SnapsToDevicePixels="True"
                             UseLayoutRounding="True">
                        <Canvas Width="256" Height="256">
                            <Path Fill="White"
                                  Data="M87.3412 108.871L53 89.242V168.973L87.3412 149.345V108.871Z M169.054 108.911L203.394 89.283V169.014L169.054 149.385V108.911Z M203.45 82.1898L203.338 82.1266V80.6797V64.202V43L165.769 65.2644L130.249 44.9614V84.3453L165.655 104.582L203.45 82.1898Z M130.249 173.87V213L199.885 173.198L165.655 153.633L130.249 173.87Z M89.8419 104.582L125.248 84.3453V44.9614L55.3903 84.8905L89.8419 104.582Z M55.6124 173.198L125.248 213V173.87L89.8414 153.633L55.6124 173.198Z" />
                        </Canvas>
                    </Viewbox>
                </Border>

                <!-- 5 abas (RadioButton agrupado em MainNav: só uma checked
                     por vez). Tag carrega o id da aba pra OnRailTabChecked
                     ler em vez de switch nominal. -->
                <StackPanel DockPanel.Dock="Top"
                            HorizontalAlignment="Center">
                    <RadioButton x:Name="TabAll"
                                 Style="{StaticResource RailTabStyle}"
                                 GroupName="MainNav"
                                 IsChecked="True"
                                 Tag="all"
                                 Checked="OnRailTabChecked"
                                 ToolTip="Todas"
                                 AutomationProperties.Name="Todas">
                        <TextBlock Text="&#xE7B8;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="17" />
                    </RadioButton>
                    <RadioButton x:Name="TabFavorites"
                                 Style="{StaticResource RailTabStyle}"
                                 GroupName="MainNav"
                                 Tag="fav"
                                 Checked="OnRailTabChecked"
                                 ToolTip="Favoritas"
                                 AutomationProperties.Name="Favoritas">
                        <TextBlock Text="&#xEB52;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="17" />
                    </RadioButton>
                    <RadioButton x:Name="TabRecent"
                                 Style="{StaticResource RailTabStyle}"
                                 GroupName="MainNav"
                                 Tag="recent"
                                 Checked="OnRailTabChecked"
                                 ToolTip="Recentes"
                                 AutomationProperties.Name="Recentes">
                        <TextBlock Text="&#xE823;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="17" />
                    </RadioButton>
                    <RadioButton x:Name="TabPopular"
                                 Style="{StaticResource RailTabStyle}"
                                 GroupName="MainNav"
                                 Tag="popular"
                                 Checked="OnRailTabChecked"
                                 ToolTip="Populares"
                                 AutomationProperties.Name="Populares">
                        <TextBlock Text="&#xEB05;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="17" />
                    </RadioButton>
                    <RadioButton x:Name="TabCollections"
                                 Style="{StaticResource RailTabStyle}"
                                 GroupName="MainNav"
                                 Tag="collections"
                                 Checked="OnRailTabChecked"
                                 ToolTip="Coleções"
                                 AutomationProperties.Name="Coleções">
                        <TextBlock Text="&#xE8B7;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="17" />
                    </RadioButton>
                </StackPanel>

                <!-- Avatar circular (placeholder). Gradient coral espelha o
                     accent — encaixa no tema sem precisar de PNG. -->
                <Border DockPanel.Dock="Bottom"
                        Width="30"
                        Height="30"
                        CornerRadius="15"
                        Margin="13,8,13,12">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{StaticResource AccentColor}" Offset="0" />
                            <GradientStop Color="#E68A56" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="MA"
                               Foreground="White"
                               FontSize="11"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <!-- Settings (placeholder; clique não wireado ainda). -->
                <Button DockPanel.Dock="Bottom"
                        Style="{StaticResource RailIconButtonStyle}"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,4"
                        ToolTip="Configurações"
                        AutomationProperties.Name="Configurações">
                    <TextBlock Text="&#xE713;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="17" />
                </Button>

            </DockPanel>
        </Border>

        <!--
            ===== CONTENT =====
            Painel direito: header (eyebrow + título + busca), filtros
            colapsáveis, toolbar (count/sort/view), galeria, footer status.
        -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="44" />
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0"
                    BorderBrush="{DynamicResource Line}"
                    BorderThickness="0,0,0,1">
                <StackPanel Margin="20,16,20,16">
                    <TextBlock Text="IMPORTAR FAMÍLIAS"
                               Style="{StaticResource EyebrowTextStyle}"
                               Margin="0,0,0,2" />
                    <TextBlock x:Name="HeaderTitleText"
                               Text="Tigre"
                               Style="{StaticResource HeaderTitleStyle}"
                               Margin="0,0,0,10" />

                    <!-- SearchBar — borda hairline, raio 10, lupa Segoe MDL2.
                         No foco do TextBox interno o Border ganha borda
                         Accent 1px (IsKeyboardFocusWithin propaga o estado
                         do filho até aqui sem precisar de event handler). -->
                    <Border CornerRadius="10"
                            Height="36">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource Surface}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource Line}" />
                                <Setter Property="BorderThickness" Value="0.5" />
                                <Style.Triggers>
                                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="&#xE721;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Foreground="{DynamicResource InkFaint}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />

                            <TextBox x:Name="SearchTextBox"
                                     Grid.Column="1"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="{DynamicResource Ink}"
                                     FontSize="12"
                                     VerticalContentAlignment="Center"
                                     Padding="0,0,10,0"
                                     TextChanged="OnSearchTextChanged"
                                     ToolTip="Buscar família, código, tag…" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!--
                FILTROS por sistema. Sempre visível (14 chips fixos, mesmo
                com 0 famílias na categoria). Chevron à esquerda recolhe
                a área dos chips para liberar espaço vertical à galeria.
            -->
            <Border x:Name="TagFiltersCard"
                    Grid.Row="1"
                    BorderBrush="{DynamicResource Line}"
                    BorderThickness="0,0,0,1"
                    Padding="20,12,20,12">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ToggleButton x:Name="FilterSectionToggle"
                                      Grid.Column="0"
                                      Style="{StaticResource FilterSectionToggleStyle}"
                                      IsChecked="False"
                                      Checked="OnFilterSectionToggled"
                                      Unchecked="OnFilterSectionToggled">
                            <StackPanel Orientation="Horizontal">
                                <!-- Glyph de funil (Segoe MDL2 E71C). Reforça
                                     que esta é uma seção de filtro mesmo com
                                     a lista de chips colapsada. -->
                                <TextBlock Text="&#xE71C;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="12"
                                           Foreground="{DynamicResource InkSoft}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="Filtrar por sistema"
                                           FontFamily="{DynamicResource BodyFont}"
                                           FontSize="11.5"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource InkSoft}"
                                           VerticalAlignment="Center" />
                                <!-- Badge contador. Visibility e Text são
                                     atualizados em UpdateClearTagsButton no
                                     code-behind, junto com o botão Limpar
                                     (mesmo gatilho: _selectedSistemaIds). -->
                                <Border x:Name="FilterCountBadge"
                                        Background="{DynamicResource Heart}"
                                        CornerRadius="9"
                                        MinWidth="18"
                                        Height="18"
                                        Margin="8,0,0,0"
                                        Padding="5,0"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                    <TextBlock x:Name="FilterCountText"
                                               Text="0"
                                               FontFamily="{DynamicResource BodyFont}"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <!-- Chevron de expandir/recolher (E76C ↓ /
                                     E70D ↑). O code-behind reescreve o glyph
                                     em ApplyFilterSectionState. -->
                                <TextBlock x:Name="FilterSectionChevron"
                                           Text="&#xE76C;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="11"
                                           Foreground="{DynamicResource InkFaint}"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0" />
                            </StackPanel>
                        </ToggleButton>

                        <Button x:Name="ClearTagsButton"
                                Grid.Column="1"
                                Content="Limpar"
                                Style="{StaticResource ClearTagsButtonStyle}"
                                Click="OnClearTagsClicked"
                                Visibility="Collapsed" />
                    </Grid>

                    <ItemsControl x:Name="TagFiltersHost"
                                  Margin="0,10,0,0"
                                  Visibility="Collapsed">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ToggleButton IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Style="{StaticResource TagDotStyle}"
                                              ToolTip="{Binding Description}"
                                              ToolTipService.InitialShowDelay="200"
                                              ToolTipService.ShowDuration="8000"
                                              AutomationProperties.Name="{Binding Description}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- TOOLBAR: contador à esquerda, sort + view-toggle à direita. -->
            <Border Grid.Row="2"
                    BorderBrush="{DynamicResource Line}"
                    BorderThickness="0,0,0,1"
                    Padding="20,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="ToolbarCountNumber"
                                   Text="0"
                                   FontFamily="{DynamicResource BodyFont}"
                                   FontSize="11.5"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Ink}" />
                        <TextBlock x:Name="ToolbarCountLabel"
                                   Text=" famílias"
                                   FontFamily="{DynamicResource BodyFont}"
                                   FontSize="11.5"
                                   Foreground="{DynamicResource InkSoft}"
                                   Margin="2,0,0,0" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            x:Name="SortButton"
                            Style="{StaticResource ToolbarSortButtonStyle}"
                            Margin="0,0,8,0"
                            Click="OnSortButtonClicked">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8CB;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="11"
                                       Margin="0,0,5,0"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="SortLabel"
                                       Text="Atualização"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="&#xE70D;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="9"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Popup x:Name="SortPopup"
                           PlacementTarget="{Binding ElementName=SortButton}"
                           Placement="Bottom"
                           StaysOpen="False"
                           AllowsTransparency="True">
                        <Border Background="{DynamicResource Surface}"
                                BorderBrush="{DynamicResource Line}"
                                BorderThickness="0.5"
                                CornerRadius="8"
                                Padding="4"
                                Margin="0,4,0,0">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2"
                                                  BlurRadius="12"
                                                  Opacity="0.10" />
                            </Border.Effect>
                            <StackPanel>
                                <Button Style="{StaticResource SortMenuItemStyle}"
                                        Tag="updated"
                                        Click="OnSortItemClicked"
                                        Content="Atualização" />
                                <Button Style="{StaticResource SortMenuItemStyle}"
                                        Tag="name"
                                        Click="OnSortItemClicked"
                                        Content="Nome A–Z" />
                                <Button Style="{StaticResource SortMenuItemStyle}"
                                        Tag="newest"
                                        Click="OnSortItemClicked"
                                        Content="Mais novas" />
                            </StackPanel>
                        </Border>
                    </Popup>

                    <Border Grid.Column="2"
                            Background="{DynamicResource LineSoft}"
                            CornerRadius="6"
                            Padding="2">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="ViewGrid"
                                         GroupName="ViewMode"
                                         IsChecked="True"
                                         Style="{StaticResource ViewToggleButtonStyle}"
                                         Tag="grid"
                                         Checked="OnViewModeChanged"
                                         ToolTip="Grade"
                                         AutomationProperties.Name="Grade">
                                <TextBlock Text="&#xF0E2;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="11" />
                            </RadioButton>
                            <RadioButton x:Name="ViewList"
                                         GroupName="ViewMode"
                                         Style="{StaticResource ViewToggleButtonStyle}"
                                         Tag="list"
                                         Checked="OnViewModeChanged"
                                         ToolTip="Lista"
                                         AutomationProperties.Name="Lista">
                                <TextBlock Text="&#xE8FD;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="11" />
                            </RadioButton>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- GALLERY (skeleton + listbox + empty + overlay).
                 Margin 15 + card margin 5 = 20px de respiro lateral
                 conforme spec da paleta Cromatica. -->
            <Grid Grid.Row="3" Margin="15,12,15,12">
                <ItemsControl x:Name="SkeletonHost"
                              Visibility="Visible"
                              IsHitTestVisible="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <StaticResource ResourceKey="SkeletonCardTemplate" />
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ListBox x:Name="GalleryList"
                         Visibility="Collapsed"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="0"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         VirtualizingPanel.ScrollUnit="Pixel"
                         VirtualizingPanel.CacheLengthUnit="Pixel"
                         VirtualizingPanel.CacheLength="200,200"
                         SizeChanged="OnGallerySizeChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Focusable" Value="False" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <ItemsControl ItemsSource="{Binding Cards}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!--
                                            Card 168×~auto. ClipToBounds no
                                            FamilyCardStyle garante que o
                                            background do thumb não vaze pelo
                                            raio externo.
                                        -->
                                        <Border Width="168"
                                                Margin="5"
                                                Style="{StaticResource FamilyCardStyle}"
                                                Tag="{Binding}"
                                                MouseLeftButtonUp="OnFamilyCardClicked">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="150" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <!-- Thumb area: branco unificado com o body do card. As
                                                     thumbnails da API costumam vir com fundo branco; manter
                                                     a área branca camufla a borda da imagem e elimina a
                                                     "moldura" cinza que aparecia com gradient. -->
                                                <Border Grid.Row="0"
                                                        Background="{DynamicResource Surface}"
                                                        CornerRadius="10,10,0,0">
                                                    <Grid>
                                                        <Image ui:CachedImage.SourceUrl="{Binding UrlImg}"
                                                               Stretch="Uniform"
                                                               Margin="14"
                                                               SnapsToDevicePixels="True"
                                                               RenderOptions.BitmapScalingMode="HighQuality" />

                                                        <!-- Badge NOVO (visível só pra famílias com CreatedAt recente). -->
                                                        <Border HorizontalAlignment="Left"
                                                                VerticalAlignment="Top"
                                                                Margin="8"
                                                                Background="{DynamicResource Ink}"
                                                                CornerRadius="4"
                                                                Padding="6,2"
                                                                Visibility="{Binding IsNew, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <TextBlock Text="NOVO"
                                                                       Foreground="{DynamicResource Paper}"
                                                                       FontFamily="{DynamicResource BodyFont}"
                                                                       FontSize="9"
                                                                       FontWeight="Bold" />
                                                        </Border>

                                                        <!--
                                                            Coração de favoritar. Two-way bound a
                                                            FamilyCardViewModel.IsFavorita; a página ouve
                                                            o PropertyChanged e sincroniza com o
                                                            FamilyPreferencesService. Ícone Unicode
                                                            (♥/♡) em vez de Segoe MDL2 — robusto a
                                                            mudanças de glyph entre versões da fonte.
                                                        -->
                                                        <!--
                                                            Heart: estado visual via OneWay binding (IsChecked
                                                            só lê IsFavorita, nunca empurra de volta). O
                                                            toggle real é feito no Click handler — TwoWay
                                                            aqui causava feedback loop com o
                                                            FamilyPreferencesService toggle quando havia
                                                            qualquer dessincronia.

                                                            Os PreviewMouse handlers param a fase tunneling
                                                            antes que o ToggleButton dispare o ButtonBase
                                                            click handling, e marcam Handled=true para
                                                            que a fase bubbling do evento mouse não suba
                                                            até OnFamilyCardClicked (que dispararia import).
                                                        -->
                                                        <ToggleButton HorizontalAlignment="Right"
                                                                      VerticalAlignment="Top"
                                                                      Margin="0,8,8,0"
                                                                      Width="26"
                                                                      Height="26"
                                                                      Cursor="Hand"
                                                                      Background="{DynamicResource HeartChipBackground}"
                                                                      BorderThickness="0"
                                                                      IsChecked="{Binding IsFavorita, Mode=OneWay}"
                                                                      Click="OnFavoriteHeartClick"
                                                                      ToolTip="Favoritar"
                                                                      AutomationProperties.Name="Favoritar">
                                                            <ToggleButton.Template>
                                                                <ControlTemplate TargetType="ToggleButton">
                                                                    <Border CornerRadius="13"
                                                                            Background="{TemplateBinding Background}">
                                                                        <TextBlock x:Name="HeartIcon"
                                                                                   Text="♡"
                                                                                   FontSize="14"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="{DynamicResource InkSoft}"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center" />
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsChecked" Value="True">
                                                                            <Setter TargetName="HeartIcon" Property="Text" Value="♥" />
                                                                            <Setter TargetName="HeartIcon" Property="Foreground" Value="{DynamicResource Heart}" />
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </ToggleButton.Template>
                                                        </ToggleButton>
                                                    </Grid>
                                                </Border>

                                                <!-- Body: nome + data + bolinhas de sistema. -->
                                                <StackPanel Grid.Row="1"
                                                            Margin="10,8,10,10">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontFamily="{DynamicResource BodyFont}"
                                                               FontSize="12.5"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource Ink}"
                                                               LineHeight="15"
                                                               LineStackingStrategy="BlockLineHeight"
                                                               TextWrapping="Wrap"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxHeight="32" />

                                                    <TextBlock Text="{Binding UpdatedAtLabel, StringFormat='Atualizado em {0}'}"
                                                               FontFamily="{DynamicResource BodyFont}"
                                                               FontSize="10.5"
                                                               Foreground="{DynamicResource InkSoft}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,3,0,8" />

                                                    <!--
                                                        Bolinhas de sistema (até 3, vindas do mapper). Cada
                                                        uma é um círculo 20×20 com a cor pastel do sistema
                                                        de fundo e o ícone PNG no centro. ToolTip mostra o
                                                        nome cheio.
                                                    -->
                                                    <ItemsControl ItemsSource="{Binding SistemaBadges}"
                                                                  HorizontalAlignment="Left">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal" />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Width="20"
                                                                        Height="20"
                                                                        Background="{Binding BackgroundBrush}"
                                                                        BorderBrush="{Binding BorderBrush}"
                                                                        BorderThickness="0.5"
                                                                        CornerRadius="10"
                                                                        Margin="0,0,4,0"
                                                                        ToolTip="{Binding Label}"
                                                                        ToolTipService.InitialShowDelay="200"
                                                                        ToolTipService.ShowDuration="6000"
                                                                        AutomationProperties.Name="{Binding Label}">
                                                                    <Image Source="{Binding Icon}"
                                                                           Width="12"
                                                                           Height="12"
                                                                           Stretch="Uniform"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           SnapsToDevicePixels="True"
                                                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel x:Name="EmptyStatePanel"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,28,0,10"
                            IsHitTestVisible="False"
                            Visibility="Collapsed">
                    <TextBlock x:Name="EmptyStateIcon"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="28"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8" />
                    <TextBlock x:Name="EmptyStateTitle"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Ink}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center" />
                    <TextBlock x:Name="EmptyStateHint"
                               FontSize="11"
                               Foreground="{DynamicResource InkSoft}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="280"
                               Margin="0,4,0,0" />
                </StackPanel>

            </Grid>

            <!-- FOOTER: status à esquerda + versão à direita.
                 Padding 20,10 e borda superior 1px conforme spec. -->
            <Border Grid.Row="4"
                    Background="{DynamicResource Rail}"
                    BorderBrush="{DynamicResource Line}"
                    BorderThickness="0,1,0,0"
                    Padding="20,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Ellipse x:Name="FooterStatusDot"
                                 Width="7"
                                 Height="7"
                                 Fill="{DynamicResource Success}"
                                 Margin="0,0,8,0"
                                 VerticalAlignment="Center" />
                        <TextBlock x:Name="FooterStatusText"
                                   Text="Sincronizado"
                                   Style="{StaticResource FooterTextStyle}" />
                    </StackPanel>

                    <TextBlock x:Name="FooterVersionText"
                               Grid.Column="1"
                               Text="v 0.0"
                               Style="{StaticResource FooterVersionStyle}" />
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Page>