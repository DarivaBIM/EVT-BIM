<Page x:Class="DarivaBIM.Plugin.Ui.FamiliesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="clr-namespace:DarivaBIM.Plugin.Ui"
      Title="FamiliesPage"
      Loaded="OnPageLoaded"
      Background="#F4F7FB"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SoftBorderBrush" Color="#D8E0EA" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F172A" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#64748B" />
        <SolidColorBrush x:Key="SearchIconBrush" Color="#94A3B8" />

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SoftBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="CardContainerStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource SoftBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="9" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="0"
                                      Opacity="0.09" />
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#C7D9F8" />
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.02" ScaleY="1.02" />
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="24"
                                              ShadowDepth="0"
                                              Opacity="0.16" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="InfoLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#94A3B8" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="InfoValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <!--
            Skeleton/shimmer resources. x:Shared="False" forces WPF to mint a
            fresh brush instance for every consumer, so each placeholder owns
            its own (unfrozen) RelativeTransform that the storyboard can drive
            independently — without this, the brush ends up frozen and the
            animation silently no-ops.
        -->
        <LinearGradientBrush x:Key="ShimmerBrush"
                             x:Shared="False"
                             StartPoint="0,0.5"
                             EndPoint="1,0.5">
            <GradientStop Color="#E5EBF1" Offset="0.0" />
            <GradientStop Color="#F1F5F9" Offset="0.5" />
            <GradientStop Color="#E5EBF1" Offset="1.0" />
            <LinearGradientBrush.RelativeTransform>
                <TranslateTransform X="-1" />
            </LinearGradientBrush.RelativeTransform>
        </LinearGradientBrush>

        <Style x:Key="SkeletonShape" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ShimmerBrush}" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.RelativeTransform).(TranslateTransform.X)"
                                From="-1"
                                To="2"
                                Duration="0:0:1.4"
                                RepeatBehavior="Forever" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <!--
            Tag dot: a 28px circular ToggleButton that visually represents
            one system (água fria, esgoto, pluvial, ...). Selection is
            communicated by a *fill swap* — neutral gray (UnselectedBackgroundBrush)
            when off, the category pastel (BackgroundBrush) when on — instead
            of an extra ring around the chip. Removing that outer ring also
            fixes the icon-clipping that happened when hover scaled the
            checked chip past its parent's bounds.

            Visual states:
              · Default — neutral gray fill, no ring.
              · Hover (unchecked) — same fill, hairline gray ring +
                tiny scale-up so the dot feels interactive without a label.
              · Checked — fill swaps to the category pastel; no ring needed
                because the color reveal carries the signal.

            Accessibility: the system name is exposed both as ToolTip and
            AutomationProperties.Name so screen readers can announce the
            filter; the glyph is decorative.
        -->
        <Style x:Key="TagDotStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid SnapsToDevicePixels="True">
                            <Ellipse x:Name="DotFill"
                                     Width="28"
                                     Height="28"
                                     Fill="{Binding UnselectedBackgroundBrush}" />

                            <Ellipse x:Name="DotRing"
                                     Width="28"
                                     Height="28"
                                     Stroke="Transparent"
                                     StrokeThickness="1.5" />

                            <!--
                                Icon image: visible when TagFilterOption.HasIcon is true
                                (PNG file present in Resources/FilterIcons). Otherwise
                                the Segoe MDL2 glyph below is shown as fallback. Sizing
                                stays inside the 28px ellipse so the chip shape reads
                                first; the icon adds the system-specific cue.
                            -->
                            <Image x:Name="DotIcon"
                                   Source="{Binding Icon}"
                                   Width="20"
                                   Height="20"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   SnapsToDevicePixels="True"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Visibility="Collapsed" />

                            <TextBlock x:Name="DotGlyph"
                                       Text="{Binding Glyph}"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding ForegroundBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsChecked" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="DotRing" Property="Stroke" Value="#94A3B8" />
                            </MultiTrigger>

                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="DotFill" Property="Fill" Value="{Binding BackgroundBrush}" />
                            </Trigger>

                            <DataTrigger Binding="{Binding HasIcon}" Value="True">
                                <Setter TargetName="DotIcon" Property="Visibility" Value="Visible" />
                                <Setter TargetName="DotGlyph" Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.04" ScaleY="1.04" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--
            Section header toggle for the entire filter panel. Clicking the
            chevron + "Filtrar por sistema" label expands/collapses the dots
            area below. Default = collapsed so the gallery reclaims vertical
            space until the user actively wants to filter.
        -->
        <Style x:Key="FilterSectionToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0,3" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="8">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              RecognizesAccessKey="False" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ClearTagsButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#0F172A" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OverlayButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource SoftBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <DataTemplate x:Key="SkeletonCardTemplate">
            <Border Width="176"
                    Background="White"
                    BorderBrush="{StaticResource SoftBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="9"
                    Margin="6">
                <StackPanel>
                    <Border Style="{StaticResource SkeletonShape}"
                            Width="110"
                            Height="110"
                            CornerRadius="14"
                            HorizontalAlignment="Center" />

                    <Border Style="{StaticResource SkeletonShape}"
                            Height="10"
                            Width="140"
                            HorizontalAlignment="Left"
                            Margin="0,12,0,4" />

                    <Border Style="{StaticResource SkeletonShape}"
                            Height="10"
                            Width="100"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,12" />

                    <StackPanel Orientation="Horizontal">
                        <Border Style="{StaticResource SkeletonShape}"
                                Height="14"
                                Width="40"
                                CornerRadius="9"
                                Margin="0,0,4,0" />
                        <Border Style="{StaticResource SkeletonShape}"
                                Height="14"
                                Width="55"
                                CornerRadius="9" />
                    </StackPanel>

                    <Border Style="{StaticResource SkeletonShape}"
                            Height="8"
                            Width="90"
                            HorizontalAlignment="Left"
                            Margin="0,12,0,0" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Logo Tigre -->
        <Grid Grid.Row="0"
              Margin="0,0,0,15"
              UseLayoutRounding="True"
              SnapsToDevicePixels="True">
            <Image ui:CachedImage.SourceUrl="https://darivabim.s3.sa-east-1.amazonaws.com/manufacturers/ImgLarge/tigre-logo.png"
                   Height="65"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   SnapsToDevicePixels="True"
                   RenderOptions.BitmapScalingMode="HighQuality" />
        </Grid>

        <!-- Powered by DarivaBIM -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0,0,0,10">
            <TextBlock Text="Powered by"
                       FontSize="15"
                       Foreground="#94A3B8"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0" />

            <Image ui:CachedImage.SourceUrl="https://darivabim.s3.sa-east-1.amazonaws.com/manufacturers/ImgLarge/logo_darivabim_semfundo.png"
                   Height="35"
                   Stretch="Uniform"
                   VerticalAlignment="Center" />
        </StackPanel>

        <!-- Busca -->
        <Border Grid.Row="2"
                Style="{StaticResource SectionCardStyle}"
                Padding="10"
                Margin="0,0,0,12">
            <Grid Height="22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="&#xE721;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="13"
                           Foreground="{StaticResource SearchIconBrush}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center" />

                <TextBox x:Name="SearchTextBox"
                         Grid.Column="1"
                         Style="{StaticResource SearchTextBoxStyle}"
                         TextChanged="OnSearchTextChanged"
                         ToolTip="Pesquise por nome, fabricante, tags e palavras-chave" />
            </Grid>
        </Border>

        <!--
            Filtros por sistema/tag.

            Whole panel collapses behind the FilterSectionToggle in the
            header — chevron on the left plus "Filtrar por sistema" label.
            Default = collapsed (cards reclaim space). When the user opens
            it, the WrapPanel below shows every chip without inner clipping
            (no row-cap) so the icon scale-on-hover never overflows into
            cropped neighbors.
        -->
        <Border x:Name="TagFiltersCard"
                Grid.Row="3"
                Style="{StaticResource SectionCardStyle}"
                Padding="10"
                Margin="0,0,0,12"
                Visibility="Collapsed">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ToggleButton x:Name="FilterSectionToggle"
                                  Grid.Column="0"
                                  Style="{StaticResource FilterSectionToggleStyle}"
                                  IsChecked="False"
                                  Checked="OnFilterSectionToggled"
                                  Unchecked="OnFilterSectionToggled">
                        <StackPanel Orientation="Horizontal">
                            <!-- ChevronRight (E76C) when collapsed → ChevronDown (E70D) when expanded. -->
                            <TextBlock x:Name="FilterSectionChevron"
                                       Text="&#xE76C;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="10"
                                       Foreground="#94A3B8"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <TextBlock Text="Filtrar por sistema"
                                       Style="{StaticResource InfoLabelStyle}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </ToggleButton>

                    <Button x:Name="ClearTagsButton"
                            Grid.Column="1"
                            Content="Limpar"
                            Style="{StaticResource ClearTagsButtonStyle}"
                            Click="OnClearTagsClicked"
                            Visibility="Collapsed" />
                </Grid>

                <ItemsControl x:Name="TagFiltersHost"
                              Margin="0,10,0,0"
                              Visibility="Collapsed">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ToggleButton IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          Style="{StaticResource TagDotStyle}"
                                          ToolTip="{Binding Description}"
                                          ToolTipService.InitialShowDelay="200"
                                          ToolTipService.ShowDuration="8000"
                                          AutomationProperties.Name="{Binding Description}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Galeria -->
        <Border Grid.Row="4"
                Style="{StaticResource SectionCardStyle}"
                Padding="8">
            <Grid>
                <ItemsControl x:Name="SkeletonHost"
                              Visibility="Visible"
                              IsHitTestVisible="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <StaticResource ResourceKey="SkeletonCardTemplate" />
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ListBox x:Name="GalleryList"
                         Visibility="Collapsed"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="0"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         VirtualizingPanel.ScrollUnit="Pixel"
                         VirtualizingPanel.CacheLengthUnit="Pixel"
                         VirtualizingPanel.CacheLength="200,200"
                         SizeChanged="OnGallerySizeChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Focusable" Value="False" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="176"
                                                Style="{StaticResource CardContainerStyle}"
                                                Tag="{Binding}"
                                                MouseLeftButtonUp="OnFamilyCardClicked">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="2" />
                                                    <RowDefinition Height="35" />
                                                    <RowDefinition Height="2" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="20" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <!-- Imagem -->
                                                <Grid Grid.Row="0"
                                                      Height="110">
                                                    <Image ui:CachedImage.SourceUrl="{Binding UrlImg}"
                                                           Width="110"
                                                           Height="110"
                                                           Stretch="Uniform"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           SnapsToDevicePixels="True"
                                                           RenderOptions.BitmapScalingMode="HighQuality">
                                                        <Image.Clip>
                                                            <RectangleGeometry Rect="0,0,110,110"
                                                                               RadiusX="14"
                                                                               RadiusY="14" />
                                                        </Image.Clip>
                                                    </Image>
                                                </Grid>

                                                <!-- Título -->
                                                <TextBlock Grid.Row="2"
                                                           VerticalAlignment="Center"
                                                           Style="{StaticResource TitleTextStyle}"
                                                           Text="{Binding Name}"
                                                           LineHeight="15"
                                                           MaxHeight="30" />

                                                <!-- Sistemas -->
                                                <ItemsControl Grid.Row="4"
                                                              ItemsSource="{Binding DisplayTagBadges}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>

                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="{Binding Background}"
                                                                    CornerRadius="9"
                                                                    Padding="7,2"
                                                                    Margin="0,2,5,2"
                                                                    ToolTip="{Binding ToolTipText}"
                                                                    ToolTipService.ShowDuration="15000">
                                                                <TextBlock Text="{Binding Text}"
                                                                           FontSize="9"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{Binding Foreground}" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <!-- Data de atualização -->
                                                <Grid Grid.Row="5"
                                                      HorizontalAlignment="Left"
                                                      VerticalAlignment="Center"
                                                      Margin="0,2,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="70" />
                                                        <ColumnDefinition Width="50" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0"
                                                               Text="Atualizado em:"
                                                               Style="{StaticResource InfoLabelStyle}"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" />

                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding UpdatedAtLabel}"
                                                               Style="{StaticResource InfoValueStyle}"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Left" />
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel x:Name="EmptyStatePanel"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,28,0,10"
                            IsHitTestVisible="False"
                            Visibility="Collapsed">
                    <TextBlock x:Name="EmptyStateIcon"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="28"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8" />
                    <TextBlock x:Name="EmptyStateTitle"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center" />
                    <TextBlock x:Name="EmptyStateHint"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="280"
                               Margin="0,4,0,0" />
                </StackPanel>

                <!--
                    Download overlay: covers the gallery while a family is being
                    fetched. Semi-translucent so the cards behind hint at the
                    interaction context. Cancellation propagates a CTS into
                    FamilyDownloadService, which honors it on every chunk read.
                -->
                <Border x:Name="DownloadOverlay"
                        Visibility="Collapsed"
                        Background="#E6FFFFFF"
                        CornerRadius="14">
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Margin="24">
                        <TextBlock Text="Baixando família"
                                   HorizontalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />

                        <TextBlock x:Name="DownloadingFamilyName"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="Wrap"
                                   MaxWidth="240"
                                   Margin="0,4,0,14" />

                        <ProgressBar x:Name="DownloadProgressBar"
                                     Height="6"
                                     Width="240"
                                     Minimum="0"
                                     Maximum="1"
                                     Value="0"
                                     IsIndeterminate="True" />

                        <TextBlock x:Name="DownloadProgressLabel"
                                   HorizontalAlignment="Center"
                                   FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,8,0,16"
                                   Text="Conectando..." />

                        <Button x:Name="CancelDownloadButton"
                                Content="Cancelar"
                                Click="OnCancelDownloadClicked"
                                Style="{StaticResource OverlayButtonStyle}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>