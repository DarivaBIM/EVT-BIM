<Page x:Class="DarivaBIM.Plugin.Ui.FamiliesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="FamiliesPage"
      Loaded="OnPageLoaded"
      Background="#F4F7FB"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SoftBorderBrush" Color="#D8E0EA" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F172A" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#64748B" />
        <SolidColorBrush x:Key="SearchIconBrush" Color="#94A3B8" />

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SoftBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="LoadMoreButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,10,0,6" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource SoftBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="10.5" />
        </Style>

        <Style x:Key="CardContainerStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource SoftBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="9" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="0"
                                      Opacity="0.09" />
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#C7D9F8" />
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.02" ScaleY="1.02" />
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="24"
                                              ShadowDepth="0"
                                              Opacity="0.16" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="InfoLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#94A3B8" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="InfoValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>
    </Page.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Logo Tigre -->
        <Grid Grid.Row="0"
              Margin="0,0,0,15"
              UseLayoutRounding="True"
              SnapsToDevicePixels="True">
            <Image Source="https://darivabim.s3.sa-east-1.amazonaws.com/manufacturers/ImgLarge/tigre-logo.png"
                   Height="65"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   SnapsToDevicePixels="True"
                   RenderOptions.BitmapScalingMode="HighQuality" />
        </Grid>

        <!-- Powered by DarivaBIM -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0,0,0,10">
            <TextBlock Text="Powered by"
                       FontSize="15"
                       Foreground="#94A3B8"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0" />

            <Image Source="https://darivabim.s3.sa-east-1.amazonaws.com/manufacturers/ImgLarge/logo_darivabim_semfundo.png"
                   Height="35"
                   Stretch="Uniform"
                   VerticalAlignment="Center" />
        </StackPanel>

        <!-- Busca -->
        <Border Grid.Row="2"
                Style="{StaticResource SectionCardStyle}"
                Padding="10"
                Margin="0,0,0,12">
            <Grid Height="22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="&#xE721;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="13"
                           Foreground="{StaticResource SearchIconBrush}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center" />

                <TextBox x:Name="SearchTextBox"
                         Grid.Column="1"
                         Style="{StaticResource SearchTextBoxStyle}"
                         TextChanged="OnSearchTextChanged"
                         ToolTip="Pesquise por nome, fabricante, tags e palavras-chave" />
            </Grid>
        </Border>

        <!-- Galeria -->
        <Border Grid.Row="3"
                Style="{StaticResource SectionCardStyle}"
                Padding="8">
            <ScrollViewer x:Name="GalleryScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False">
                <StackPanel>
                    <ItemsControl x:Name="FamiliesItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="176"
                                        Style="{StaticResource CardContainerStyle}"
                                        Tag="{Binding}"
                                        MouseLeftButtonUp="OnFamilyCardClicked">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="2" />
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="2" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="20" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Imagem -->
                                        <Grid Grid.Row="0"
                                              Height="110">
                                            <Image Source="{Binding UrlImg}"
                                                   Width="110"
                                                   Height="110"
                                                   Stretch="Uniform"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   SnapsToDevicePixels="True"
                                                   RenderOptions.BitmapScalingMode="HighQuality">
                                                <Image.Clip>
                                                    <RectangleGeometry Rect="0,0,110,110"
                                                                       RadiusX="14"
                                                                       RadiusY="14" />
                                                </Image.Clip>
                                            </Image>
                                        </Grid>

                                        <!-- Título -->
                                        <TextBlock Grid.Row="2"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource TitleTextStyle}"
                                                   Text="{Binding Name}"
                                                   LineHeight="15"
                                                   MaxHeight="30" />

                                        <!-- Sistemas -->
                                        <ItemsControl Grid.Row="4"
                                                      ItemsSource="{Binding DisplayTagBadges}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>

                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{Binding Background}"
                                                            CornerRadius="9"
                                                            Padding="7,2"
                                                            Margin="0,2,5,2"
                                                            ToolTip="{Binding ToolTipText}"
                                                            ToolTipService.ShowDuration="15000">
                                                        <TextBlock Text="{Binding Text}"
                                                                   FontSize="9"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{Binding Foreground}" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Data de atualização -->
                                        <Grid Grid.Row="5"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Margin="0,2,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="70" />
                                                <ColumnDefinition Width="50" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="Atualizado em:"
                                                       Style="{StaticResource InfoLabelStyle}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding UpdatedAtLabel}"
                                                       Style="{StaticResource InfoValueStyle}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Left" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button x:Name="LoadMoreButton"
                            Style="{StaticResource LoadMoreButtonStyle}"
                            Content="Carregar mais"
                            Click="OnLoadMoreClicked"
                            Visibility="Collapsed" />

                    <TextBlock x:Name="EmptyStateTextBlock"
                               Text="Nenhuma família encontrada para o filtro informado."
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#64748B"
                               HorizontalAlignment="Center"
                               Margin="0,18,0,10"
                               Visibility="Collapsed" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>