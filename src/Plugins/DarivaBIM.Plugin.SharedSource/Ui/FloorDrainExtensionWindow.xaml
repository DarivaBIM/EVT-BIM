<Window x:Class="DarivaBIM.Plugin.Ui.FloorDrainExtensionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:common="clr-namespace:DarivaBIM.Presentation.Wpf.Common;assembly=DarivaBIM.Presentation.Wpf"
        Title="Adicionar Prolongadores"
        Width="580"
        MinWidth="480"
        Height="600"
        MinHeight="480"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Background="{DynamicResource AppBgBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        FontFamily="{DynamicResource BodyFont}"
        Loaded="OnWindowLoaded"
        Closing="OnWindowClosing">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/Tokens.xaml" />
                <ResourceDictionary Source="/Themes/Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <common:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
            <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

            <!-- Paleta amber pro pill de estado "ocupado". Tokens.xaml não
                 traz amber (PipeCadMapper não usa) — defino só aqui. -->
            <SolidColorBrush x:Key="AmberBgBrush"     Color="#FFF8E1" />
            <SolidColorBrush x:Key="AmberBorderBrush" Color="#F7D588" />
            <SolidColorBrush x:Key="AmberDeepBrush"   Color="#6A4A05" />
            <SolidColorBrush x:Key="AmberBrush"       Color="#C77A06" />

            <!-- ===== Tipografia ===== -->
            <Style x:Key="HeaderTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            </Style>

            <Style x:Key="SubtitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12.5" />
                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="EyebrowStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="10.5" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource TextSubtleBrush}" />
            </Style>

            <Style x:Key="GroupTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="GroupMetaStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Foreground" Value="{StaticResource TextSubtleBrush}" />
            </Style>

            <Style x:Key="EmptyDropdownStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11.5" />
                <Setter Property="FontStyle" Value="Italic" />
                <Setter Property="Foreground" Value="{StaticResource TextSubtleBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <!-- Badge de diâmetro: pill compacto com AccentSoftBrush. -->
            <Style x:Key="DiameterBadgeStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                <Setter Property="CornerRadius" Value="11" />
                <Setter Property="Padding" Value="10,3" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="MinWidth" Value="74" />
            </Style>

            <Style x:Key="DiameterBadgeTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11.5" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                <Setter Property="HorizontalAlignment" Value="Center" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{StaticResource CardBgBrush}"
            BorderBrush="{StaticResource BorderStrongBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />   <!-- Header -->
                <RowDefinition Height="Auto" />   <!-- Comprimento -->
                <RowDefinition Height="*" />      <!-- Lista -->
                <RowDefinition Height="Auto" />   <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- ===== Header ===== -->
            <Border Grid.Row="0"
                    Background="{StaticResource CardBgBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="22,18,22,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="200" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Style="{StaticResource HeaderTitleStyle}"
                                   Text="Adicionar Prolongadores" />
                        <TextBlock Style="{StaticResource SubtitleStyle}"
                                   Margin="0,6,0,0"
                                   Text="Cria tubos verticais acima de caixas sifonadas, caixas secas e ralos, herdando o diâmetro do conector superior." />
                    </StackPanel>

                    <!-- Status pill: verde quando idle, amber quando IsBusy=true.
                         MaxWidth elástico até 300 + ellipsis pra não quebrar
                         o header quando a mensagem é longa. -->
                    <Border Grid.Column="1"
                            VerticalAlignment="Top"
                            Margin="0,2,0,0"
                            Height="30"
                            Padding="12,0,14,0"
                            CornerRadius="15"
                            MaxWidth="300">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{StaticResource CardBgSubtleBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource AmberBgBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource AmberBorderBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="8" Height="8" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource AmberBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Margin="8,0,0,0"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Text="{Binding StatusMessage}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding StatusMessage}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AmberDeepBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ===== Comprimento ===== -->
            <Border Grid.Row="1"
                    Background="{StaticResource CardBgBrush}"
                    Padding="22,16,22,12">
                <StackPanel>
                    <TextBlock Text="COMPRIMENTO" Style="{StaticResource EyebrowStyle}" Margin="0,0,0,6" />
                    <TextBox x:Name="LengthTextBox"
                             Style="{StaticResource TextBoxStyle}"
                             Tag="m"
                             Width="160"
                             HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <!-- ===== Lista de tipos ===== -->
            <Border Grid.Row="2"
                    Background="{StaticResource AppBgBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,1"
                    Padding="22,14,22,14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="TIPOS DE CAIXA NO PROJETO"
                               Style="{StaticResource EyebrowStyle}"
                               Margin="0,0,0,10" />

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Visibility="{Binding HasGroups, Converter={StaticResource BoolToVisibility}}">
                        <ItemsControl ItemsSource="{Binding BoxGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource CardBgBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="9"
                                            Padding="14,12,14,12"
                                            Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" MinWidth="100" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Checkbox de inclusão do tipo -->
                                            <CheckBox Grid.Row="0" Grid.Column="0"
                                                      Style="{StaticResource CheckBoxStyle}"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,12,0"
                                                      ToolTip="Quando desmarcado, este tipo é ignorado na inserção." />

                                            <!-- Título + contagem -->
                                            <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Style="{StaticResource GroupTitleStyle}"
                                                           Text="{Binding DisplayName}"
                                                           ToolTip="{Binding DisplayName}" />
                                                <TextBlock Style="{StaticResource GroupMetaStyle}"
                                                           Margin="0,3,0,0"
                                                           Text="{Binding InstanceCountLabel}" />
                                            </StackPanel>

                                            <!-- Badge de diâmetro: MinWidth garante que não some
                                                 quando o título é longo; coluna Auto impede que
                                                 o badge fique espremido. -->
                                            <Border Grid.Row="0" Grid.Column="2"
                                                    Style="{StaticResource DiameterBadgeStyle}"
                                                    Margin="10,0,0,0">
                                                <TextBlock Style="{StaticResource DiameterBadgeTextStyle}"
                                                           Text="{Binding DiameterLabel}" />
                                            </Border>

                                            <!-- Dropdown do PipeType ocupa as 3 colunas
                                                 abaixo. Sem expander — escolha sempre visível. -->
                                            <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                                  Margin="0,12,0,0">
                                                <ComboBox Style="{StaticResource ComboBoxStyle}"
                                                          ItemContainerStyle="{StaticResource ComboBoxItemStyle}"
                                                          ItemsSource="{Binding PipeTypes}"
                                                          SelectedItem="{Binding SelectedPipeType, Mode=TwoWay}"
                                                          DisplayMemberPath="Name"
                                                          IsEnabled="{Binding IsSelected}"
                                                          Visibility="{Binding HasPipeTypes, Converter={StaticResource BoolToVisibility}}" />

                                                <TextBlock Style="{StaticResource EmptyDropdownStyle}"
                                                           Text="{Binding EmptyMessage}"
                                                           Visibility="{Binding HasPipeTypes, Converter={StaticResource InverseBoolToVisibility}}" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock Grid.Row="1"
                               Style="{StaticResource SubtitleStyle}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Text="Nenhum tipo de caixa carregado ainda."
                               Visibility="{Binding HasGroups, Converter={StaticResource InverseBoolToVisibility}}" />
                </Grid>
            </Border>

            <!-- ===== Footer ===== -->
            <Border Grid.Row="3"
                    Background="{StaticResource CardBgBrush}"
                    Padding="22,14,22,16">
                <StackPanel>
                    <TextBlock Text="ONDE INSERIR OS PROLONGADORES"
                               Style="{StaticResource EyebrowStyle}"
                               Margin="0,0,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button x:Name="PickButton"
                                Grid.Column="0"
                                Style="{StaticResource GhostButtonStyle}"
                                Content="Selecionar caixas"
                                ToolTip="Permite selecionar caixas no Revit (ignora os checkboxes acima)."
                                IsEnabled="{Binding IsIdle}"
                                Click="OnPickClicked" />

                        <Button x:Name="VisibleInViewButton"
                                Grid.Column="2"
                                Style="{StaticResource GhostButtonStyle}"
                                Content="Visíveis na vista"
                                ToolTip="Insere nas caixas marcadas que estão visíveis na vista ativa."
                                IsEnabled="{Binding IsIdle}"
                                Click="OnVisibleInViewClicked" />

                        <Button x:Name="AllInProjectButton"
                                Grid.Column="4"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Content="Todas marcadas"
                                ToolTip="Insere nas caixas marcadas em todo o projeto."
                                IsEnabled="{Binding IsIdle}"
                                Click="OnAllInProjectClicked" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
