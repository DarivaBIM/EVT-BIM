<Window x:Class="DarivaBIM.Plugin.Ui.FloorDrainExtensionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:common="clr-namespace:DarivaBIM.Presentation.Wpf.Common;assembly=DarivaBIM.Presentation.Wpf"
        Title="Adicionar Prolongadores"
        Width="460"
        MinHeight="320"
        MaxHeight="780"
        SizeToContent="Height"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Background="#F4F7FB"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="OnWindowLoaded"
        Closing="OnWindowClosing">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <common:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />

        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SoftBorderBrush" Color="#D8E0EA" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F172A" />
        <SolidColorBrush x:Key="LabelBrush" Color="#64748B" />
        <SolidColorBrush x:Key="MutedBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="SecondaryBrush" Color="#0EA5E9" />
        <SolidColorBrush x:Key="AccentBrush" Color="#7C3AED" />
        <SolidColorBrush x:Key="ItemBackgroundBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="ItemBorderBrush" Color="#E2E8F0" />

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource LabelBrush}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="HintTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="Foreground" Value="{StaticResource LabelBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="28" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="26" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="10,0" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
        </Style>
        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource SecondaryBrush}" />
        </Style>
        <Style x:Key="AccentActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource LabelBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,12,0,0" />
        </Style>

        <Style x:Key="GroupItemBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ItemBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ItemBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="GroupTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="DiameterBadgeStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryBrush}" />
            <Setter Property="Margin" Value="0,2,0,6" />
        </Style>

        <Style x:Key="EmptyDropdownStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontStyle" Value="Italic" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource CardBackgroundBrush}"
            BorderBrush="{StaticResource SoftBorderBrush}"
            BorderThickness="1"
            CornerRadius="14"
            Margin="12"
            Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="Adicionar Prolongadores"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,4" />
                <TextBlock Style="{StaticResource HintTextStyle}"
                           Text="Cria tubos verticais (prolongadores) acima das caixas sifonadas/secas, herdando o diâmetro do conector de cima. Escolha o tipo de tubo a usar em cada tipo de caixa do projeto." />
            </StackPanel>

            <StackPanel Grid.Row="1">
                <TextBlock Text="Comprimento (m)" Style="{StaticResource FieldLabelStyle}" />
                <TextBox x:Name="LengthTextBox" />
            </StackPanel>

            <TextBlock Grid.Row="2"
                       Text="Tipos de caixa no projeto"
                       Style="{StaticResource FieldLabelStyle}" />

            <Border Grid.Row="3"
                    BorderBrush="{StaticResource ItemBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8"
                    MinHeight="120"
                    MaxHeight="320"
                    Margin="0,0,0,8">
                <Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Visibility="{Binding HasGroups, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl ItemsSource="{Binding BoxGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource GroupItemBorderStyle}">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Style="{StaticResource GroupTitleStyle}"
                                                           Text="{Binding DisplayName}" />
                                                <TextBlock Grid.Column="1"
                                                           Style="{StaticResource DiameterBadgeStyle}"
                                                           Text="{Binding DiameterLabel}" />
                                            </Grid>

                                            <ComboBox ItemsSource="{Binding PipeTypes}"
                                                      SelectedItem="{Binding SelectedPipeType, Mode=TwoWay}"
                                                      DisplayMemberPath="Name"
                                                      Visibility="{Binding HasPipeTypes, Converter={StaticResource BoolToVisibilityConverter}}" />

                                            <TextBlock Style="{StaticResource EmptyDropdownStyle}"
                                                       Text="{Binding EmptyMessage}"
                                                       Visibility="{Binding HasPipeTypes, Converter={StaticResource InverseBoolToVisibility}}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock Style="{StaticResource HintTextStyle}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Text="Nenhum tipo de caixa carregado ainda."
                               Visibility="{Binding HasGroups, Converter={StaticResource InverseBoolToVisibility}}" />
                </Grid>
            </Border>

            <StackPanel Grid.Row="4">
                <TextBlock Text="Onde inserir os prolongadores" Style="{StaticResource FieldLabelStyle}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="PickButton"
                            Grid.Column="0"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Content="Selecionar caixas"
                            ToolTip="Permite selecionar caixas no Revit."
                            IsEnabled="{Binding IsIdle}"
                            Click="OnPickClicked" />

                    <Button x:Name="AllInProjectButton"
                            Grid.Column="2"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Content="Todas do projeto"
                            ToolTip="Insere prolongadores em todas as caixas do projeto."
                            IsEnabled="{Binding IsIdle}"
                            Click="OnAllInProjectClicked" />

                    <Button x:Name="VisibleInViewButton"
                            Grid.Column="4"
                            Style="{StaticResource AccentActionButtonStyle}"
                            Content="Visíveis na vista"
                            ToolTip="Insere prolongadores nas caixas visíveis na vista ativa."
                            IsEnabled="{Binding IsIdle}"
                            Click="OnVisibleInViewClicked" />
                </Grid>
            </StackPanel>

            <TextBlock Grid.Row="5"
                       x:Name="StatusTextBlock"
                       Style="{StaticResource StatusTextStyle}"
                       Text="{Binding StatusMessage}" />
        </Grid>
    </Border>
</Window>
